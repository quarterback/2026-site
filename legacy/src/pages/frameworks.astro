---
import Base from '../layouts/Base.astro';
import HeroCard from '../components/HeroCard.astro';
import Footer from '../components/Footer.astro';

const heroCards = [
  {
    title: "Solving Dating with a Fantasy Draft",
    description: "Swiping is a social disaster. My fix? I replaced the infinite swipe with a 15-pick weekly draft.",
    image: "/img/heypbj.xyz.png",
    href: "/work/heypbj-matching-platform",
    label: "Platform",
  },
  {
    title: "Pricing the AI Futures Market",
    description: "Compute is the new crude. I built the index to track it. From Civic CPI to reasoning models, I engineered the metrics that turn \u201Cblack-box\u201D AI spend into tradable data.",
    image: "/img/occupant.png",
    href: "/work/occupant-ai-benchmarks",
    label: "Product",
  },
  {
    title: "Engineering portable trust",
    description: "Bad actors thrive in silos. I engineered a decentralize clearinghouse that makes niche apps scalable by creating a cross-platform trust layer.",
    image: "/img/glowrm.png",
    href: "/work/glowrm-trust-layer",
    label: "Infrastructure",
  },
  {
    title: "Making Open Licensing Legible",
    description: "Most people open source licenses without understanding. I built a modular license framework that scales with projects.",
    image: "/img/parachute-commons.png",
    href: "/work/parachute-commons-license",
    label: "Infrastructure",
  },
];

const techStack = [
  "built hastily using Astro, Open Props, FontAwesome, TypeScript, Inter, JetBrains Mono, Netlify & GitHub"
];

const fonts: string[] = [];
---

<Base title="Frameworks in Action — Ron Bronson">
  <main>
    <section class="frameworks-hero">
      <div class="container">
        <h1 class="page-heading">Frameworks in Action</h1>
        <p class="page-intro">Speculative projects exploring how design frameworks apply to real-world problems.</p>
      </div>
    </section>

    <section class="frameworks-grid">
      <div class="container">
        <div class="hero-cards-stack">
          {heroCards.map(card => (
            <HeroCard
              title={card.title}
              description={card.description}
              image={card.image}
              href={card.href}
              label={card.label}
            />
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer
    techStack={techStack}
    fonts={fonts}
  />
</Base>

<style>
  .frameworks-hero {
    padding-block: var(--size-8) var(--size-4);
  }

  .page-heading {
    font-size: clamp(var(--font-size-4), 5vw, var(--font-size-6));
    font-family: var(--font-mono);
    font-weight: var(--font-weight-7);
    margin-bottom: var(--size-2);
  }

  .page-intro {
    font-size: var(--font-size-1);
    color: var(--text-2);
    max-width: 60ch;
  }

  .frameworks-grid {
    padding-block: var(--size-4) var(--size-8);
  }

  .hero-cards-stack {
    display: flex;
    flex-direction: column;
    gap: var(--size-5);
  }

  @media (max-width: 600px) {
    .frameworks-hero {
      padding-block: var(--size-6) var(--size-3);
    }

    .frameworks-grid {
      padding-block: var(--size-3) var(--size-6);
    }

    .hero-cards-stack {
      gap: var(--size-4);
    }
  }
</style>
