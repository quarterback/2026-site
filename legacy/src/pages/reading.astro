---
import { getLiteral, type LiteralBook } from '../lib/literal';

const { reading, finished } = await getLiteral();

const ME = { name: 'Ron Bronson' };
const SITE_URL = 'https://ronbronson.design';
const CANONICAL_URL = SITE_URL + '/reading';
const PAGE_DESCRIPTION =
  'What Ron Bronson is reading now and a rolling log of recent finishes — references that shape the work.';

const sections: { heading: string; books: LiteralBook[] }[] = [
  { heading: 'Currently reading', books: reading },
  { heading: 'Recently read', books: finished },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Reading — {ME.name}</title>
    <meta name="description" content={PAGE_DESCRIPTION} />
    <meta name="author" content={ME.name} />
    <link rel="canonical" href={CANONICAL_URL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={ME.name} />
    <meta property="og:title" content={`Reading — ${ME.name}`} />
    <meta property="og:description" content={PAGE_DESCRIPTION} />
    <meta property="og:url" content={CANONICAL_URL} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;0,6..72,700;1,6..72,400;1,6..72,500;1,6..72,600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="page">
      <p class="page__back"><a href="/">&larr; {ME.name}</a></p>

      <header class="page__hdr">
        <h1 class="page__name">Reading</h1>
        <p class="page__intro">
          What I&rsquo;m reading now and a rolling log of recent finishes &mdash;
          the references that keep turning up in the work, in the order I actually
          read them. The full shelf lives on
          <a href="https://literal.club/ron" target="_blank" rel="noopener">Literal</a>.
        </p>
      </header>

      {reading.length === 0 && finished.length === 0 && (
        <p class="page__empty">The shelf is loading &mdash; check back shortly.</p>
      )}

      {sections.map((section) => section.books.length > 0 && (
        <section class="sec">
          <h2 class="sec__h">{section.heading}</h2>
          <ul class="booklist">
            {section.books.map((book) => (
              <li class="book">
                <a class="book__cover" href={book.url} target="_blank" rel="noopener">
                  <span class="book__cover-fallback" aria-hidden="true">{book.title.slice(0, 1)}</span>
                  {book.cover && (
                    <img
                      src={book.cover}
                      alt={`Cover of ${book.title}`}
                      loading="lazy"
                      onerror="this.remove()"
                    />
                  )}
                </a>
                <div class="book__body">
                  <h3 class="book__title">
                    <a href={book.url} target="_blank" rel="noopener">{book.title}</a>
                  </h3>
                  {book.subtitle && <p class="book__subtitle">{book.subtitle}</p>}
                  {book.authors && <p class="book__author">{book.authors}</p>}
                </div>
              </li>
            ))}
          </ul>
        </section>
      ))}

      <footer class="foot">
        <em>Synced from <a href="https://literal.club/ron" target="_blank" rel="noopener">Literal</a>.</em>
      </footer>
    </main>
  </body>
</html>

<style is:global>
  :root {
    --paper: #ededeb;
    --ink: #18181a;
    --ink-2: #5b5a55;
    --ink-3: #95938d;
    --oxblood: #7a1f2c;
    --link: #1c3faa;
    --link-vis: #5c2d91;
    --link-hov: #0e2670;
    --hair: #c9c8c4;

    --serif: "Newsreader", "Source Serif 4", "Lyon Text", Georgia,
      "Times New Roman", serif;
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    background: var(--paper);
    color: var(--ink);
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    font-feature-settings: "kern", "liga", "onum";
    font-optical-sizing: auto;
    hanging-punctuation: first last;
  }

  .page {
    max-width: 600px;
    margin: 0 auto;
    padding: 48px 28px 96px;
  }

  .page__back {
    margin: 0 0 36px;
    font-size: 15px;
    font-style: italic;
  }

  .page__hdr { margin: 0 0 44px; }

  .page__name {
    margin: 0 0 16px;
    font-family: var(--serif);
    font-style: italic;
    font-weight: 600;
    font-size: clamp(34px, 5.6vw, 44px);
    line-height: 1.02;
    letter-spacing: -0.015em;
    color: var(--ink);
    font-variation-settings: "opsz" 60;
  }

  .page__intro {
    margin: 0;
    font-size: 18px;
    line-height: 1.6;
    color: var(--ink);
    text-wrap: pretty;
    max-width: 52ch;
  }

  .page__empty { color: var(--ink-2); font-style: italic; }

  .sec { margin: 0 0 48px; }

  .sec__h {
    margin: 0 0 22px;
    font-family: var(--serif);
    font-weight: 600;
    font-size: 13px;
    line-height: 1;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--oxblood);
    padding-bottom: 10px;
    border-bottom: 0.5px solid var(--hair);
  }

  .booklist {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 26px;
  }

  .book {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 20px;
    align-items: start;
  }

  .book__cover {
    position: relative;
    display: block;
    aspect-ratio: 2 / 3;
    background: #e0dfdb;
    overflow: hidden;
    border: 0.5px solid rgba(24, 24, 26, 0.18);
    box-shadow: 0 1px 2px rgba(24, 24, 26, 0.12);
    transition: transform 140ms ease, box-shadow 140ms ease;
  }

  .book__cover:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 14px rgba(24, 24, 26, 0.2);
  }

  .book__cover img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.92) contrast(1.02);
  }

  .book__cover-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--serif);
    font-style: italic;
    font-size: 24px;
    color: var(--ink-3);
  }

  .book__body { min-width: 0; padding-top: 2px; }

  .book__title {
    margin: 0 0 4px;
    font-family: var(--serif);
    font-weight: 600;
    font-size: 19px;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  .book__title a {
    color: var(--ink);
    text-decoration: none;
  }
  .book__title a:hover {
    color: var(--oxblood);
    text-decoration: underline;
    text-decoration-thickness: 0.7px;
    text-underline-offset: 2.5px;
  }

  .book__subtitle {
    margin: 0 0 6px;
    font-style: italic;
    font-size: 16px;
    line-height: 1.3;
    color: var(--ink-2);
  }

  .book__author {
    margin: 0;
    font-size: 15px;
    color: var(--ink-2);
  }

  .foot {
    margin-top: 56px;
    padding-top: 18px;
    border-top: 0.5px solid var(--hair);
    font-size: 14px;
    color: var(--ink-2);
    text-align: right;
  }

  a {
    color: var(--link);
    text-decoration: underline;
    text-decoration-thickness: 0.7px;
    text-underline-offset: 2.5px;
    text-decoration-color: rgba(28, 63, 170, 0.45);
    transition: color 120ms, text-decoration-color 120ms;
  }
  a:visited { color: var(--link-vis); text-decoration-color: rgba(92, 45, 145, 0.45); }
  a:hover { color: var(--link-hov); text-decoration-color: currentColor; }
  a:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 2px;
    border-radius: 1px;
  }

  ::selection { background: rgba(122, 31, 44, 0.18); color: var(--ink); }

  @media (max-width: 560px) {
    .page { padding: 32px 22px 64px; }
    body { font-size: 16px; }
    .page__intro { font-size: 17px; }
    .book { grid-template-columns: 52px 1fr; gap: 16px; }
    .book__title { font-size: 18px; }
  }
</style>
