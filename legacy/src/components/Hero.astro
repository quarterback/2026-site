---
interface Affiliation {
  text: string;
  href?: string;
}

interface CTA {
  label: string;
  url: string;
  style: 'primary' | 'ghost' | 'text';
  external?: boolean;
}

interface Props {
  kicker?: string;
  headline: string;
  headlineAccent?: string;
  bio: string;
  affiliations?: Affiliation[];
  ctas?: CTA[];
}

const {
  kicker,
  headline,
  headlineAccent,
  bio,
  affiliations,
  ctas,
} = Astro.props;
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="container">
    {kicker && (
      <p class="hero-kicker">{kicker}</p>
    )}

    <h1 id="hero-heading" class="hero-headline" set:html={headline} />

    <div class="hero-bio" set:html={bio} />

    {ctas && ctas.length > 0 && (
      <div class="hero-cta-row">
        {ctas.map(cta => (
          <a
            href={cta.url}
            class={`btn btn-${cta.style}`}
            {...(cta.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
          >{cta.label}</a>
        ))}
      </div>
    )}

    {affiliations && affiliations.length > 0 && (
      <nav class="hero-spine" aria-label="Affiliations">
        {affiliations.map(aff => (
          aff.href ? (
            <a href={aff.href} class="spine-item">{aff.text}</a>
          ) : (
            <span class="spine-item">{aff.text}</span>
          )
        ))}
      </nav>
    )}
  </div>
</section>

<style>
  .hero {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: clamp(3.5rem, 10vh, 6rem) var(--pad) 0;
  }

  .hero-kicker {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .hero-kicker::after {
    content: '';
    display: inline-block;
    width: 2.5rem;
    height: 1px;
    background: var(--accent);
    opacity: 0.45;
  }

  .hero-headline {
    font-family: var(--font-serif);
    font-size: clamp(2.6rem, 6.5vw, 5.2rem);
    font-weight: 900;
    line-height: 1.04;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 2rem;
  }

  .hero-headline :global(em) {
    font-style: italic;
    font-weight: 400;
    color: var(--accent);
  }

  .hero-bio {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    font-weight: 300;
    line-height: 1.75;
    color: var(--ink-mid);
    max-width: 620px;
    margin-bottom: 2.5rem;
  }

  .hero-bio :global(p) {
    margin: 0 0 1rem;
  }

  .hero-bio :global(p:last-child) {
    margin-bottom: 0;
  }

  .hero-bio :global(strong) {
    font-weight: 500;
    color: var(--ink);
  }

  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: clamp(3rem, 6vh, 5rem);
  }

  .btn {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.7rem 1.4rem;
    border: 1px solid;
    transition: all 0.18s;
    display: inline-block;
  }

  .btn-primary {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--brand-dim);
    border-color: var(--brand-dim);
    color: #fff;
  }

  .btn-ghost {
    background: transparent;
    border-color: var(--border);
    color: var(--ink-mid);
  }

  .btn-ghost:hover {
    border-color: var(--ink-muted);
    color: var(--ink);
  }

  .btn-text {
    background: transparent;
    border-color: transparent;
    color: var(--ink-muted);
  }

  .btn-text:hover {
    color: var(--accent);
    border-color: transparent;
  }

  .hero-spine {
    border-top: 1px solid var(--rule);
    padding: 1.5rem 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0;
  }

  .spine-item {
    font-family: var(--font-mono);
    font-size: 0.63rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
    text-decoration: none;
    padding: 0.3rem 1.25rem 0.3rem 0;
    margin-right: 1.25rem;
    border-right: 1px solid var(--rule);
    transition: color 0.15s;
    white-space: nowrap;
    line-height: 1.8;
  }

  .spine-item:last-child {
    border-right: none;
  }

  a.spine-item:hover {
    color: var(--accent);
  }

  @media (max-width: 480px) {
    .spine-item {
      border-right: none;
      padding-right: 0;
    }
  }
</style>
