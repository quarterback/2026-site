---
import StatusTicker from '../components/StatusTicker.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Designer focused on public systems and decision-making" } = Astro.props;

const tickerItems = [
  { label: "About", url: "/about" },
  { label: "Speaking", url: "/media" },
  { label: "Work", url: "/work" },
  { label: "Blog ↗", url: "https://blog.ronbronson.com" },
  { label: "Now", url: "/now" },
  { label: "🎧", url: "https://listening.ronbronson.com" },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <!-- Webmentions -->
    <link rel="webmention" href="https://webmention.io/ronbronson.com/webmention" />
    <link rel="pingback" href="https://webmention.io/ronbronson.com/xmlrpc" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <StatusTicker items={tickerItems} />
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/design-tokens.css";
  @import "../styles/global.css";

  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    background: var(--accent);
    color: #fff;
    padding: 0.5rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-decoration: none;
    z-index: 999;
  }
  .skip-link:focus {
    top: 0.5rem;
    color: #fff;
  }
</style>
