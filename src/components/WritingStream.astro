---
import type { StreamItem } from '../lib/stream';

interface Props {
  items: StreamItem[];
}

const { items } = Astro.props;

function formatDate(d: Date): string {
  return d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<ul class="stream">
  {items.map(item => (
    <li class="stream-item">
      <a
        href={item.url}
        class="stream-link"
        target="_blank"
        rel="noopener"
      >
        <div class="stream-meta">
          <time class="stream-date" datetime={item.date.toISOString()}>{formatDate(item.date)}</time>
          <span class="stream-source">{item.source}</span>
        </div>
        <div class="stream-body">
          <h3 class="stream-title">{item.title}</h3>
          {item.excerpt && <p class="stream-excerpt">{item.excerpt}</p>}
        </div>
        <span class="stream-arrow" aria-hidden="true">↗</span>
      </a>
    </li>
  ))}
</ul>

<style>
  .stream {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .stream-item {
    border-top: 1px solid var(--rule);
  }

  .stream-item:last-child {
    border-bottom: 1px solid var(--rule);
  }

  .stream-link {
    display: grid;
    grid-template-columns: 10rem 1fr auto;
    align-items: baseline;
    gap: 1.75rem;
    padding: 1.4rem 0;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }

  .stream-link:hover {
    background: var(--bg-warm);
  }

  .stream-link:hover .stream-title {
    color: var(--accent);
  }

  .stream-meta {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .stream-date {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-mid);
  }

  .stream-source {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .stream-body {
    min-width: 0;
  }

  .stream-title {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-style: italic;
    font-weight: 400;
    color: var(--ink);
    line-height: 1.3;
    margin: 0 0 0.4rem;
    transition: color 0.15s;
  }

  .stream-excerpt {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 300;
    line-height: 1.55;
    color: var(--ink-mid);
    margin: 0;
    max-width: 62ch;
  }

  .stream-arrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-faint);
    padding-top: 0.25rem;
  }

  @media (max-width: 768px) {
    .stream-link {
      grid-template-columns: 7rem 1fr;
      gap: 1rem;
    }

    .stream-arrow {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .stream-link {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }

    .stream-meta {
      flex-direction: row;
      gap: 0.75rem;
    }
  }
</style>
