---
interface StatusItem {
  label: string;
  url: string;
}

interface Props {
  items: StatusItem[];
  name?: string;
}

const { items, name = "Ron Bronson" } = Astro.props;
---

<div class="ticker">
  <div class="ticker__container">
    <a href="/" class="ticker__name">{name}</a>
    <div class="ticker__track">
      {items.map((item, i) => (
        <>
          {i > 0 && <span class="ticker__separator">·</span>}
          <a href={item.url} class="ticker__link">
            {item.label}
          </a>
        </>
      ))}
      <span class="ticker__separator">·</span>
      <a href="https://www.occupant.works/" class="ticker__link ticker__icon-link" aria-label="Phone a friend" target="_blank" rel="noopener noreferrer">
        <i class="fas fa-phone"></i>
      </a>
      <span class="ticker__separator">·</span>
      <button id="theme-toggle" class="ticker__theme-toggle" aria-label="Toggle theme">
        <span class="theme-light">☀</span>
        <span class="theme-dark">☾</span>
      </button>
    </div>
  </div>
</div>

<style>
  .ticker {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--surface-1);
    border-bottom: 1px solid var(--surface-3);
    padding-block: var(--size-3);
    font-family: var(--font-mono);
    font-size: var(--font-size-00);
    letter-spacing: 0.02em;
  }

  .ticker__container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--size-4);
    padding-inline: var(--size-5);
    max-width: 1400px;
    margin: 0 auto;
  }

  .ticker__name {
    font-weight: var(--font-weight-7);
    font-size: var(--font-size-1);
    color: var(--text-1);
    text-decoration: none;
    white-space: nowrap;
    font-family: var(--font-sans);
  }

  .ticker__name:hover {
    color: var(--brand);
  }

  .ticker__track {
    display: flex;
    align-items: center;
    gap: var(--size-3);
    white-space: nowrap;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
  }

  .ticker__track::-webkit-scrollbar {
    display: none;
  }

  @media (max-width: 768px) {
    .ticker {
      font-size: 0.7rem;
      padding-block: var(--size-2);
    }

    .ticker__container {
      padding-inline: var(--size-3);
      gap: var(--size-3);
    }

    .ticker__name {
      font-size: var(--font-size-0);
    }

    .ticker__track {
      gap: var(--size-2);
    }
  }

  .ticker__separator {
    color: var(--text-3);
    font-weight: 400;
  }

  .ticker__link {
    color: var(--text-3);
    text-decoration: none;
    transition: color 0.15s ease;
    text-transform: uppercase;
  }

  .ticker__link:hover {
    color: var(--text-1);
  }

  .ticker__icon-link {
    font-size: 0.85em;
  }

  .ticker__theme-toggle {
    background: none;
    border: none;
    color: var(--text-3);
    cursor: pointer;
    padding: 0;
    font-size: 1rem;
    line-height: 1;
    transition: color 0.15s ease;
    text-transform: uppercase;
  }

  .ticker__theme-toggle:hover {
    color: var(--text-1);
  }

  .theme-light {
    display: none;
  }

  .theme-dark {
    display: inline;
  }

  :global([data-theme="light"]) .theme-light {
    display: inline;
  }

  :global([data-theme="light"]) .theme-dark {
    display: none;
  }

  /* Optional: animated entrance */
  @media (prefers-reduced-motion: no-preference) {
    .ticker {
      animation: ticker-in 0.4s ease-out;
    }

    @keyframes ticker-in {
      from {
        opacity: 0;
        transform: translateY(-100%);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  }
</style>

<script>
  const toggle = document.getElementById('theme-toggle');

  // Get initial theme from localStorage or default to light
  const getInitialTheme = () => {
    const stored = localStorage.getItem('theme');
    return stored || 'light';
  };

  // Apply theme to document
  const applyTheme = (theme: string) => {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
  };

  // Initialize theme
  applyTheme(getInitialTheme());

  // Toggle theme on click
  toggle?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'light' ? 'dark' : 'light';
    applyTheme(next);
  });
</script>
