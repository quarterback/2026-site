---
interface Social {
  platform: string;
  url: string;
  icon: string;
  solid?: boolean;
  me?: boolean;
}

interface Props {
  socials?: Social[];
  techStack?: string | string[];
  fonts?: string | string[];
  copyright?: string;
}

const defaultSocials: Social[] = [
  { platform: 'Last.fm', url: 'https://last.fm/user/statechampion', icon: 'fa-lastfm' },
  { platform: 'Bluesky', url: 'https://bsky.app/profile/ronbronson.com', icon: 'fa-bluesky', me: true },
  { platform: 'LinkedIn', url: 'https://linkedin.com/in/ronbronson', icon: 'fa-linkedin' },
  { platform: 'GitHub', url: 'https://github.com/ronbronson', icon: 'fa-github', me: true },
  { platform: 'Instagram', url: 'https://instagram.com/ronbronson', icon: 'fa-instagram' },
  { platform: 'pi.fyi', url: 'https://www.pi.fyi/u/ron', icon: 'fa-vine' },
  { platform: 'Record Club', url: 'https://record.club/ron', icon: 'fa-record-vinyl', solid: true },
  { platform: 'Letterboxd', url: 'https://letterboxd.com/ronbronson', icon: 'fa-letterboxd' },
  { platform: 'Mastodon', url: 'https://mastodon.social/@ronbronson', icon: 'fa-mastodon', me: true },
  { platform: 'Literal', url: 'https://literal.club/ronbronson', icon: 'fa-book', solid: true },
  { platform: 'Mixcloud', url: 'https://mixcloud.com/908RB', icon: 'fa-mixcloud' },
];

const {
  socials = defaultSocials,
  techStack: techStackProp = 'Built with Astro, Open Props, Playfair Display, DM Sans, and DM Mono.',
  fonts: fontsProp = '',
  copyright = '© 2026 Ron Bronson',
} = Astro.props;

const techStack = Array.isArray(techStackProp) ? techStackProp.join(', ') : techStackProp;
const fonts = Array.isArray(fontsProp) ? fontsProp.join(', ') : fontsProp;
---

<footer>
  <div class="container footer-inner">

    <div class="footer-contact">
      <p class="footer-label">Contact</p>
      <a href="mailto:ron@ronbronson.com" class="footer-email">ron@ronbronson.com</a>
    </div>

    <div class="footer-social">
      <p class="footer-label">Elsewhere</p>
      <ul class="footer-social-list">
        {socials.map(social => (
          <li>
            <a
              href={social.url}
              target="_blank"
              rel={social.me ? 'me noopener' : 'noopener'}
              title={social.platform}
            >
              <i class={social.solid ? `fa-solid ${social.icon}` : `fa-brands ${social.icon}`} aria-hidden="true"></i>
              <span>{social.platform}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="footer-colophon">
      <div class="footer-license">
        <a href="/privacy" title="Parachute Commons License">
          <img src="/badges/parachute-commons.svg" alt="license: Parachute Commons" height="20" />
        </a>
      </div>
      <p class="footer-copy">
        {copyright} &middot; {techStack}{fonts ? ' ' + fonts : ''}
      </p>
    </div>

  </div>
</footer>

<style>
  footer {
    margin-top: var(--size-6);
    padding-block: var(--size-8) var(--size-6);
    border-top: 1px solid var(--rule);
    background: var(--surface-2);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: var(--size-6);
  }

  .footer-label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin: 0 0 var(--size-3);
  }

  .footer-contact {
    padding-bottom: var(--size-5);
    border-bottom: 1px solid var(--rule);
  }

  .footer-email {
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    font-style: italic;
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 3px;
  }

  .footer-email:hover {
    color: var(--accent);
  }

  .footer-social-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--size-3) var(--size-5);
  }

  .footer-social-list a {
    display: inline-flex;
    align-items: center;
    gap: var(--size-2);
    font-family: var(--font-sans);
    font-size: 0.88rem;
    color: var(--ink-mid);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-social-list a:hover {
    color: var(--accent);
  }

  .footer-social-list i {
    font-size: 0.95rem;
    width: 1.1em;
    text-align: center;
  }

  .footer-colophon {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--size-4);
    padding-top: var(--size-5);
    border-top: 1px solid var(--rule);
  }

  .footer-license a {
    display: inline-block;
    line-height: 0;
    transition: opacity 0.2s ease;
  }

  .footer-license a:hover {
    opacity: 0.8;
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    color: var(--ink-faint);
    line-height: 1.6;
    margin: 0;
    flex: 1;
    min-width: 260px;
  }
</style>
