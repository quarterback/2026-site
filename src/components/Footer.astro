---
interface Social {
  platform: string;
  url: string;
  icon: string;
  solid?: boolean;
  me?: boolean;
}

interface NavLink {
  label: string;
  url: string;
  external?: boolean;
}

interface Props {
  socials?: Social[];
  siteLinks?: NavLink[];
  legalLinks?: NavLink[];
  techStack?: string | string[];
  fonts?: string | string[];
  copyright?: string;
}

const defaultSocials: Social[] = [
  { platform: 'Last.fm', url: 'https://last.fm/user/statechampion', icon: 'fa-lastfm' },
  { platform: 'Bluesky', url: 'https://bsky.app/profile/ronbronson.com', icon: 'fa-bluesky', me: true },
  { platform: 'LinkedIn', url: 'https://linkedin.com/in/ronbronson', icon: 'fa-linkedin' },
  { platform: 'GitHub', url: 'https://github.com/ronbronson', icon: 'fa-github', me: true },
  { platform: 'Instagram', url: 'https://instagram.com/ronbronson', icon: 'fa-instagram' },
  { platform: 'pi.fyi', url: 'https://www.pi.fyi/u/ron', icon: 'fa-vine' },
  { platform: 'Record Club', url: 'https://record.club/ron', icon: 'fa-record-vinyl', solid: true },
  { platform: 'Letterboxd', url: 'https://letterboxd.com/ronbronson', icon: 'fa-letterboxd' },
  { platform: 'Mastodon', url: 'https://mastodon.social/@ronbronson', icon: 'fa-mastodon', me: true },
  { platform: 'Literal', url: 'https://literal.club/ronbronson', icon: 'fa-book', solid: true },
  { platform: 'Mixcloud', url: 'https://mixcloud.com/908RB', icon: 'fa-mixcloud' },
];

const defaultSiteLinks: NavLink[] = [
  { label: 'Home', url: '/' },
  { label: 'Notes', url: '/notes' },
  { label: 'Essays', url: '/essays' },
  { label: 'Work', url: '/work' },
  { label: 'Speaking', url: '/media' },
  { label: 'Newsletter', url: 'https://makingpublicwork.com', external: true },
  { label: 'Blog', url: 'https://blog.ronbronson.com', external: true },
  { label: 'Listening log', url: 'https://listening.ronbronson.com', external: true },
  { label: 'Now', url: '/now' },
  { label: 'About', url: '/about' },
  { label: 'Coaching', url: '/coaching' },
];

const defaultLegalLinks: NavLink[] = [
  { label: 'Privacy', url: '/privacy' },
  { label: 'Webmention endpoint', url: 'https://webmention.io/ronbronson.com/webmention', external: true },
  { label: 'RSS — Essays', url: '/rss.xml' },
  { label: 'RSS — Notes', url: '/notes.xml' },
];

const {
  socials = defaultSocials,
  siteLinks = defaultSiteLinks,
  legalLinks = defaultLegalLinks,
  techStack: techStackProp = 'Built with Astro, Open Props, Playfair Display, DM Sans, and DM Mono.',
  fonts: fontsProp = '',
  copyright = '© 2026 Ron Bronson',
} = Astro.props;

const techStack = Array.isArray(techStackProp) ? techStackProp.join(', ') : techStackProp;
const fonts = Array.isArray(fontsProp) ? fontsProp.join(', ') : fontsProp;
---

<footer>
  <div class="container footer-inner">

    <div class="footer-contact">
      <p class="footer-label">Contact</p>
      <a href="mailto:ron@ronbronson.com" class="footer-email">ron@ronbronson.com</a>
    </div>

    <div class="footer-columns">
      <div class="footer-col">
        <p class="footer-label">Site</p>
        <ul>
          {siteLinks.map(link => (
            <li>
              <a
                href={link.url}
                {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}
              >{link.label}{link.external ? ' ↗' : ''}</a>
            </li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <p class="footer-label">Elsewhere</p>
        <ul class="footer-social-list">
          {socials.map(social => (
            <li>
              <a
                href={social.url}
                target="_blank"
                rel={social.me ? 'me noopener' : 'noopener'}
                title={social.platform}
              >
                <i class={social.solid ? `fa-solid ${social.icon}` : `fa-brands ${social.icon}`} aria-hidden="true"></i>
                <span>{social.platform}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <p class="footer-label">Meta</p>
        <ul>
          {legalLinks.map(link => (
            <li>
              <a
                href={link.url}
                {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}
              >{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-colophon">
      <div class="footer-license">
        <a href="/privacy" title="Parachute Commons License">
          <img src="/badges/parachute-commons.svg" alt="license: Parachute Commons" height="20" />
        </a>
      </div>
      <p class="footer-copy">
        {copyright} &middot; {techStack}{fonts ? ' ' + fonts : ''}
      </p>
    </div>

  </div>
</footer>

<style>
  footer {
    margin-top: var(--size-6);
    padding-block: var(--size-8) var(--size-6);
    border-top: 1px solid var(--rule);
    background: var(--surface-2);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: var(--size-6);
  }

  .footer-label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin: 0 0 var(--size-3);
  }

  .footer-contact {
    padding-bottom: var(--size-5);
    border-bottom: 1px solid var(--rule);
  }

  .footer-email {
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    font-style: italic;
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 3px;
  }

  .footer-email:hover {
    color: var(--accent);
  }

  .footer-columns {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--size-6);
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--size-2);
  }

  .footer-col a {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--ink-mid);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-col a:hover {
    color: var(--accent);
  }

  .footer-social-list a {
    display: inline-flex;
    align-items: center;
    gap: var(--size-2);
  }

  .footer-social-list i {
    font-size: 0.95rem;
    width: 1.1em;
    text-align: center;
  }

  .footer-colophon {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--size-4);
    padding-top: var(--size-5);
    border-top: 1px solid var(--rule);
  }

  .footer-license a {
    display: inline-block;
    line-height: 0;
    transition: opacity 0.2s ease;
  }

  .footer-license a:hover {
    opacity: 0.8;
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    color: var(--ink-faint);
    line-height: 1.6;
    margin: 0;
    flex: 1;
    min-width: 260px;
  }

  @media (max-width: 768px) {
    .footer-columns {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .footer-columns {
      grid-template-columns: 1fr;
    }
  }
</style>
