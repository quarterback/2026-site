---
interface Props {
  quote: string;
  title: string;
  href: string;
  label: string;
}

const { quote, title, href, label } = Astro.props;
---

<a href={href} target="_blank" rel="noopener" class="writing-excerpt">
  <div class="writing-excerpt__mark" aria-hidden="true">"</div>
  <blockquote class="writing-excerpt__quote">
    {quote}
  </blockquote>
  <div class="writing-excerpt__footer">
    <div class="writing-excerpt__source">
      <span class="writing-excerpt__label">{label}</span>
      <span class="writing-excerpt__title">{title}</span>
    </div>
    <span class="writing-excerpt__cta">Read<span class="writing-excerpt__arrow">&rarr;</span></span>
  </div>
</a>

<style>
  .writing-excerpt {
    display: block;
    position: relative;
    padding: var(--size-6) var(--size-7);
    background: var(--surface-2);
    border-top: 3px solid var(--brand);
    text-decoration: none;
    transition: all 0.25s ease;
    overflow: hidden;
  }

  .writing-excerpt:hover {
    background: var(--surface-3);
  }

  .writing-excerpt:hover .writing-excerpt__arrow {
    transform: translateX(4px);
  }

  .writing-excerpt:hover .writing-excerpt__mark {
    opacity: 0.12;
  }

  .writing-excerpt__mark {
    position: absolute;
    top: -0.15em;
    left: var(--size-4);
    font-family: var(--font-serif);
    font-size: 8rem;
    line-height: 1;
    color: var(--brand);
    opacity: 0.08;
    pointer-events: none;
    transition: opacity 0.25s ease;
    user-select: none;
  }

  .writing-excerpt__quote {
    position: relative;
    margin: 0 0 var(--size-5);
    font-family: var(--font-serif);
    font-size: clamp(var(--font-size-2), 2.5vw, var(--font-size-4));
    line-height: 1.45;
    color: var(--text-1);
    max-width: 55ch;
  }

  .writing-excerpt__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--size-4);
    padding-top: var(--size-4);
    border-top: 1px solid var(--surface-3);
  }

  .writing-excerpt__source {
    display: flex;
    align-items: center;
    gap: var(--size-3);
  }

  .writing-excerpt__label {
    font-family: var(--font-mono);
    font-size: var(--font-size-00);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand);
    flex-shrink: 0;
  }

  .writing-excerpt__title {
    font-size: var(--font-size-1);
    font-weight: var(--font-weight-6);
    color: var(--text-2);
  }

  .writing-excerpt__cta {
    font-family: var(--font-mono);
    font-size: var(--font-size-0);
    color: var(--brand);
    display: flex;
    align-items: center;
    gap: var(--size-2);
    flex-shrink: 0;
  }

  .writing-excerpt__arrow {
    display: inline-block;
    transition: transform 0.25s ease;
  }

  @media (max-width: 768px) {
    .writing-excerpt {
      padding: var(--size-5) var(--size-5);
    }

    .writing-excerpt__mark {
      font-size: 5rem;
    }

    .writing-excerpt__footer {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--size-3);
    }

    .writing-excerpt__source {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--size-1);
    }
  }
</style>
