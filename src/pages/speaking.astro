---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';

interface Talk { date: string; title: string; venue?: string; url?: string; }
interface RefItem { title: string; source?: string; url?: string; date?: string; }

const topics = [
  { name: 'Public Mechanics', desc: 'How services actually get delivered, past the journey maps and transformation theater.' },
  { name: "The Designer's Share of the Problem", desc: 'Consequences, hostile design, and accountability in public systems.' },
  { name: 'Delivery Leadership', desc: 'Leading from where you are, building trust across silos, unblocking stalled programs.' },
  { name: 'AI and Public Infrastructure', desc: 'What happens when automation meets civic life.' },
  { name: 'Why Systems Stall', desc: 'How authority, procurement, and operational reality collide.' },
];

const talks: Talk[] = [
  { date: "Jul. '25", title: "Keynote on Service Delivery & Innovation", venue: "US Forest Service ACIO Trailhead Summit" },
  { date: "Jun. '25", title: "AI Agents and the Web: How Developers Can Build Smarter with Agent Experience", venue: "webinar" },
  { date: "Apr. '25", title: "Leading From Where You Are", venue: "Bloomberg Industry Summit" },
  { date: "Apr. '24", title: "Sprinkle Some AI On It: Service Design, Consequences & How Tech Disrupts Everyday Life", venue: "University of Michigan College of Architecture & Urban Planning" },
  { date: "Feb. '24", title: "Graphic Design", venue: "Portland State University" },
  { date: "Nov. '23", title: "Art Talk on Service Design", venue: "George Fox University" },
  { date: "May '23", title: "The Designer's Share of the Problem", venue: "ConveyUX Conference" },
  { date: "Feb. '23", title: "The Designer's Share of the Problem", venue: "Outcome Conference, Chandigarh, India" },
  { date: "Nov. '22", title: "The Designer's Share of the Problem", venue: "Rosenfeld Media Civic Design Conference" },
  { date: "Oct. '22", title: "Federal CX Leadership Symposium" },
  { date: "Aug. '22", title: "Service Design", venue: "Cloudflare Design Growth Week" },
  { date: "Nov. '21", title: "The Designer's Share of the Problem", venue: "IxDA Oslo" },
  { date: "Oct. '21", title: "Consequence Design", venue: "Design Week Colorado Springs" },
  { date: "Oct. '20", title: "The consequences in service design", venue: "SDN Global Conference" },
  { date: "Oct. '20", title: "Avoiding deception design patterns", venue: "Digital.gov Monthly" },
  { date: "Jul. '20", title: "The Researcher's Role in Reducing Consequence Design", venue: "An Event Apart HCD" },
  { date: "Mar. '20", title: "The Researcher's Role in Reducing Hostile Design", venue: "UX Australia Design Research" },
  { date: "Oct. '19", title: "Hostile Design of Digital Experiences", venue: "ACM SIGDOC, Portland" },
  { date: "Jun. '19", title: "Involving Stakeholders in Design Research", venue: "UXR Conference Toronto" },
  { date: "May '19", title: "Code For America Summit", venue: "panel" },
];

const podcasts: RefItem[] = [
  { title: "Repairing Service Design in the Age of AI", source: "The Service Design Show", url: "https://www.youtube.com/watch?v=4HKTGod1Xyo", date: "2025" },
  { title: "What, Huh? Me? Huh, What?", source: "Did I Do That? w/ Sean Schumacher", url: "https://schumacher.substack.com/p/ron-bronson-what-huh-me-huh-what", date: "2025" },
  { title: "Leading the Field: Ron Bronson", source: "Code for America", url: "https://codeforamerica.org/news/leading-the-field-ron-bronson/" },
  { title: "Surfacing", source: "with Lisa Welchman & Andy Vitale", url: "https://open.spotify.com/episode/2lC2xrhf4PIasyzJW4faP7", date: "2021" },
  { title: "Building Better User-Centered Products", source: "Pixel Pioneers", url: "https://pixelpioneers.co/blog/building-better-user-centered-products-an-interview-with-ron-bronson", date: "2020" },
  { title: "Responsive Web Design", source: "podcast", url: "https://responsivewebdesign.com/podcast/ron-bronson/", date: "2017" },
];

const writing: RefItem[] = [
  { title: "Some advice on managing your design career upwards", source: "Piccalil.li", url: "https://piccalil.li/blog/some-advice-on-managing-your-design-career-upwards/", date: "2026" },
];

interface Exhibition { title: string; date: string; location: string; }
const exhibitions: Exhibition[] = [
  { title: "Design For The Public Conference", date: "Oct. '24", location: "Wacom Experience Center / Revolution Hall, Portland" },
  { title: "A Parliament of Neighbors", date: "May '23", location: "Lloyd Center Mall, Portland" },
  { title: "Designer's Share of the Problem", date: "Oct. '22", location: "Portland Design Festival" },
  { title: "The Hidden Cost of Everything: Decentering the user experience", date: "Oct. '21", location: "zine" },
];

const techStack = ["built with Astro, DM Sans, and DM Mono"];
---

<Base title="Speaking — Ron Bronson" description="Talks, podcasts, and writing on public systems, service design, and delivery.">
  <main id="main">
    <header class="page-head">
      <p class="kicker">Speaking & Media</p>
      <h1 class="page-head__title">Speaking</h1>
      <p class="page-head__lede">I speak around the world on the territory between digital transformation, delivery, systems thinking, and service design — at tech and design conferences and in rooms full of public servants. Energetic talks, even when the subject is in the weeds.</p>
    </header>

    <div class="container speaking">

      <section class="sec" aria-labelledby="topics-h">
        <h2 class="sec__h" id="topics-h"><span class="kicker">Topics</span></h2>
        <ul class="topics">
          {topics.map(t => (
            <li><strong>{t.name}</strong> — {t.desc}</li>
          ))}
        </ul>
        <p class="contact">For speaking inquiries, contact <a href="#" data-u="speakers" data-d="neptunevelocity.com" rel="nofollow">Aiden Christmas</a>.</p>
      </section>

      <section class="sec" aria-labelledby="talks-h">
        <h2 class="sec__h" id="talks-h"><span class="kicker">Selected Talks</span></h2>
        <ul class="list">
          {talks.map(t => (
            <li class="entry">
              <span class="entry__date">{t.date}</span>
              <span class="entry__body">
                {t.url ? <a href={t.url} target="_blank" rel="noopener">{t.title}</a> : <span class="entry__title">{t.title}</span>}
                {t.venue && <span class="entry__meta"> — {t.venue}</span>}
              </span>
            </li>
          ))}
        </ul>
      </section>

      <section class="sec" aria-labelledby="pod-h">
        <h2 class="sec__h" id="pod-h"><span class="kicker">Podcasts & Interviews</span></h2>
        <ul class="list">
          {podcasts.map(p => (
            <li class="entry entry--nodate">
              <span class="entry__body">
                {p.url ? <a href={p.url} target="_blank" rel="noopener">{p.title}</a> : <span class="entry__title">{p.title}</span>}
                {p.source && <span class="entry__meta"> — {p.source}</span>}
              </span>
              {p.date && <span class="entry__year">{p.date}</span>}
            </li>
          ))}
        </ul>
      </section>

      <section class="sec" aria-labelledby="writing-h">
        <h2 class="sec__h" id="writing-h"><span class="kicker">Writing</span></h2>
        <ul class="list">
          {writing.map(w => (
            <li class="entry entry--nodate">
              <span class="entry__body">
                {w.url ? <a href={w.url} target="_blank" rel="noopener">{w.title}</a> : <span class="entry__title">{w.title}</span>}
                {w.source && <span class="entry__meta"> — {w.source}</span>}
              </span>
              {w.date && <span class="entry__year">{w.date}</span>}
            </li>
          ))}
        </ul>
      </section>

      <section class="sec" aria-labelledby="exh-h">
        <h2 class="sec__h" id="exh-h"><span class="kicker">Exhibitions & Projects</span></h2>
        <ul class="list">
          {exhibitions.map(e => (
            <li class="entry">
              <span class="entry__date">{e.date}</span>
              <span class="entry__body">
                <span class="entry__title">{e.title}</span>
                <span class="entry__meta"> — {e.location}</span>
              </span>
            </li>
          ))}
        </ul>
      </section>

    </div>
  </main>

  <Footer techStack={techStack} />
</Base>

<style>
  .speaking { padding-block: clamp(2rem, 5vw, 3.5rem); }

  .sec { padding-block: clamp(1.75rem, 4vw, 2.75rem); border-top: 1px solid var(--rule); }
  .sec:first-child { border-top: none; }
  .sec__h { margin: 0 0 1.25rem; }

  .topics { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.85rem; max-width: 70ch; }
  .topics li { font-family: var(--font-body); font-size: 1.02rem; line-height: 1.5; color: var(--ink-mid); }
  .topics strong { color: var(--ink); font-weight: 600; }
  .contact { margin: 1.5rem 0 0; font-family: var(--font-body); font-size: 0.95rem; color: var(--ink-mid); }

  .list { list-style: none; margin: 0; padding: 0; }
  .entry {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: 1rem;
    align-items: baseline;
    padding: 0.7rem 0;
    border-top: 1px solid var(--rule);
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.45;
  }
  .entry:first-child { border-top: none; }
  .entry--nodate { grid-template-columns: 1fr auto; }
  .entry__date { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.04em; color: var(--ink-faint); white-space: nowrap; }
  .entry__year { font-family: var(--font-mono); font-size: 0.72rem; color: var(--ink-faint); white-space: nowrap; }
  .entry__title { color: var(--ink); }
  .entry__meta { color: var(--ink-muted); }
  .entry__body a { color: var(--ink); text-decoration: underline; text-decoration-color: var(--accent); text-underline-offset: 2px; }
  .entry__body a:hover { text-decoration-thickness: 2.5px; }

  @media (max-width: 560px) {
    .entry { grid-template-columns: 1fr; gap: 0.15rem; }
    .entry--nodate { grid-template-columns: 1fr; }
  }
</style>
