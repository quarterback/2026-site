---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';

interface Favorite {
  category: string;
  labelColor: string;
  items: string[];
}

const favorites: Favorite[] = [
  {
    category: 'TEAS',
    labelColor: 'var(--green-6)',
    items: ['Wild lapsang', 'almonicha', 'Benifuki'],
  },
  {
    category: 'FILMS/TV',
    labelColor: 'var(--orange-6)',
    items: ['Pantheon', 'Counterpart', 'The Night Agent'],
  },
  {
    category: 'FRAGRANCES',
    labelColor: 'var(--pink-6)',
    items: ['Nocturnaility (Arquisite)', 'Apricot in Cognac (Scents of Wood)'],
  },
];

const affiliations = [
  '18F',
  'Department of Veterans Affairs',
  'Internal Revenue Service',
  'Department of Health and Human Services',
  'Department of Defense',
  'Federal Trade Commission',
  'University of Michigan',
  'Portland Digital Corps',
  'PDX Design Month',
];

const recentTalks = [
  {
    title: 'Design as Repair',
    venue: 'IxDA Oslo',
    year: '2025',
    url: 'https://www.ixda.no/talks/design-as-repair',
  },
  {
    title: 'Repairing Service Design for the Age of AI',
    venue: 'Service Design Show Podcast',
    year: '2025',
    url: 'https://podcasts.apple.com/br/podcast/repairing-service-design-for-the-age-of-ai-ron-bronson-ep-236/id1104665758?i=1000726081505',
  },
  {
    title: 'Beyond Civic Tech: Public Mechanics Starts at Home',
    venue: 'Cascadia Open Source Fall Conference',
    year: '2025',
    url: 'https://youtube.com/watch?v=hnAScuK-oMo',
  },
];
---

<Base title="About — Ron Bronson">
  <main id="main">

    <section class="about-hero">
      <div class="container about-hero-grid">
        <div class="about-intro">
          <p class="about-kicker">About</p>
          <p class="about-lede">
            Hi, I&rsquo;m Ron Bronson &mdash; I work in deployment and interaction policy, helping large institutions ship tech and AI. Based in Portland, Oregon.
          </p>
          <p>
            I&rsquo;ve spent my career learning how public systems fail in small ways that compound, and building the capacity inside institutions to catch those failures before they cascade. I spent nearly a decade at 18F, the federal government&rsquo;s digital services unit, leading design across agencies including the VA, IRS, HHS, and DOD. That work taught me what delivery actually looks like inside bureaucracies that resist it &mdash; and how to build teams that ship anyway.
          </p>
          <p>
            Now I run <a href="https://www.occupant.works/" target="_blank" rel="noopener">Occupant</a> and <a href="https://statecapacity.ai" target="_blank" rel="noopener">State Capacity AI</a>, teach at the University of Michigan, and write at <a href="https://makingpublicwork.com" target="_blank" rel="noopener">Making Public Work</a>. If your project is too important to leave the gap between pilot and product to chance, <a href="#" data-u="ron" data-d="ronbronson.com" rel="nofollow">let&rsquo;s talk</a>.
          </p>
        </div>

        <aside class="about-photo">
          <img src="/ron-bronson.jpg" alt="Ron Bronson" />
        </aside>
      </div>
    </section>

    <section class="about-affiliations" aria-label="Past and present affiliations">
      <div class="container">
        <p class="affiliations-label">Past and present</p>
        <ul class="affiliations-list">
          {affiliations.map(name => (
            <li>{name}</li>
          ))}
        </ul>
      </div>
    </section>

    <section class="service-area">
      <div class="container service-area-inner">
        <h2 class="service-heading">Deployment and interaction policy</h2>
        <div class="service-body">
          <p>
            I work where policy meets delivery &mdash; the layer where an institution&rsquo;s rules, incentives, and staff patterns meet the technology it&rsquo;s trying to use. Most large programs stall there. Procurement commits to vendors the operating teams can&rsquo;t support. Pilots get approval without a path to production. AI arrives without the decision infrastructure it needs to be trusted.
          </p>
          <p>
            Through <a href="https://www.occupant.works/" target="_blank" rel="noopener">Occupant</a>, I advise state, local, and federal leadership on stabilizing stalled programs, resetting deployment plans that aren&rsquo;t working, and building the internal capacity a program needs to outlast the engagement. Most of the work is diagnostic before it&rsquo;s constructive: figuring out where ownership got lost, where a decision broke, or what an org actually has to be good at before the next thing ships.
          </p>
          <p>
            <a href="#" data-u="ron" data-d="ronbronson.com" rel="nofollow" class="service-cta">Get in touch &rarr;</a>
          </p>
        </div>
      </div>
    </section>

    <section class="service-area">
      <div class="container service-area-inner">
        <h2 class="service-heading">Decision infrastructure for institutional AI</h2>
        <div class="service-body">
          <p>
            <a href="https://statecapacity.ai" target="_blank" rel="noopener">State Capacity AI</a> is the product side of the same problem. Governments and large institutions are being sold AI faster than they can evaluate it, and the intelligence that would let them compare vendors, track real costs, or benchmark performance doesn&rsquo;t exist in a form they can actually use.
          </p>
          <p>
            State Capacity AI builds that intelligence: live procurement benchmarks, honest pricing, and decision infrastructure that surfaces what vendors obscure. It&rsquo;s for the decision-makers who need vendor intelligence without the sales pitch.
          </p>
          <p>
            <a href="https://statecapacity.ai" target="_blank" rel="noopener" class="service-cta">Visit State Capacity AI &rarr;</a>
          </p>
        </div>
      </div>
    </section>

    <section class="service-area">
      <div class="container service-area-inner">
        <h2 class="service-heading">Public speaking</h2>
        <div class="service-body">
          <p>
            I speak with leadership teams, conferences, and institutional audiences about deploying AI in public-sector contexts, what capacity actually looks like inside bureaucracies, and why most digital-transformation work is repair more than reinvention.
          </p>
          <ul class="talks-list">
            {recentTalks.map(talk => (
              <li>
                <a href={talk.url} target="_blank" rel="noopener">
                  <em>{talk.title}</em>, {talk.venue}
                </a>
                <span class="talk-year">{talk.year}</span>
              </li>
            ))}
          </ul>
          <p>
            <a href="/media" class="service-cta">See more speaking &rarr;</a>
          </p>
        </div>
      </div>
    </section>

    <section class="service-area">
      <div class="container service-area-inner">
        <h2 class="service-heading">Teaching</h2>
        <div class="service-body">
          <p>
            I&rsquo;m an Assistant Professor of Practice in Urban Technology at the University of Michigan, where I teach students how to work on public-sector systems that don&rsquo;t want to be worked on. The courses sit at the intersection of design, policy, and delivery &mdash; the same territory I&rsquo;ve been practicing in my whole career.
          </p>
        </div>
      </div>
    </section>

    <section class="service-area">
      <div class="container service-area-inner">
        <h2 class="service-heading">Writing</h2>
        <div class="service-body">
          <p>
            I write <a href="https://makingpublicwork.com" target="_blank" rel="noopener">Making Public Work</a>, a newsletter on public-sector technology and institutional capacity; longer essays at <a href="https://blog.ronbronson.com" target="_blank" rel="noopener">blog.ronbronson.com</a>; and occasional pieces on game design and sports at <a href="https://gamedesign.leaflet.pub" target="_blank" rel="noopener">Sideline Engineering</a>.
          </p>
          <p>
            <a href="https://makingpublicwork.com" target="_blank" rel="noopener" class="service-cta">Subscribe to the newsletter &rarr;</a>
          </p>
        </div>
      </div>
    </section>

    <section class="coaching-section">
      <div class="container">
        <div class="coaching-card">
          <h3>Coaching</h3>
          <p>Head Girls Varsity Tennis Coach at Catlin Gabel School in Portland. State champion, district titles, and a constraint-led approach focused on developing problem-solvers on the court.</p>
          <a href="/coaching" class="card-link">
            Learn more about my coaching
            <i class="fas fa-arrow-right"></i>
          </a>
        </div>
      </div>
    </section>

    <section class="favorites-section">
      <div class="container">
        <h2 class="favorites-heading">Current Favorites</h2>
        <div class="favorites-grid">
          {favorites.map(favorite => (
            <article class="favorite-card">
              <span class="favorite-badge" style={`background-color: ${favorite.labelColor}`}>
                {favorite.category}
              </span>
              <ul class="favorite-items">
                {favorite.items.map(item => (
                  <li>{item}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
        <p class="pesapallo">
          Also, I&rsquo;m unreasonably enthusiastic about <a href="https://www.superpesis.fi/ajankohtaista/superpesis-yhdysvaltalainen-ron-bronson-toteutti-unelmansa-ja-matkusti-suomeen-katsomaan-pesapalloa" target="_blank" rel="noopener">pesäpallo</a>.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  /* About hero */
  .about-hero {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: clamp(3rem, 8vh, 5rem) var(--pad) clamp(2rem, 5vh, 3rem);
  }

  .about-hero-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .about-kicker {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 1rem;
  }

  .about-intro p {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--ink-mid);
    margin: 0 0 1.1rem;
    max-width: 62ch;
  }

  .about-lede {
    font-family: var(--font-serif) !important;
    font-style: italic;
    font-size: clamp(1.25rem, 2.5vw, 1.6rem) !important;
    font-weight: 400 !important;
    line-height: 1.35 !important;
    color: var(--ink) !important;
    margin-bottom: 1.5rem !important;
  }

  .about-intro a {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 2px;
    font-weight: 500;
  }

  .about-intro a:hover {
    color: var(--accent);
  }

  .about-photo {
    width: 100%;
    border-radius: 2px;
    overflow: hidden;
    border: 1px solid var(--border);
    position: sticky;
    top: clamp(3rem, 10vh, 6rem);
  }

  .about-photo img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Affiliations strip */
  .about-affiliations {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: clamp(2rem, 4vh, 3rem) var(--pad);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .affiliations-label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin: 0 0 1rem;
  }

  .affiliations-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--ink-mid);
  }

  .affiliations-list li {
    position: relative;
    padding-right: 1.25rem;
  }

  .affiliations-list li:not(:last-child)::after {
    content: '·';
    position: absolute;
    right: 0;
    color: var(--ink-faint);
  }

  /* Service areas */
  .service-area {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: clamp(2.5rem, 6vh, 4rem) var(--pad);
    border-top: 1px solid var(--rule);
  }

  .service-area:first-of-type {
    border-top: none;
  }

  .service-area-inner {
    display: grid;
    grid-template-columns: 16rem 1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
  }

  .service-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 2.3vw, 1.7rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.25;
    color: var(--ink);
    margin: 0;
    position: sticky;
    top: clamp(3rem, 10vh, 6rem);
  }

  .service-body p {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--ink-mid);
    margin: 0 0 1.1rem;
    max-width: 62ch;
  }

  .service-body p:last-child {
    margin-bottom: 0;
  }

  .service-body a {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 2px;
    font-weight: 500;
  }

  .service-body a:hover {
    color: var(--accent);
  }

  .service-cta {
    font-family: var(--font-mono) !important;
    font-size: 0.68rem !important;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none !important;
    color: var(--accent) !important;
    font-weight: 500;
  }

  .service-cta:hover {
    color: var(--brand-dim) !important;
  }

  .talks-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .talks-list li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--rule);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--ink-mid);
  }

  .talks-list li:last-child {
    border-bottom: none;
  }

  .talks-list a {
    color: var(--ink) !important;
    text-decoration: none !important;
    font-weight: 400 !important;
  }

  .talks-list a em {
    font-style: italic;
    font-family: var(--font-serif);
    color: var(--ink);
  }

  .talks-list a:hover em {
    color: var(--accent);
  }

  .talk-year {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
    white-space: nowrap;
  }

  /* Coaching / Favorites (retained) */
  .coaching-section {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--size-6) var(--pad);
    border-top: 1px solid var(--rule);
  }

  .coaching-card {
    background: var(--surface-2);
    border: 1px solid var(--surface-3);
    padding: var(--size-5);
  }

  .coaching-card h3 {
    font-family: var(--font-mono);
    font-size: var(--font-size-1);
    font-weight: var(--font-weight-6);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-1);
    margin: 0 0 var(--size-3) 0;
  }

  .coaching-card p {
    font-size: var(--font-size-1);
    line-height: 1.6;
    color: var(--text-2);
    margin: 0 0 var(--size-4) 0;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: var(--size-2);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
    transition: gap 0.2s ease;
  }

  .card-link:hover {
    gap: var(--size-3);
  }

  .favorites-section {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--size-6) var(--pad) var(--size-8);
    border-top: 1px solid var(--rule);
  }

  .favorites-heading {
    font-family: var(--font-mono);
    font-size: var(--font-size-1);
    font-weight: var(--font-weight-6);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-1);
    margin: 0 0 var(--size-5);
  }

  .favorites-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--size-3);
  }

  .favorite-card {
    background: var(--surface-2);
    border: 1px solid var(--surface-3);
    padding: var(--size-4);
    display: flex;
    flex-direction: column;
    gap: var(--size-3);
  }

  .favorite-badge {
    display: inline-block;
    padding: var(--size-1) var(--size-3);
    color: var(--gray-9);
    font-weight: var(--font-weight-6);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: var(--font-size-00);
    font-family: var(--font-mono);
    align-self: flex-start;
  }

  .favorite-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--size-2);
  }

  .favorite-items li {
    font-size: var(--font-size-0);
    line-height: 1.5;
    color: var(--text-2);
    font-family: var(--font-mono);
  }

  .pesapallo {
    margin-top: var(--size-6);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-style: italic;
    color: var(--ink-muted);
  }

  .pesapallo a {
    color: var(--ink-mid);
    text-decoration: underline;
    text-decoration-color: var(--accent);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .about-hero-grid {
      grid-template-columns: 1fr;
    }

    .about-photo {
      max-width: 280px;
      position: static;
    }

    .service-area-inner {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .service-heading {
      position: static;
    }
  }

  @media (max-width: 600px) {
    .talks-list li {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
  }
</style>
