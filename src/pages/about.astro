---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';

interface Favorite {
  category: string;
  labelColor: string;
  items: string[];
}

const favorites: Favorite[] = [
  {
    category: 'TEAS',
    labelColor: 'var(--green-6)',
    items: ['Wild lapsang', 'almonicha', 'Benifuki'],
  },
  {
    category: 'FILMS/TV',
    labelColor: 'var(--orange-6)',
    items: ['Pantheon', 'Counterpart', 'The Night Agent'],
  },
  {
    category: 'FRAGRANCES',
    labelColor: 'var(--pink-6)',
    items: ['Nocturnaility (Arquisite)', 'Apricot in Cognac (Scents of Wood)'],
  },
];

const techStack = [
  "Astro",
  "Open Props",
  "TypeScript"
];

const fonts = [
  "Inter",
  "JetBrains Mono"
];
---

<Base title="About — Ron Bronson">
  <main>
    <article class="about">
      <div class="container container--narrow">
        <h1>About</h1>
        <p class="subtitle">Who I am, what I do, what this is.</p>

        <div class="photo">
          <img src="/ron-bronson.jpg" alt="Ron Bronson" />
        </div>

        <p>Hello. I'm Ron, a public systems thinker in Portland — working at the intersection of delivery, governance, and institutional repair. I'm glad you're here.</p>

        <h2>Work</h2>

        <p>Public systems are full of small failures that compound: a form that doesn't save, an eligibility rule that contradicts itself, a policy that works on paper and nowhere else. I study how these failures propagate and how institutions can build the capacity to catch them before they cascade.</p>

        <p>I've spent my career trying to make public-facing systems work better for the people who depend on them. That's meant stints in federal service at 18F, leading design and technology strategy, and advising organisations on how to build real capacity for delivery — not just buy more software.</p>

        <p>These days I focus on decision architecture, AI accountability, and what it actually takes for institutions to repair themselves. I teach, I write, I advise, and when the situation calls for it, I roll up my sleeves and build. You can see some of that work in my <a href="/work">case studies</a> and <a href="/media">talks & media</a>.</p>

        <h2>Coaching</h2>

        <p>I'm the Head Girls Varsity Tennis Coach at Catlin Gabel School — state champion, district titles, and a constraint-led approach focused on developing problem-solvers on the court. More on my <a href="/coaching">coaching page</a>.</p>

        <h2>Life</h2>

        <p>I live in Portland, Oregon. I'm unreasonably enthusiastic about <a href="https://www.superpesis.fi/ajankohtaista/superpesis-yhdysvaltalainen-ron-bronson-toteutti-unelmansa-ja-matkusti-suomeen-katsomaan-pesapalloa">pesäpallo</a> (Finnish baseball) — enthusiastic enough to have travelled to Finland to watch it in person.</p>

        <p>I prefer things that are a bit twisted, dark, surprising, or subversive. I like tea more than coffee, fragrance more than fashion, and board games more than most things.</p>

        <h2>This site</h2>

        <p>This is a personal site — part portfolio, part notebook. It's built with Astro, styled with Open Props, and deployed as static HTML. No tracking, no analytics, no cookies.</p>

        <p>You can connect with me on <a href="https://bsky.app/profile/ronbronson.com">Bluesky</a>, <a href="https://linkedin.com/in/ronbronson">LinkedIn</a>, and <a href="https://github.com/ronbronson">GitHub</a>. My email is <a href="mailto:ron@ronbronson.com">ron@ronbronson.com</a>.</p>

        <h2>Current Favorites</h2>
        <div class="favorites-grid">
          {favorites.map(favorite => (
            <article class="favorite-card">
              <span class="favorite-badge" style={`background-color: ${favorite.labelColor}`}>
                {favorite.category}
              </span>
              <ul class="favorite-items">
                {favorite.items.map(item => (
                  <li>{item}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </article>
  </main>

  <Footer
    techStack={techStack}
    fonts={fonts}
  />
</Base>

<style>
  .about {
    padding-top: var(--size-fluid-5);
    padding-bottom: var(--size-fluid-5);
  }

  .about h1 {
    font-size: clamp(var(--font-size-4), 6vw, var(--font-size-6));
    font-family: var(--font-mono);
    margin-bottom: var(--size-2);
  }

  .subtitle {
    font-size: clamp(var(--font-size-1), 2.5vw, var(--font-size-2));
    color: var(--text-3);
    margin-bottom: var(--size-8);
  }

  .photo {
    max-width: 320px;
    border-radius: var(--radius-3);
    overflow: hidden;
    border: 3px solid var(--surface-3);
    margin-bottom: var(--size-8);
  }

  .photo img {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }

  .about h2 {
    font-family: var(--font-mono);
    font-size: clamp(var(--font-size-2), 3vw, var(--font-size-3));
    font-weight: var(--font-weight-7);
    color: var(--text-1);
    margin-top: var(--size-8);
    margin-bottom: var(--size-4);
  }

  .about p {
    font-size: clamp(var(--font-size-0), 2.5vw, var(--font-size-1));
    line-height: 1.6;
    color: var(--text-2);
    margin-bottom: var(--size-4);
    max-width: 65ch;
  }

  .about a {
    color: var(--brand);
    text-underline-offset: 2px;
  }

  .about a:hover {
    color: var(--text-1);
  }

  /* Favorites */
  .favorites-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--size-3);
    margin-top: var(--size-4);
  }

  .favorite-card {
    background: var(--surface-2);
    border: 1px solid var(--surface-3);
    border-radius: var(--radius-2);
    padding: var(--size-4);
    transition: border-color 0.2s, box-shadow 0.2s;
    display: flex;
    flex-direction: column;
    gap: var(--size-3);
  }

  .favorite-card:hover {
    border-color: var(--gray-6);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .favorite-badge {
    display: inline-block;
    padding: var(--size-1) var(--size-3);
    border-radius: var(--radius-1);
    color: var(--gray-9);
    font-weight: var(--font-weight-6);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: var(--font-size-00);
    font-family: var(--font-mono);
    align-self: flex-start;
  }

  .favorite-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--size-2);
  }

  .favorite-items li {
    font-size: var(--font-size-1);
    line-height: 1.5;
    color: var(--text-2);
    font-family: var(--font-mono);
    padding-left: var(--size-3);
    position: relative;
  }

  .favorite-items li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--text-3);
  }

  @media (max-width: 600px) {
    .about {
      padding-top: var(--size-8);
      padding-bottom: var(--size-8);
    }

    .photo {
      max-width: 100%;
    }

    .about h2 {
      margin-top: var(--size-6);
    }

    .favorites-grid {
      grid-template-columns: 1fr;
      gap: var(--size-3);
    }

    .favorite-items li {
      font-size: var(--font-size-0);
    }
  }
</style>
