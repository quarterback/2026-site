---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import WritingStream from '../components/WritingStream.astro';
import MediaCard from '../components/MediaCard.astro';
import { getHomepageStream } from '../lib/stream';
// import { getMergedNotes } from '../lib/notes';

const stream = await getHomepageStream(12);
// const notesPreview = (await getMergedNotes()).slice(0, 5);

// function formatNoteDate(d: Date) {
//   return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
// }
---

<Base title="Ron Bronson">
  <main id="main">

    <!-- HERO -->
    <section class="hero" aria-labelledby="hero-heading">
      <div class="container">
        <h1 id="hero-heading" class="hero-headline">
          I build and fix<br>the systems that<br>run <em>public life.</em>
        </h1>
      </div>
    </section>

    <!-- HOW CAN I HELP? -->
    <section class="help" aria-labelledby="help-heading">
      <div class="container">
        <h2 id="help-heading" class="help-heading">How can I help?</h2>

        <div class="service-cards">
          <article class="service-card">
            <h3 class="service-title">
              <span class="service-arrow" aria-hidden="true">&rarr;</span>
              Bounded advisory &amp; scoped tools for public-sector tech &amp; AI
            </h3>
            <p class="service-body">
              I work with public-sector teams on bounded delivery problems &mdash; backlogs and stuck workflows that need a fix in weeks, not quarters. I scope the problem narrowly, build a working tool against your actual data, and price it to move without a procurement bottleneck. Most of the wins are pattern problems: eligibility triage, document classification, case routing, backlog review where AI can add eyeballs without replacing the people holding the system together.
            </p>
            <p class="service-evidence">
              See <a href="https://statecapacity.ai" target="_blank" rel="noopener">State Capacity AI</a> for what this looks like in practice.
            </p>
            <a href="/work" class="service-cta">More about my work &rarr;</a>
          </article>

          <article class="service-card">
            <h3 class="service-title">
              <span class="service-arrow" aria-hidden="true">&rarr;</span>
              Writing, speaking, and teaching
            </h3>
            <p class="service-body">
              I publish Making Public Work, a newsletter on public-sector technology, teach at the University of Michigan, and speak with leadership teams about AI and institutional capacity.
            </p>
            <a href="/media" class="service-cta">More about speaking &rarr;</a>
          </article>
        </div>
      </div>
    </section>

    {/* NOTES — commented out until there's content to show
    {notesPreview.length > 0 && (
      <section class="notes-home" aria-labelledby="notes-home-heading">
        <div class="container">
          <div class="notes-home-head">
            <h2 id="notes-home-heading" class="notes-home-heading">Notes</h2>
            <a href="/notes" class="notes-home-all">All notes &rarr;</a>
          </div>

          <ul class="notes-home-list">
            {notesPreview.map(note => (
              <li class="notes-home-item">
                <time class="notes-home-date" datetime={note.date.toISOString()}>{formatNoteDate(note.date)}</time>
                <a
                  href={note.url}
                  class="notes-home-link"
                  {...(note.external ? { target: '_blank', rel: 'noopener' } : {})}
                >
                  {note.kind === 'markdown' && note.title ? (
                    <span class="notes-home-title">{note.title}</span>
                  ) : (
                    <span class="notes-home-body">{note.body}</span>
                  )}
                  {note.external && <span class="notes-home-external" aria-hidden="true"> ↗</span>}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}
    */}

    <!-- RECENT APPEARANCES -->
    <section class="appearances" aria-labelledby="appearances-heading">
      <div class="container">
        <h2 id="appearances-heading" class="appearances-heading">Recent appearances</h2>
        <div class="appearances-list">
          <MediaCard
            title="Design as Repair"
            source="IxDA Oslo"
            description="Most design work is repair — patching the gaps between intention and reality, between policy and the lived experience of the people who depend on public systems."
            mediaType="talk"
            url="https://www.ixda.no/talks/design-as-repair"
            date="2025"
          />
          <MediaCard
            title="Future Perfect Book Club"
            source="futureperfectbook.club"
            description="Co-hosted with Joel Goodman, exploring the intersection of design, technology, and the future of institutions."
            mediaType="podcast"
            url="https://futureperfectbook.club"
            date="2025"
          />
          <MediaCard
            title="Some advice on managing your design career upwards"
            source="Piccalil.li"
            description="Navigating design leadership, building influence across organizations, and positioning yourself for strategic impact."
            mediaType="article"
            url="https://piccalil.li/blog/some-advice-on-managing-your-design-career-upwards/"
            image="/img/piccalil.li.png"
            date="January 2026"
          />
          <MediaCard
            title="Beyond Civic Tech: Public Mechanics Starts at Home"
            source="Cascadia Open Source Fall Conference"
            description="Why civic tech fails when it ignores maintenance, repair, and the invisible work that keeps public services running."
            mediaType="talk"
            embedUrl="https://youtube.com/watch?v=hnAScuK-oMo"
            date="November 2025"
          />
          <MediaCard
            title="Repairing Service Design for the Age of AI"
            source="Service Design Show Podcast"
            description="Exploring how service design must evolve to address the challenges and opportunities of AI-driven systems."
            mediaType="podcast"
            url="https://podcasts.apple.com/br/podcast/repairing-service-design-for-the-age-of-ai-ron-bronson-ep-236/id1104665758?i=1000726081505"
            date="September 2025"
          />
          <MediaCard
            title="Design Systems and Public Services"
            source="YouTube"
            description="Discussion on service design, public sector innovation, and building decision systems that work at scale."
            mediaType="video"
            embedUrl="https://www.youtube.com/watch?v=kL0gYtoUtvI"
            date="October 2025"
          />
        </div>
      </div>
    </section>

    <!-- LATEST POSTS -->
    <section class="posts" aria-labelledby="posts-heading">
      <div class="container">
        <h2 id="posts-heading" class="posts-heading">Latest Posts</h2>

        <WritingStream items={stream} />
      </div>
    </section>

  </main>

  <Footer />
</Base>

<style>
  /* ===== HERO ===== */
  .hero {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: clamp(3rem, 7vh, 4.5rem) var(--pad) clamp(2rem, 4vh, 3rem);
  }

  .hero-headline {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4.5vw, 3.4rem);
    font-weight: 900;
    line-height: 1.06;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0;
  }

  .hero-headline :global(em) {
    font-style: italic;
    font-weight: 400;
    color: var(--accent);
  }

  /* ===== HOW CAN I HELP? ===== */
  .help {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: clamp(3rem, 7vh, 5rem) var(--pad);
    border-top: 1px solid var(--rule);
  }

  .help-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin: 0 0 2.5rem;
  }

  .service-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    background: var(--bg);
    border: 1px solid var(--border);
    padding: clamp(1.5rem, 3vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    transition: background 0.15s, border-color 0.15s;
  }

  .service-card:hover {
    background: var(--bg-warm);
    border-color: var(--ink-faint);
  }

  .service-title {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--ink);
    margin: 0;
  }

  .service-arrow {
    color: var(--accent);
    font-weight: 400;
    margin-right: 0.35rem;
  }

  .service-body {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.65;
    color: var(--ink-mid);
    margin: 0;
    flex: 1;
  }

  .service-evidence {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 300;
    line-height: 1.55;
    color: var(--ink-faint);
    margin: 0;
  }

  .service-evidence a {
    color: var(--ink-mid);
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 2px;
    transition: color 0.15s;
  }

  .service-evidence a:hover {
    color: var(--accent);
  }

  .service-cta {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
    margin-top: 0.4rem;
    align-self: flex-start;
    transition: color 0.15s;
  }

  .service-cta:hover {
    color: var(--brand-dim);
  }

  /* ===== NOTES (home) ===== */
  .notes-home {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: clamp(3rem, 7vh, 5rem) var(--pad);
    border-top: 1px solid var(--rule);
  }

  .notes-home-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin: 0 0 1.75rem;
  }

  .notes-home-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin: 0;
  }

  .notes-home-all {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
  }

  .notes-home-all:hover {
    color: var(--brand-dim);
  }

  .notes-home-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .notes-home-item {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    gap: 1.25rem;
    align-items: baseline;
    padding: 0.9rem 0;
    border-top: 1px solid var(--rule);
  }

  .notes-home-item:last-child {
    border-bottom: 1px solid var(--rule);
  }

  .notes-home-date {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .notes-home-link {
    text-decoration: none;
    color: var(--ink);
    transition: color 0.15s;
  }

  .notes-home-link:hover .notes-home-title,
  .notes-home-link:hover .notes-home-body {
    color: var(--accent);
  }

  .notes-home-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-style: italic;
    line-height: 1.4;
  }

  .notes-home-body {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--ink);
  }

  .notes-home-external {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-faint);
    margin-left: 0.3rem;
  }

  @media (max-width: 480px) {
    .notes-home-item {
      grid-template-columns: 3.5rem 1fr;
      gap: 0.75rem;
    }
  }

  /* ===== RECENT APPEARANCES ===== */
  .appearances {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: clamp(3rem, 7vh, 5rem) var(--pad);
    border-top: 1px solid var(--rule);
  }

  .appearances-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin: 0 0 2rem;
  }

  .appearances-list {
    display: flex;
    flex-direction: column;
    gap: var(--size-4);
  }

  /* ===== LATEST POSTS ===== */
  .posts {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: clamp(3rem, 7vh, 5rem) var(--pad);
    border-top: 1px solid var(--rule);
  }

  .posts-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin: 0 0 2rem;
  }

  .posts-more {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2rem;
    margin-top: 2rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .posts-more a {
    color: var(--ink-mid);
    text-decoration: none;
    transition: color 0.15s;
  }

  .posts-more a:hover {
    color: var(--accent);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .service-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
