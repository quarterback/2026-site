---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import { HERO, CURRENT_WORK, SPEAKING } from '../data/frontdoor';

const SITE_URL = 'https://ronbronson.design';
const CANONICAL_URL = SITE_URL + '/';
const PAGE_DESCRIPTION = HERO.headline;
const OG_IMAGE = new URL('/hero.jpg', SITE_URL).toString();
---

<Base title={`Ron Bronson — ${HERO.headline}`} description={PAGE_DESCRIPTION} noindex={false}>
  <Fragment slot="head">
    <link rel="canonical" href={CANONICAL_URL} />
    <meta property="og:type" content="profile" />
    <meta property="og:title" content="Ron Bronson" />
    <meta property="og:description" content={PAGE_DESCRIPTION} />
    <meta property="og:url" content={CANONICAL_URL} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={OG_IMAGE} />
  </Fragment>

  <main id="main" class="home">

    <!-- Hero — big statement + about + contact -->
    <header class="hero">
      <h1 class="hero__headline">{HERO.headline}</h1>
      <div class="hero__meta">
        <div class="hero__col">
          <p class="kicker">About</p>
          {HERO.about.map((a) => (
            <p class="hero__about">
              {a.href ? <a href={a.href} target={a.external ? '_blank' : undefined} rel={a.external ? 'noopener noreferrer' : undefined}>{a.text}</a> : a.text}
            </p>
          ))}
        </div>
        <div class="hero__col">
          <p class="kicker">Contact</p>
          {HERO.contact.map((c) => (
            <p class="hero__link">
              <a href={c.href} target={c.external ? '_blank' : undefined} rel={c.external ? 'noopener noreferrer' : undefined}>{c.label}</a>
              {c.note && <span class="hero__note"> {c.note}</span>}
            </p>
          ))}
        </div>
        <div class="hero__col">
          <p class="kicker">Links</p>
          {HERO.links.map((l) => (
            <p class="hero__link"><a href={l.href} target="_blank" rel="noopener noreferrer">{l.label}</a></p>
          ))}
        </div>
      </div>
    </header>

    <!-- Current Work — image-forward (Martin-style) -->
    <section class="block" aria-labelledby="cw-h">
      <h2 id="cw-h" class="block__h"><span class="kicker">Current Work</span></h2>
      {CURRENT_WORK.map((w) => (
        <article class="work">
          <h3 class="work__title">
            {w.href ? <a href={w.href} target={w.external ? '_blank' : undefined} rel={w.external ? 'noopener noreferrer' : undefined}>{w.title}{w.external ? ' ↗' : ''}</a> : w.title}
          </h3>
          <div class={`work__media work__media--${w.images.length === 0 ? 'empty' : (w.images.length > 1 ? 'pair' : 'one')}`}>
            {w.images.length === 0 ? (
              <div class="work__placeholder"><span>photo</span></div>
            ) : (
              w.images.map((img) => (
                <figure class="work__fig"><img src={img.src} alt={img.alt} loading="lazy" /></figure>
              ))
            )}
          </div>
          <div class="work__body">
            <div class="work__roleblock">
              {w.role && <p class="work__role"><strong>Role:</strong> {w.role}</p>}
              {w.collaborators && w.collaborators.length > 0 && (
                <p class="work__collab">with {w.collaborators.join(', ')}</p>
              )}
            </div>
            <p class="work__desc">{w.description}</p>
          </div>
        </article>
      ))}
    </section>

    <!-- Speaking — recent, 2026 first -->
    <section class="block" aria-labelledby="sp-h">
      <h2 id="sp-h" class="block__h"><span class="kicker">Speaking</span></h2>
      <ul class="talks">
        {SPEAKING.map((t) => (
          <li class="talk">
            <span class="talk__body">
              {t.href ? <a href={t.href} target="_blank" rel="noopener noreferrer">{t.title}</a> : <span class="talk__title">{t.title}</span>}
              {t.video && <span class="talk__icon" aria-hidden="true"> ▶</span>}
              {t.venue && <span class="talk__venue"> — {t.venue}</span>}
            </span>
            {t.year && <span class="talk__year">{t.year}</span>}
          </li>
        ))}
      </ul>
      <p class="seeall"><a href="/speaking">→ See all speaking</a></p>
    </section>

  </main>

  <Footer />
</Base>

<style>
  .home { max-width: 1080px; margin: 0 auto; padding: 0 var(--pad); }

  .kicker {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-mid);
    margin: 0 0 0.9rem;
  }

  /* ───── Hero ───── */
  .hero { padding: clamp(3rem, 8vw, 5.5rem) 0 clamp(2rem, 5vw, 3.5rem); }
  .hero__headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.4rem, 7vw, 5rem);
    line-height: 1.02;
    letter-spacing: -0.035em;
    color: var(--ink);
    margin: 0 0 clamp(2.5rem, 6vw, 4rem);
    max-width: 16ch;
  }
  .hero__meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--rule);
  }
  .hero__about, .hero__link { font-family: var(--font-body); font-size: 1rem; line-height: 1.45; color: var(--ink); margin: 0 0 0.6rem; }
  .hero__note { color: var(--ink-muted); }

  /* ───── Block ───── */
  .block { padding: clamp(2.5rem, 6vw, 4rem) 0; border-top: 1px solid var(--rule); }
  .block__h { margin: 0 0 2rem; }

  /* ───── Current Work — image forward ───── */
  .work { margin-bottom: clamp(3rem, 7vw, 5rem); }
  .work:last-child { margin-bottom: 0; }
  .work__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.4rem, 3vw, 2rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 1.25rem;
  }
  .work__title a { color: var(--ink); text-decoration: none; }
  .work__title a:hover { text-decoration: underline; text-decoration-color: var(--accent); text-decoration-thickness: 2px; text-underline-offset: 4px; }

  .work__media { display: grid; gap: 0.75rem; margin-bottom: 1.5rem; }
  .work__media--pair { grid-template-columns: 1fr 1fr; }
  .work__fig { margin: 0; overflow: hidden; border-radius: 6px; background: var(--bg-ink); }
  .work__fig img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 16 / 9; }
  .work__media--pair .work__fig img { aspect-ratio: 4 / 3; }

  .work__placeholder {
    aspect-ratio: 16 / 9;
    border-radius: 6px;
    background: repeating-linear-gradient(45deg, var(--bg-warm), var(--bg-warm) 12px, var(--bg-ink) 12px, var(--bg-ink) 24px);
    border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
  }
  .work__placeholder span {
    font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--ink-muted);
    background: var(--bg); padding: 0.3rem 0.7rem; border-radius: 100px;
  }

  .work__body {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: 1.5rem 2.5rem;
    align-items: start;
  }
  .work__role { font-family: var(--font-body); font-size: 1rem; color: var(--ink); margin: 0 0 0.25rem; }
  .work__role strong { font-weight: 600; }
  .work__collab { font-family: var(--font-body); font-size: 0.95rem; color: var(--ink-muted); margin: 0; }
  .work__desc { font-family: var(--font-body); font-size: 1.1rem; line-height: 1.55; color: var(--ink); margin: 0; }

  /* ───── Speaking ───── */
  .talks { list-style: none; margin: 0; padding: 0; }
  .talk {
    display: flex; justify-content: space-between; align-items: baseline; gap: 1rem;
    padding: 0.9rem 0;
    border-top: 1px solid var(--rule);
    font-family: var(--font-body); font-size: 1.15rem; line-height: 1.35;
  }
  .talk:first-child { border-top: none; }
  .talk a, .talk__title { color: var(--ink); text-decoration: none; }
  .talk a { text-decoration: underline; text-decoration-color: var(--accent); text-underline-offset: 3px; }
  .talk a:hover { text-decoration-thickness: 2.5px; }
  .talk__icon { color: var(--accent); font-size: 0.7em; }
  .talk__venue { color: var(--ink-muted); }
  .talk__year { font-family: var(--font-mono); font-size: 0.72rem; color: var(--ink-faint); white-space: nowrap; }
  .seeall { margin: 1.75rem 0 0; font-family: var(--font-mono); font-size: 0.8rem; letter-spacing: 0.04em; }

  @media (max-width: 700px) {
    .work__body { grid-template-columns: 1fr; gap: 0.75rem; }
    .work__media--pair { grid-template-columns: 1fr; }
    .talk { flex-direction: column; gap: 0.2rem; }
  }
</style>
