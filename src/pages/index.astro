---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{ME.name}</title>
    <meta name="description" content={PAGE_DESCRIPTION} />
    <meta name="author" content={ME.name} />
    <link rel="canonical" href={CANONICAL_URL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="profile" />
    <meta property="og:site_name" content={ME.name} />
    <meta property="og:title" content={ME.name} />
    <meta property="og:description" content={PAGE_DESCRIPTION} />
    <meta property="og:url" content={CANONICAL_URL} />
    <meta property="og:image" content={PORTRAIT_URL} />
    <meta property="og:image:alt" content={`Portrait of ${ME.name}`} />
    <meta property="profile:first_name" content="Ron" />
    <meta property="profile:last_name" content="Bronson" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@ronbronson" />
    <meta name="twitter:creator" content="@ronbronson" />
    <meta name="twitter:title" content={ME.name} />
    <meta name="twitter:description" content={PAGE_DESCRIPTION} />
    <meta name="twitter:image" content={PORTRAIT_URL} />
    <meta name="twitter:image:alt" content={`Portrait of ${ME.name}`} />

    <!-- Webmentions / IndieWeb -->
    <link
      rel="webmention"
      href="https://webmention.io/ronbronson.design/webmention"
    />
    <link
      rel="pingback"
      href="https://webmention.io/ronbronson.design/xmlrpc"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;0,6..72,700;1,6..72,400;1,6..72,500;1,6..72,600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="page h-card">
      <a class="u-url u-uid" href={CANONICAL_URL} hidden aria-hidden="true"
        >{ME.name}</a
      >

      <figure class="page__fig">
        <img class="u-photo" src={ME.portrait} alt={ME.name} />
      </figure>

      <header class="page__hdr">
        <h1 class="page__name p-name">{ME.name}</h1>
        {/*
        <p class="page__byline">
          <span class="p-job-title">{ME.byline}</span> Based in <span
            class="p-locality">{ME.location}</span
          >.
        </p>
        */}
      </header>

      <p class="page__intro p-note">
        From counties with more cows than people, to multilateral digital public
        infrastructure, I'm living at the crossroads of tactical delivery and
        measuring the societal impacts of consequential technology. In plain
        language, I work at the altitude of systems but never too high that I
        can't parachute down to Earth to fix what's going on at the street
        level.
      </p>
      <p class="page__intro p-note">
        Lately, I've been writing (and teaching) about <a
          href="https://makingpublicwork.com/">public mechanics</a
        >; back in March I organized <a href="https://yearsahead.io"
          >Years Ahead</a
        >. Currently: Head of Product Strategy for an EU-based civil AI concern,
        and part-time faculty in the Urban Technology program at the University
        of Michigan's Taubman College of Architecture and Urban Planning.
      </p>
      <p class="page__intro p-note">
        In my spare time, I coach high school tennis, host a <a
          href="https://www.mixcloud.com/908RB/">radio show</a
        >, and news anchor on community radio sometimes. My buddy Joel and I
        have an intermittent podcast about books, <a
          href="https://futureperfectbook.club">Future Perfect Book Club</a
        >.
      </p>
      <p class="page__intro p-note">
        Previously: Head of Design at <a href="https://18f.org">18F</a>, and
        founder of the <a href="https://digitalcorpspdx.org"
          >Portland Digital Corps</a
        >.
      </p>

      <a
        class="np"
        href="https://listening.ronbronson.com"
        target="_blank"
        rel="noopener noreferrer"
        aria-live="polite"
        hidden
      >
        <img class="np__art" alt="" width="40" height="40" />
        <span class="np__text">
          <span class="np__label">Now playing</span>
          <span class="np__track"></span>
          <span class="np__artist"></span>
        </span>
      </a>
      <p class="page__more">
        <a href="/reading">Reading — books past &amp; present &rarr;</a>
      </p>

      {
        sections.map((section) => (
          <section class="sec">
            <h2 class="sec__h">
              <span class="sec__name">{section.title}</span>
            </h2>
            <ul class="sec__list">
              {section.items.map((it) => (
                <li class="sec__row">
                  {it.href && it.href !== "#" ? (
                    <a href={it.href} target="_blank" rel="noopener noreferrer">
                      {it.title}
                    </a>
                  ) : (
                    <span>{it.title}</span>
                  )}
                  {section.venue && it.where ? (
                    <span class="sec__where"> — {it.where}</span>
                  ) : null}
                </li>
              ))}
            </ul>
          </section>
        ))
      }

      {
        POSTS.length > 0 && (
          <section class="sec">
            <h2 class="sec__h">
              <span class="sec__name">Some Thoughts</span>
            </h2>
            <ul class="sec__list">
              {POSTS.map((post) => (
                <li class="sec__row">
                  <a href={post.url} target="_blank" rel="noopener noreferrer">
                    {post.title}
                  </a>
                  <span class="sec__where"> — {post.source}</span>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      <section class="sec">
        <h2 class="sec__h">
          <span class="sec__name">Elsewhere</span>
        </h2>
        <ul class="sec__icons">
          {
            ELSEWHERE.map((e) => {
              const isEmail = e.href.startsWith("mailto:");
              const linkClass = isEmail ? "icon-link u-email" : "icon-link u-url";
              const linkRel = isEmail ? "me" : "me noopener noreferrer";
              const glyph = ICONS[e.icon];
              return (
                <li>
                  <a
                    class={linkClass}
                    href={e.href}
                    target={isEmail ? undefined : "_blank"}
                    rel={linkRel}
                    aria-label={e.label}
                    title={e.label}
                  >
                    <svg
                      viewBox="0 0 24 24"
                      width="22"
                      height="22"
                      fill="currentColor"
                      fill-rule={glyph.rule}
                      aria-hidden="true"
                      focusable="false"
                    >
                      <path d={glyph.d} />
                    </svg>
                  </a>
                </li>
              );
            })
          }
        </ul>
      </section>

      <footer class="foot">
        <em>Last updated <time datetime="2026-06-09">June 2026</time>.</em>
      </footer>
    </main>

    <script>
      // Now playing — same last.fm source as listening.ronbronson.com
      (async () => {
        const el = document.querySelector<HTMLAnchorElement>(".np");
        if (!el) return;

        const user = "statechampion";
        const apiKey = "4f1d49f394a1567717e2c9049947d004";
        const url = `https://ws.audioscrobbler.com/2.0/?method=user.getrecenttracks&user=${user}&limit=1&api_key=${apiKey}&format=json`;

        try {
          const res = await fetch(url);
          if (!res.ok) return;
          const data = await res.json();

          const track = data?.recenttracks?.track?.[0];
          if (!track) return;

          const isNow = track["@attr"]?.nowplaying === "true";
          const name = track.name || "";
          const artist = track.artist?.["#text"] || track.artist?.name || "";
          const images = track.image || [];
          const art =
            images.find(
              (i: { size: string; "#text": string }) => i.size === "large",
            )?.["#text"] || "";

          const $art = el.querySelector<HTMLImageElement>(".np__art");
          const $label = el.querySelector<HTMLElement>(".np__label");
          const $track = el.querySelector<HTMLElement>(".np__track");
          const $artist = el.querySelector<HTMLElement>(".np__artist");

          if ($art && art) {
            $art.src = art;
            $art.alt = `${name} — ${artist}`;
          }
          if ($label) $label.textContent = isNow ? "Now playing" : "Last played";
          if ($track) $track.textContent = name;
          if ($artist) $artist.textContent = artist;

          el.classList.toggle("np--now", isNow);
          el.hidden = false;
        } catch {
          /* silent fail — widget stays hidden */
        }
      })();
    </script>
  </body>
</html>

