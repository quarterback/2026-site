---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import { LEAD, SOCIAL_PROOF, CAPABILITIES, CONTACT } from '../data/frontdoor';

const SITE_URL = 'https://ronbronson.design';
const CANONICAL_URL = SITE_URL + '/';
const PAGE_DESCRIPTION = LEAD.headline;
const OG_IMAGE = new URL('/hero.jpg', SITE_URL).toString();
---

<Base title={`${LEAD.name} — ${LEAD.headline}`} description={PAGE_DESCRIPTION} noindex={false}>
  <Fragment slot="head">
    <link rel="canonical" href={CANONICAL_URL} />
    <meta property="og:type" content="profile" />
    <meta property="og:title" content={LEAD.name} />
    <meta property="og:description" content={PAGE_DESCRIPTION} />
    <meta property="og:url" content={CANONICAL_URL} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={OG_IMAGE} />
  </Fragment>

  <main id="main" class="home">

    <!-- Lead — the pitch + a clear path to act -->
    <header class="lead">
      <p class="lead__name">{LEAD.name}</p>
      <h1 class="lead__headline">{LEAD.headline}</h1>
      <p class="lead__sub">{LEAD.sub}</p>
      <div class="lead__ctas">
        {LEAD.ctas.map((c, i) => (
          <a
            class={i === 0 ? 'btn' : 'btn btn--ghost'}
            href={c.href}
            target={c.external ? '_blank' : undefined}
            rel={c.external ? 'noopener noreferrer' : undefined}
          >{c.label}</a>
        ))}
      </div>
    </header>

    <!-- Social proof — the names that vouch (Logan) -->
    <section class="proofbar" aria-label={SOCIAL_PROOF.label}>
      <span class="proofbar__label">{SOCIAL_PROOF.label}</span>
      <ul class="proofbar__list">
        {SOCIAL_PROOF.items.map((name) => <li>{name}</li>)}
      </ul>
    </section>

    <!-- Capabilities — big statements, each anchored by work (Martin) -->
    {CAPABILITIES.map((cap) => (
      <section class="cap">
        <div class="cap__lead">
          <h2 class="cap__statement">{cap.statement}</h2>
          <p class="cap__blurb">{cap.blurb}</p>
          {cap.cta && (
            <a class="cap__cta" href={cap.cta.href} target={cap.cta.external ? '_blank' : undefined} rel={cap.cta.external ? 'noopener noreferrer' : undefined}>
              {cap.cta.label}{cap.cta.external ? ' ↗' : ' →'}
            </a>
          )}
        </div>
        <ul class="cap__proof">
          {cap.proof.map((p) => {
            const inner = (
              <>
                {p.image && (
                  <figure class="proof__fig">
                    <img src={p.image} alt={p.label} loading="lazy" />
                  </figure>
                )}
                <span class="proof__label">{p.label}{p.href && p.external ? ' ↗' : ''}</span>
              </>
            );
            return (
              <li class={p.image ? 'proof' : 'proof proof--text'}>
                {p.href ? (
                  <a href={p.href} target={p.external ? '_blank' : undefined} rel={p.external ? 'noopener noreferrer' : undefined}>{inner}</a>
                ) : inner}
              </li>
            );
          })}
        </ul>
      </section>
    ))}

    <!-- Contact — the ask -->
    <section class="contact">
      <p class="contact__line">{CONTACT.line}</p>
      <div class="contact__ctas">
        {CONTACT.ctas.map((c, i) => (
          <a
            class={i === 0 ? 'btn' : 'btn btn--ghost'}
            href={c.href}
            target={c.external ? '_blank' : undefined}
            rel={c.external ? 'noopener noreferrer' : undefined}
          >{c.label}</a>
        ))}
      </div>
    </section>

  </main>

  <Footer />
</Base>

<style>
  .home { max-width: 1000px; margin: 0 auto; padding: 0 var(--pad); }

  /* ───── Buttons ───── */
  .btn {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.7rem 1.25rem;
    border-radius: 100px;
    background: var(--ink);
    color: #fff;
    border: 1.5px solid var(--ink);
    transition: background 0.15s, color 0.15s;
  }
  .btn:hover { background: var(--accent); border-color: var(--accent); color: #1a1a1a; }
  .btn--ghost { background: transparent; color: var(--ink); }
  .btn--ghost:hover { background: var(--ink); color: #fff; border-color: var(--ink); }

  /* ───── Lead ───── */
  .lead { padding: clamp(3rem, 9vw, 6rem) 0 clamp(1.5rem, 3vw, 2.5rem); }
  .lead__name {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-mid);
    margin: 0 0 1.5rem;
  }
  .lead__headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.1rem, 6vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin: 0;
    max-width: 18ch;
  }
  .lead__sub {
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 1.8vw, 1.3rem);
    line-height: 1.5;
    color: var(--ink-mid);
    max-width: 52ch;
    margin: 1.25rem 0 0;
  }
  .lead__ctas { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 2rem; }

  /* ───── Social proof bar ───── */
  .proofbar {
    padding: 1.25rem 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem 1.5rem;
  }
  .proofbar__label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .proofbar__list {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-wrap: wrap; gap: 0.4rem 1rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--ink-mid);
  }
  .proofbar__list li { white-space: nowrap; }

  /* ───── Capability blocks ───── */
  .cap {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: start;
    padding: clamp(2.5rem, 6vw, 4.5rem) 0;
    border-bottom: 1px solid var(--rule);
  }
  .cap__statement {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0;
  }
  .cap__blurb {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--ink-mid);
    margin: 1rem 0 0;
    max-width: 42ch;
  }
  .cap__cta {
    display: inline-block;
    margin-top: 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 3px;
  }
  .cap__cta:hover { text-decoration-thickness: 2.5px; }

  /* proof grid — work artifacts */
  .cap__proof {
    list-style: none; margin: 0; padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 1rem;
  }
  .proof a { text-decoration: none; color: inherit; display: block; }
  .proof__fig {
    margin: 0 0 0.5rem;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--bg-ink);
    border-radius: 5px;
  }
  .proof__fig img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.25s; }
  .proof a:hover .proof__fig img { transform: scale(1.04); }
  .proof__label {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-mid);
    line-height: 1.3;
  }
  /* text-only proof = a pill */
  .proof--text {
    align-self: start;
  }
  .proof--text .proof__label {
    display: inline-block;
    background: var(--bg-ink);
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 0.35rem 0.7rem;
    color: var(--ink);
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.8rem;
  }

  /* ───── Contact band ───── */
  .contact { padding: clamp(3rem, 7vw, 5rem) 0; }
  .contact__line {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.5rem, 3.5vw, 2.4rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink);
    max-width: 24ch;
    margin: 0;
  }
  .contact__ctas { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.75rem; }

  @media (max-width: 720px) {
    .cap { grid-template-columns: 1fr; gap: 1.5rem; }
  }
</style>
