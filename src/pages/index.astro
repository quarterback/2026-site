---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Books from '../components/Books.astro';
import Albums from '../components/Albums.astro';
import Footer from '../components/Footer.astro';
import { fetchMultipleRSS } from '../lib/rss';

const rssFeeds = [
  'https://makingpublicwork.com/rss/',
  'https://blog.ronbronson.com/feed.rss',
];

let recentPosts: any[] = [];
try {
  const allPosts = await fetchMultipleRSS(rssFeeds);
  recentPosts = allPosts.slice(0, 5);
} catch (error) {
  console.error('Failed to fetch RSS feeds:', error);
  recentPosts = [];
}

const currentBooks = [
  {
    title: "1929",
    author: "Andrew Ross Sorkin",
  },
  {
    title: "Exocapitalism: The Political Economy of Software",
    author: "Charles Mudede",
  },
  {
    title: "The Field Guide to Design Futures",
    author: "Giovanni Caruso, Silvio Cioni",
  },
];

const currentAlbums = [
  {
    title: "Until It's Time For Me to Go",
    artist: "Jim Croce",
  },
  {
    title: "There Is Nothing more to Say",
    artist: "The Millenium",
  },
  {
    title: "Another Song for the End of the World",
    artist: "Sophie May",
  },
  {
    title: "People Make The World Go Round",
    artist: "Saeed",
  },
];

const techStack = [
  "built hastily using Astro, Open Props, FontAwesome, TypeScript, Playfair Display, DM Sans, DM Mono, Netlify & GitHub"
];

const fonts: string[] = [];
---

<Base title="Ron Bronson">
  <main id="main">
    <Hero
      headline='I build and fix<br>the systems that<br>run <em>public life.</em>'
      bio='Service designer, UX engineer, and information architect. I build and lead high-performing cross-functional teams across product, design, and engineering. I developed trajectory management and delivery forensics, frameworks for navigating complex programs and diagnosing failure. Currently Assistant Professor of Practice in Urban Technology at <strong>Michigan&apos;s Taubman College</strong>. Former Head of Design at <strong>18F</strong>. Co-founder of <a href="https://aigapdx.org">PDX Design Month</a>. Developed the model for <a href="https://pdxdigitalcorps.org">local civic response teams</a>.'

      primaryCTA={{ label: "Making Public Work ↗", url: "https://makingpublicwork.com" }}
      secondaryCTA={{ label: "Independent Practice", url: "https://occupant.works" }}
    />

    <!-- Work Grid -->
    <section class="section" id="work" aria-labelledby="work-heading">
      <div class="container">
        <p class="section-label" id="work-heading">Selected Work</p>
        <div class="work-grid">
          <a href="/work/18f-leadership" class="work-item">
            <span class="work-tag">Federal · 2016–2024</span>
            <span class="work-title">Design Leadership at Scale, 18F</span>
            <span class="work-desc">Built and led a 40-person design practice across federal agencies including the VA, IRS, HHS, DOD, and FTC. Delivery work touched millions of Americans.</span>
            <span class="work-arrow">See the work →</span>
          </a>
          <a href="/frameworks" class="work-item">
            <span class="work-tag">Research · Ongoing</span>
            <span class="work-title">Public Mechanics</span>
            <span class="work-desc">Original frameworks for how public services are built, maintained, and fail — including Trajectory Management and Delivery Forensics.</span>
            <span class="work-arrow">Read the frameworks →</span>
          </a>
          <a href="https://statecapacity.ai" class="work-item">
            <span class="work-tag">Tool · 2024–Ongoing</span>
            <span class="work-title">State Capacity AI</span>
            <span class="work-desc">Tracks AI model pricing and performance for institutional procurement. Built for decision-makers who need vendor intelligence without the sales pitch.</span>
            <span class="work-arrow">statecapacity.ai →</span>
          </a>
          <a href="/work/portland-digital-corps" class="work-item">
            <span class="work-tag">Community · 2025</span>
            <span class="work-title">Portland Digital Corps</span>
            <span class="work-desc">Assembled 50+ practitioners to rebuild six Oregon nonprofit websites. Volunteer infrastructure for civic digital capacity.</span>
            <span class="work-arrow">See the work →</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Pull Quote -->
    <div class="pull-quote">
      <div class="pull-quote-inner container">
        <blockquote>
          Most design work is repair — patching the gaps between intention and reality, between policy and the lived experience of the people who depend on public systems.
          <cite>— Design as Repair, 2025</cite>
        </blockquote>
      </div>
    </div>

    <!-- Writing + Speaking -->
    <section class="section" id="writing" aria-labelledby="writing-heading">
      <div class="container">
        <p class="section-label" id="writing-heading">Writing &amp; Speaking</p>
        <div class="two-col">

          <div>
            <p class="col-label">Recent Writing</p>
            <ul class="writing-list">
              <li>
                <a href="https://makingpublicwork.com/who-holds-the-pen-why-ai-agents-need-a-manager-not-just-a-manual/" class="writing-item">
                  <span class="writing-type">Analysis</span>
                  <span class="writing-title">Who Holds the Pen?</span>
                  <span class="writing-pub">makingpublicwork.com</span>
                </a>
              </li>
              <li>
                <a href="https://blog.ronbronson.com/design-as-repair" class="writing-item">
                  <span class="writing-type">Essay</span>
                  <span class="writing-title">Design as Repair</span>
                  <span class="writing-pub">ronbronson.com</span>
                </a>
              </li>
              <li>
                <a href="https://piccalil.li/blog/some-advice-on-managing-your-design-career-upwards/" class="writing-item">
                  <span class="writing-type">Article</span>
                  <span class="writing-title">Managing Your Design Career Upwards</span>
                  <span class="writing-pub">Piccalilli</span>
                </a>
              </li>
              <li>
                <a href="https://makingpublicwork.com" class="writing-item">
                  <span class="writing-type">Newsletter</span>
                  <span class="writing-title">Making Public Work — Ongoing</span>
                  <span class="writing-pub">Subscribe →</span>
                </a>
              </li>
            </ul>
          </div>

          <div id="speaking">
            <p class="col-label">Recent Speaking</p>
            <ul class="speaking-list">
              <li class="speaking-item">
                <span class="speaking-venue">IxDA Oslo</span>
                <span class="speaking-title">Keynote</span>
                <span class="speaking-date">2025</span>
              </li>
              <li class="speaking-item">
                <span class="speaking-venue">Service Design Show</span>
                <span class="speaking-title">Repairing Service Design for the Age of AI</span>
                <span class="speaking-date">Sep 2025</span>
              </li>
              <li class="speaking-item">
                <span class="speaking-venue">Code for America Summit</span>
                <span class="speaking-title">Panel</span>
                <span class="speaking-date">2025</span>
              </li>
              <li class="speaking-item">
                <span class="speaking-venue">Hype Studies, Barcelona</span>
                <span class="speaking-title">Workshop</span>
                <span class="speaking-date">2025</span>
              </li>
              <li class="speaking-item">
                <span class="speaking-venue">Throughline Conference</span>
                <span class="speaking-title">Design as Repair</span>
                <span class="speaking-date">2025</span>
              </li>
              <li class="speaking-item">
                <span class="speaking-venue">Cascadia Open Source GIS</span>
                <span class="speaking-title">Beyond Civic Tech</span>
                <span class="speaking-date">Nov 2025</span>
              </li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- Media Consumption: Books & Albums (personal section) -->
    <section id="media-consumption">
      <div class="container">
        <div class="media-grid">
          <Books books={currentBooks} />
          <Albums albums={currentAlbums} title="Now Listening" />
        </div>
      </div>
    </section>
  </main>

  <Footer
    techStack={techStack}
    fonts={fonts}
  />
</Base>

<style>
  /* ===== SECTIONS ===== */
  .section {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: clamp(3rem, 7vh, 5rem) var(--pad);
    border-top: 1px solid var(--rule);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.63rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 2.5rem;
  }

  /* ===== WORK GRID ===== */
  .work-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .work-item {
    background: var(--bg);
    padding: 2rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    transition: background 0.15s;
  }

  .work-item:hover {
    background: var(--bg-warm);
  }

  .work-tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .work-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.25;
  }

  .work-desc {
    font-size: 0.875rem;
    font-weight: 300;
    color: var(--ink-mid);
    line-height: 1.65;
    flex: 1;
  }

  .work-arrow {
    font-family: var(--font-mono);
    font-size: 0.63rem;
    letter-spacing: 0.04em;
    color: var(--ink-faint);
    margin-top: 0.5rem;
    transition: color 0.15s;
  }

  .work-item:hover .work-arrow {
    color: var(--accent);
  }

  /* ===== PULL QUOTE ===== */
  .pull-quote {
    background: var(--bg-warm);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: clamp(3rem, 7vh, 5rem) 0;
  }

  .pull-quote-inner {
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .pull-quote blockquote {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.3rem, 2.6vw, 1.85rem);
    font-weight: 400;
    line-height: 1.55;
    color: var(--ink);
    max-width: 740px;
    padding-left: 1.5rem;
    border-left: 3px solid var(--accent);
  }

  .pull-quote blockquote cite {
    display: block;
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-top: 1.25rem;
  }

  /* ===== WRITING + SPEAKING TWO-COL ===== */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .col-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 1.5rem;
  }

  .writing-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .writing-item {
    display: grid;
    grid-template-columns: 4.5rem 1fr auto;
    align-items: baseline;
    gap: 1.25rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--rule);
    text-decoration: none;
  }

  .writing-item:first-child {
    border-top: 1px solid var(--rule);
  }

  .writing-item:hover .writing-title {
    color: var(--accent);
  }

  .writing-type {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .writing-title {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-style: italic;
    color: var(--ink);
    line-height: 1.35;
    transition: color 0.15s;
  }

  .writing-pub {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
    white-space: nowrap;
  }

  .speaking-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  .speaking-item {
    padding: 1.1rem;
    background: var(--bg-ink);
    border: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .speaking-venue {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .speaking-title {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    font-style: italic;
    color: var(--ink);
    line-height: 1.4;
  }

  .speaking-date {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-top: auto;
    padding-top: 0.4rem;
  }

  /* ===== MEDIA CONSUMPTION (kept from original) ===== */
  #media-consumption {
    margin-bottom: var(--size-5);
  }

  .media-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--size-6);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .work-grid {
      grid-template-columns: 1fr;
    }

    .two-col {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .writing-item {
      grid-template-columns: 3.5rem 1fr;
    }

    .writing-pub {
      display: none;
    }

    .media-grid {
      grid-template-columns: 1fr;
      gap: var(--size-5);
    }
  }

  @media (max-width: 480px) {
    .writing-item {
      grid-template-columns: 1fr;
      gap: 0.15rem;
    }

    .writing-type {
      display: none;
    }
  }
</style>
