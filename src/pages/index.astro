---
const ME = {
  name: "Ron Bronson",
  byline: "Service designer & design leader",
  location: "Pacific Northwest",
  portrait: "/hero.jpg",
};

const WRITING = [
  {
    title: "Some advice on managing your design career upwards",
    where: "Piccalil.li",
    href: "https://piccalil.li/blog/some-advice-on-managing-your-design-career-upwards/",
  },
];

const INTERVIEWS = [
  {
    title: "Repairing Service Design for the Age of AI",
    where: "Service Design Show",
    href: "https://podcasts.apple.com/br/podcast/repairing-service-design-for-the-age-of-ai-ron-bronson-ep-236/id1104665758?i=1000726081505",
  },
  {
    title: "Future Perfect Book Club",
    where: "with Joel Goodman",
    href: "https://futureperfectbook.club",
  },
];

const TALKS = [
  {
    title: "Design as Repair",
    where: "IxDA Oslo, 2025",
    href: "https://www.ixda.no/talks/design-as-repair",
  },
  {
    title: "Beyond Civic Tech: Public Mechanics Starts at Home",
    where: "Cascadia Open Source Fall Conference, 2025",
    href: "https://youtube.com/watch?v=hnAScuK-oMo",
  },
  {
    title: "Design Systems and Public Services",
    where: "YouTube, 2025",
    href: "https://www.youtube.com/watch?v=kL0gYtoUtvI",
  },
];

const PROJECTS = [
  { title: "State Capacity AI", href: "https://statecapacity.ai" },
  { title: "Portland Digital Corps", href: "https://digitalcorpspdx.org" },
  { title: "Making Public Work", href: "https://makingpublicwork.com" },
];

const ELSEWHERE = [
  { label: "Bluesky", href: "https://bsky.app/profile/ronbronson.com" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/ronbronson/" },
  { label: "GitHub", href: "https://github.com/quarterback" },
  { label: "Email", href: "mailto:hello@ronbronson.com" },
];

const ROMANS = ["I", "II", "III", "IV", "V", "VI", "VII", "VIII"];

const sections = [
  { title: "Writing", items: WRITING, venue: true },
  { title: "Interviews", items: INTERVIEWS, venue: true },
  { title: "Talks", items: TALKS, venue: true },
  { title: "Projects", items: PROJECTS, venue: false },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Ron Bronson</title>
    <meta
      name="description"
      content={`${ME.byline}. Based in ${ME.location}.`}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;0,6..72,700;1,6..72,400;1,6..72,500;1,6..72,600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="page">
      <figure class="page__fig">
        <img src={ME.portrait} alt={ME.name} />
      </figure>

      <header class="page__hdr">
        <h1 class="page__name">{ME.name}</h1>
        <p class="page__byline">{ME.byline}. Based in {ME.location}.</p>
      </header>

      <p class="page__intro">
        I work with public-sector teams on bounded delivery problems — backlogs
        and stuck workflows that need a fix in weeks, not quarters. I publish <a
          href="https://makingpublicwork.com">Making Public Work</a>, teach at
        the University of Michigan, and build tools like <a
          href="https://statecapacity.ai">State Capacity AI</a> for institutions
        trying to do more with the people and systems they already have.
      </p>

      {
        sections.map((section, i) => (
          <section class="sec">
            <h2 class="sec__h">
              <span class="sec__num">{ROMANS[i]}.</span>
              <span class="sec__name">{section.title}</span>
            </h2>
            <ul class="sec__list">
              {section.items.map((it) => (
                <li class="sec__row">
                  <a href={it.href} target="_blank" rel="noopener noreferrer">
                    {it.title}
                  </a>
                  {section.venue && it.where ? (
                    <span class="sec__where"> — {it.where}</span>
                  ) : null}
                </li>
              ))}
            </ul>
          </section>
        ))
      }

      <section class="sec">
        <h2 class="sec__h">
          <span class="sec__num">{ROMANS[sections.length]}.</span>
          <span class="sec__name">Elsewhere</span>
        </h2>
        <ul class="sec__list sec__list--inline">
          {
            ELSEWHERE.map((e, i) => (
              <li>
                <a href={e.href} target="_blank" rel="noopener noreferrer">
                  {e.label}
                </a>
                {i < ELSEWHERE.length - 1 && (
                  <span class="sec__sep" aria-hidden="true"> · </span>
                )}
              </li>
            ))
          }
        </ul>
      </section>

      <footer class="foot">
        <em>Last updated <time datetime="2026-05-18">May 2026</time>.</em>
      </footer>
    </main>
  </body>
</html>

<style is:global>
  /* ─────────────────────────────────────────────────────────────
     TOKENS — WCAG verified on stone paper #ededeb:
       #18181a on #ededeb   15.4 : 1   AAA   body
       #5b5a55 on #ededeb    5.7 : 1   AA    meta / italic
       #7a1f2c on #ededeb    7.4 : 1   AAA   oxblood accent
       #1c3faa on #ededeb    8.4 : 1   AAA   link
       #5c2d91 on #ededeb    7.0 : 1   AAA   visited
     Paper is a near-neutral cool stone — explicitly NOT yellow/beige.
     ───────────────────────────────────────────────────────────── */
  :root {
    --paper: #ededeb;
    --ink: #18181a;
    --ink-2: #5b5a55;
    --ink-3: #95938d;
    --oxblood: #7a1f2c;
    --link: #1c3faa;
    --link-vis: #5c2d91;
    --link-hov: #0e2670;
    --hair: #c9c8c4;
    --hair-2: #dddcd8;

    --serif: "Newsreader", "Source Serif 4", "Lyon Text", Georgia,
      "Times New Roman", serif;
  }

  * {
    box-sizing: border-box;
  }
  html,
  body {
    margin: 0;
    padding: 0;
  }
  body {
    background: var(--paper);
    color: var(--ink);
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    font-feature-settings: "kern", "liga", "onum";
    font-optical-sizing: auto;
    hanging-punctuation: first last;
  }

  .page {
    max-width: 580px;
    margin: 0 auto;
    padding: 56px 28px 96px;
  }

  /* ───── Portrait — wide visual anchor at the top ───── */
  .page__fig {
    margin: 0 0 28px;
    position: relative;
  }
  .page__fig img {
    display: block;
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    object-position: center 22%;
    filter: saturate(0.86) contrast(1.06) brightness(0.98);
    border: 0.5px solid rgba(24, 24, 26, 0.18);
  }

  /* ───── Name + byline ───── */
  .page__hdr {
    margin: 0 0 28px;
  }
  .page__name {
    margin: 0;
    font-family: var(--serif);
    font-style: italic;
    font-weight: 600;
    font-size: clamp(34px, 5.6vw, 44px);
    line-height: 1.02;
    letter-spacing: -0.015em;
    color: var(--ink);
    font-variation-settings: "opsz" 60;
  }
  .page__byline {
    margin: 8px 0 0;
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: 17px;
    line-height: 1.4;
    color: var(--ink-2);
    text-wrap: pretty;
  }

  /* ───── Intro paragraph ───── */
  .page__intro {
    margin: 0 0 56px;
    font-size: 18px;
    line-height: 1.6;
    color: var(--ink);
    text-wrap: pretty;
    max-width: 50ch;
  }

  /* ───── Section ───── */
  .sec {
    margin: 0 0 44px;
  }

  .sec__h {
    margin: 0 0 14px;
    font-family: var(--serif);
    font-weight: 600;
    font-size: 13px;
    line-height: 1;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--oxblood);
    display: flex;
    align-items: baseline;
    gap: 12px;
    padding-bottom: 10px;
    border-bottom: 0.5px solid var(--hair);
  }
  .sec__num {
    font-style: italic;
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.05em;
    color: var(--oxblood);
    font-variant-numeric: lining-nums;
    min-width: 26px;
    text-transform: none;
  }
  .sec__name {
    flex: 1;
  }

  .sec__list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .sec__row {
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.5;
    color: var(--ink);
    text-wrap: pretty;
    text-indent: 0;
  }
  .sec__where {
    color: var(--ink-2);
    font-style: italic;
  }

  /* Inline list — for the elsewhere row */
  .sec__list--inline {
    flex-direction: row;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0;
  }
  .sec__list--inline li {
    font-family: var(--serif);
    font-size: 17px;
  }
  .sec__sep {
    color: var(--ink-3);
    padding: 0 4px;
  }

  /* ───── Links ───── */
  a {
    color: var(--link);
    text-decoration: underline;
    text-decoration-thickness: 0.7px;
    text-underline-offset: 2.5px;
    text-decoration-color: rgba(28, 63, 170, 0.45);
    transition: color 120ms, text-decoration-color 120ms;
  }
  a:visited {
    color: var(--link-vis);
    text-decoration-color: rgba(92, 45, 145, 0.45);
  }
  a:hover {
    color: var(--link-hov);
    text-decoration-color: currentColor;
  }
  a:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 2px;
    border-radius: 1px;
  }

  /* ───── Foot ───── */
  .foot {
    margin-top: 60px;
    padding-top: 18px;
    border-top: 0.5px solid var(--hair);
    font-family: var(--serif);
    font-size: 14px;
    color: var(--ink-2);
    text-align: right;
  }
  .foot time {
    font-variant-numeric: tabular-nums oldstyle-nums;
  }

  ::selection {
    background: rgba(122, 31, 44, 0.18);
    color: var(--ink);
  }

  /* ─────────────────────────────────────────────────────────────
     Responsive
     ───────────────────────────────────────────────────────────── */
  @media (max-width: 560px) {
    .page {
      padding: 32px 22px 64px;
    }
    body {
      font-size: 16px;
    }
    .page__intro {
      font-size: 17px;
    }
    .sec__row,
    .sec__list--inline li {
      font-size: 16px;
    }
    .page__byline {
      font-size: 16px;
    }
  }

  @media (max-width: 380px) {
    .page {
      padding: 24px 16px 48px;
    }
  }

  @media print {
    body {
      background: white;
    }
    .page__fig img {
      filter: none;
    }
    a {
      color: black;
    }
  }
</style>
</html>
