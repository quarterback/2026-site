---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import LastScrobble from '../components/LastScrobble.astro';
import { getHomepageStream } from '../lib/stream';
import { getBookhive } from '../lib/bookhive';
import { POSITIONING, HIGHLIGHTS } from '../data/frontdoor';

const SITE_URL = 'https://ronbronson.design';
const CANONICAL_URL = SITE_URL + '/';
const PAGE_DESCRIPTION = `${POSITIONING.name} — ${POSITIONING.role}. ${POSITIONING.tagline}`;
const PORTRAIT_URL = new URL(POSITIONING.portrait, SITE_URL).toString();

const POSTS = await getHomepageStream(5);
const bookhive = await getBookhive();
const reading = bookhive.reading[0];
---

<Base title={POSITIONING.name} description={PAGE_DESCRIPTION} noindex={false}>
  <Fragment slot="head">
    <link rel="canonical" href={CANONICAL_URL} />
    <meta property="og:type" content="profile" />
    <meta property="og:title" content={POSITIONING.name} />
    <meta property="og:description" content={PAGE_DESCRIPTION} />
    <meta property="og:url" content={CANONICAL_URL} />
    <meta property="og:image" content={PORTRAIT_URL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={PORTRAIT_URL} />
  </Fragment>

  <main id="main" class="home">

    <!-- Masthead — lead with name + what he does, not a title. -->
    <header class="mast">
      <h1 class="mast__name">{POSITIONING.name}</h1>
      <p class="mast__line">{POSITIONING.tagline}</p>
    </header>

    <!-- Now — slim present-tense pulse -->
    <section class="pulse" aria-label="Now">
      <span class="kicker">Now</span>
      {reading && (
        <span class="pulse__item">Reading <em>{reading.title}</em></span>
      )}
      <LastScrobble />
      <a class="pulse__more" href="/now">More &rarr;</a>
    </section>

    <!-- Highlights — photo-forward grid of things done. The core. -->
    <section class="block" aria-labelledby="hl-h">
      <h2 id="hl-h" class="block__h"><span class="kicker">Highlights</span></h2>
      <ul class="cards">
        {HIGHLIGHTS.map((h) => (
          <li class="card">
            {h.image && (
              <figure class="card__fig">
                <img src={h.image} alt={h.alt ?? h.title} loading="lazy" />
              </figure>
            )}
            <div class="card__body">
              {h.tag && <span class={`chip chip--${h.tag.toLowerCase()}`}>{h.tag}</span>}
              <h3 class="card__title">
                {h.href ? (
                  <a href={h.href} target={h.external ? '_blank' : undefined} rel={h.external ? 'noopener noreferrer' : undefined}>
                    {h.title}{h.external ? ' ↗' : ''}
                  </a>
                ) : h.title}
              </h3>
              {h.blurb && <p class="card__blurb">{h.blurb}</p>}
              {h.when && <span class="card__when">{h.when}</span>}
            </div>
          </li>
        ))}
      </ul>
    </section>

    <!-- Recent writing — simple list pattern -->
    {POSTS.length > 0 && (
      <section class="block" aria-labelledby="rw-h">
        <h2 id="rw-h" class="block__h"><span class="kicker">Recent Writing</span></h2>
        <ul class="rows">
          {POSTS.map((post) => (
            <li class="row">
              <a href={post.url} target="_blank" rel="noopener noreferrer">{post.title}</a>
              <span class="row__where">{post.source}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

  </main>

  <Footer />
</Base>

<style>
  .home {
    max-width: 1080px;
    margin: 0 auto;
    padding: clamp(2.5rem, 6vw, 4.5rem) var(--pad) 0;
  }

  /* ───── Kicker — mono label, neutral for legibility ───── */
  .kicker {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-mid);
    margin: 0;
  }

  /* ───── Masthead ───── */
  .mast {
    padding-bottom: clamp(1.5rem, 4vw, 2.5rem);
  }
  .mast__name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.03em;
    margin: 0 0 0.75rem;
    color: var(--ink);
  }
  .mast__line {
    font-family: var(--font-body);
    font-size: clamp(1.15rem, 2vw, 1.5rem);
    font-weight: 400;
    line-height: 1.4;
    color: var(--ink-mid);
    max-width: 30ch;
    margin: 0;
  }

  /* ───── Now pulse ───── */
  .pulse {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 1.25rem;
    padding: 0.85rem 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--ink-mid);
  }
  .pulse__item em { font-style: normal; font-weight: 600; color: var(--ink); }
  .pulse :global(.last-scrobble) {
    display: inline-flex; align-items: center; gap: 0.5rem;
    color: var(--ink-mid); text-decoration: none;
  }
  .pulse :global(.last-scrobble .ls-label) {
    font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--ink-faint); display: block;
  }
  .pulse__more { margin-left: auto; font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; }

  /* ───── Block ───── */
  .block { padding: clamp(2.5rem, 6vw, 4rem) 0; }
  .block__h { margin: 0 0 1.75rem; }

  /* ───── Highlight cards — photo-forward grid ───── */
  .cards {
    list-style: none; margin: 0; padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }
  .card { display: flex; flex-direction: column; }
  .card__fig {
    margin: 0 0 1rem;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--bg-ink);
    border-radius: 6px;
  }
  .card__fig img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .card__body { display: flex; flex-direction: column; align-items: flex-start; gap: 0.5rem; }
  .card__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.35rem;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--ink);
  }
  .card__title a { color: var(--ink); text-decoration: none; }
  .card__title a:hover { text-decoration: underline; text-decoration-color: var(--accent); text-decoration-thickness: 2px; text-underline-offset: 3px; }
  .card__blurb {
    font-family: var(--font-body);
    font-size: 0.98rem;
    line-height: 1.5;
    color: var(--ink-mid);
    margin: 0;
  }
  .card__when {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  /* ───── Category chips — the bright palette lives here ───── */
  .chip {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    color: #1a1a1a;
    padding: 0.2rem 0.55rem;
    border-radius: 100px;
  }
  .chip--ran,
  .chip--speaking      { background: var(--pink); }
  .chip--founded,
  .chip--built         { background: var(--blue); }
  .chip--teaching,
  .chip--writing       { background: var(--gold); }
  .chip--coaching      { background: var(--blue-soft); }

  /* ───── Row list (recent writing) ───── */
  .rows { list-style: none; margin: 0; padding: 0; display: grid; gap: 0; }
  .row {
    display: flex; justify-content: space-between; align-items: baseline; gap: 1rem;
    padding: 0.85rem 0;
    border-top: 1px solid var(--rule);
    font-family: var(--font-body); font-size: 1.05rem;
  }
  .row:last-child { border-bottom: 1px solid var(--rule); }
  .row a { color: var(--ink); text-decoration: none; }
  .row a:hover { text-decoration: underline; text-decoration-color: var(--accent); text-decoration-thickness: 2px; text-underline-offset: 3px; }
  .row__where { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-faint); white-space: nowrap; }

  @media (max-width: 560px) {
    .row { flex-direction: column; gap: 0.2rem; }
  }
</style>
