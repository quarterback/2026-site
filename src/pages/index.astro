---
import { getHomepageStream } from "../lib/stream";

const ME = {
  name: "Ron Bronson",
  byline: "Product Delivery Engineer + Critical Service Design Exec",
  location: "",
  portrait: "/hero.jpg",
};

const POSTS = await getHomepageStream(5);

const SITE_URL = "https://ronbronson.design";
const PAGE_DESCRIPTION = `${ME.byline} ${ME.location}.`;
const PORTRAIT_URL = new URL(ME.portrait, SITE_URL).toString();
const CANONICAL_URL = SITE_URL + "/";

const WRITING = [
  {
    title: "Some advice on managing your design career upwards",
