];

const ELSEWHERE = [
  { label: "Bluesky", href: "https://bsky.app/profile/ronbronson.com", icon: "bluesky" },
  { label: "Mastodon", href: "https://mastodon.social/@ronbronson", icon: "mastodon" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/ronbronson/", icon: "linkedin" },
  { label: "GitHub", href: "https://github.com/quarterback", icon: "github" },
  { label: "Instagram", href: "https://www.instagram.com/ronbronson/", icon: "instagram" },
  { label: "Twitter", href: "https://twitter.com/ronbronson", icon: "twitter" },
  { label: "Letterboxd", href: "https://letterboxd.com/ronbronson/", icon: "letterboxd" },
  { label: "Literal.club", href: "https://literal.club/ron", icon: "book" },
  { label: "Record.club", href: "https://record.club/ron", icon: "record" },
  { label: "Listening", href: "https://listening.ronbronson.com", icon: "headphones" },
  { label: "Email", href: "mailto:ron@ronbronson.com", icon: "email" },
