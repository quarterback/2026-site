---
import { getHomepageStream } from "../lib/stream";

const ME = {
  name: "Ron Bronson",
  byline: "Product Delivery Engineer + Critical Service Design Exec",
  location: "",
  portrait: "/hero.jpg",
};

const POSTS = await getHomepageStream(5);

const SITE_URL = "https://ronbronson.design";
const PAGE_DESCRIPTION = `${ME.byline} ${ME.location}.`;
const PORTRAIT_URL = new URL(ME.portrait, SITE_URL).toString();
const CANONICAL_URL = SITE_URL + "/";

const WRITING = [
  {
    title: "Some advice on managing your design career upwards",
    where: "Piccalil.li",
    href: "https://piccalil.li/blog/some-advice-on-managing-your-design-career-upwards/",
  },
  {
    title: "Design as Repair",
    href: "https://blog.ronbronson.com/design-as-repair",
  },
  {
    title: "The Bureaucratic Banality of Andor",
    href: "https://blog.ronbronson.com/the-bureaucratic-banality-of-andor",
  },
  {
    title: "What Forward Deployed Design Actually Looks Like",
    href: "https://blog.ronbronson.com/what-forward-deployed-design-actually-looks-like?ref=rogerwong.me",
  },
];

const INTERVIEWS = [
  {
    title: "Service Design Show Podcast",
    href: "https://podcasts.apple.com/br/podcast/repairing-service-design-for-the-age-of-ai-ron-bronson-ep-236/id1104665758?i=1000726081505",
  },
  {
    title: "Leading the Field",
    where: "Code for America",
    href: "https://codeforamerica.org/news/leading-the-field-ron-bronson/",
  },
  {
    title: "Did I Do That Podcast",
    href: "https://www.dididothat.design/episode/what-huh-me-huh-what-with-ron-bronson",
  },
  {
    title: "Surfacing Podcast",
    href: "https://open.spotify.com/episode/2lC2xrhf4PIasyzJW4faP7",
  },
  {
    title: "Building Better User-Centered Products",
    where: "Pixel Pioneers",
    href: "https://pixelpioneers.co/blog/building-better-user-centered-products-an-interview-with-ron-bronson",
  },
];

const TEACHING = [
  { title: "UT 402 Public Mechanics", where: "F26, W26" },
  { title: "UT 330 Interaction Design", where: "F26" },
  { title: "UT 360 Service Design and Urban Needs", where: "W'26, W'24" },
];

const HOST = [
  { title: "Future Perfect Book Club", href: "https://futureperfectbook.club" },
  {
    title: "The Sound Bulletin on KFFP-FM",
    href: "https://www.mixcloud.com/908rb/",
  },
];

const TALKS = [
  {
    title: "Design as Repair",
    where: "IxDA Oslo",
    href: "https://www.ixda.no/talks/design-as-repair",
  },
  {
    title: "Deceptive Design / Consequence Design",
    where: "digital.gov",
    href: "https://digital.gov/resources/deceptive-design-how-to-identify-and-combat-consequence-design",
  },
  {
    title: "Design Consequences in Everyday Life",
    where: "Rosenfeld Civic Design, 2022",
    href: "https://rosenfeldmedia.com/civic-design-2022/design-consequences-everyday-life-ron-bronson-readings-and-other-resources/",
  },
];

const ELSEWHERE = [
  { label: "Bluesky", href: "https://bsky.app/profile/ronbronson.com", icon: "fa-brands fa-bluesky" },
  { label: "Mastodon", href: "https://mastodon.social/@ronbronson", icon: "fa-brands fa-mastodon" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/ronbronson/", icon: "fa-brands fa-linkedin-in" },
  { label: "GitHub", href: "https://github.com/quarterback", icon: "fa-brands fa-github" },
  { label: "Instagram", href: "https://www.instagram.com/ronbronson/", icon: "fa-brands fa-instagram" },
  { label: "Twitter", href: "https://twitter.com/ronbronson", icon: "fa-brands fa-x-twitter" },
  { label: "Letterboxd", href: "https://letterboxd.com/ronbronson/", icon: "fa-brands fa-letterboxd" },
  { label: "Literal.club", href: "https://literal.club/ron", icon: "fa-solid fa-book" },
  { label: "Record.club", href: "https://record.club/ron", icon: "fa-solid fa-record-vinyl" },
  { label: "Listening", href: "https://listening.ronbronson.com", icon: "fa-solid fa-headphones" },
  { label: "Email", href: "mailto:ron@ronbronson.com", icon: "fa-solid fa-envelope" },
];

const sections = [
  { title: "Writing", items: WRITING, venue: true },
  { title: "Interviews", items: INTERVIEWS, venue: true },
  { title: "Teaching", items: TEACHING, venue: true },
  { title: "Host", items: HOST, venue: false },
  { title: "Talks", items: TALKS, venue: true },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{ME.name}</title>
    <meta name="description" content={PAGE_DESCRIPTION} />
    <meta name="author" content={ME.name} />
    <link rel="canonical" href={CANONICAL_URL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="profile" />
    <meta property="og:site_name" content={ME.name} />
    <meta property="og:title" content={ME.name} />
    <meta property="og:description" content={PAGE_DESCRIPTION} />
    <meta property="og:url" content={CANONICAL_URL} />
    <meta property="og:image" content={PORTRAIT_URL} />
    <meta property="og:image:alt" content={`Portrait of ${ME.name}`} />
    <meta property="profile:first_name" content="Ron" />
    <meta property="profile:last_name" content="Bronson" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@ronbronson" />
    <meta name="twitter:creator" content="@ronbronson" />
    <meta name="twitter:title" content={ME.name} />
    <meta name="twitter:description" content={PAGE_DESCRIPTION} />
    <meta name="twitter:image" content={PORTRAIT_URL} />
    <meta name="twitter:image:alt" content={`Portrait of ${ME.name}`} />

    <!-- Webmentions / IndieWeb -->
    <link
      rel="webmention"
      href="https://webmention.io/ronbronson.design/webmention"
    />
    <link
      rel="pingback"
      href="https://webmention.io/ronbronson.design/xmlrpc"
    />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />
    <link
      href="https://api.fontshare.com/v2/css?f[]=sentient@400,500,700,401,501&f[]=general-sans@400,500,600&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.7.2/css/all.min.css"
    />
  </head>
  <body>
    <main class="page h-card">
      <a class="u-url u-uid" href={CANONICAL_URL} hidden aria-hidden="true"
        >{ME.name}</a
      >

      <header class="page__hdr">
        <h1 class="page__name p-name">{ME.name}</h1>
        {/*
        <p class="page__byline">
          <span class="p-job-title">{ME.byline}</span> Based in <span
            class="p-locality">{ME.location}</span
          >.
        </p>
        */}
      </header>

      <p class="page__intro p-note">
        I design information systems.
      </p>
      <p class="page__intro p-note">
        That has meant content strategy, information architecture, digital
        services, governance, and delivery leadership.
      </p>
      <p class="page__intro p-note">
        Today, as organizations rush to adopt AI, I'm focused on a question I've
        been working on for most of my career: how do we structure information
        so people can understand it, organizations can operate it, and machines
        can use it responsibly?
      </p>
      <p class="page__intro p-note">
        Lately, I've been writing (and teaching) about <a
          href="https://makingpublicwork.com/">public mechanics</a
        >; back in March I organized <a href="https://yearsahead.io"
          >Years Ahead</a
        >. Currently: Head of Product Strategy for an EU-based civil AI concern,
        and part-time faculty in the Urban Technology program at the University
        of Michigan's Taubman College of Architecture and Urban Planning.
      </p>
      <p class="page__intro p-note">
        In my spare time, I coach high school tennis, host a <a
          href="https://www.mixcloud.com/908RB/">radio show</a
        >, and news anchor on community radio sometimes. My buddy Joel and I
        have an intermittent podcast about books, <a
          href="https://futureperfectbook.club">Future Perfect Book Club</a
        >.
      </p>
      <p class="page__intro p-note">
        The first game I designed was a sport. I invented <a
          href="https://en.wikipedia.org/wiki/Tennis_polo">Tennis Polo</a
        > in 2004 and it's since been played in eighteen-plus countries. These
        days, I build games of every kind, analog and digital. More of those
        experiments live at <a href="https://ronbronson.dev">ronbronson.dev</a>.
      </p>
      <p class="page__intro p-note">
        Previously: Head of Design at <a href="https://18f.org">18F</a>, and
        founder of the <a href="https://digitalcorpspdx.org"
          >Portland Digital Corps</a
        >.
      </p>

      <a
        class="np"
        href="https://listening.ronbronson.com"
        target="_blank"
        rel="noopener noreferrer"
        aria-live="polite"
        hidden
      >
        <img class="np__art" alt="" width="40" height="40" />
        <span class="np__text">
          <span class="np__label">Now playing</span>
          <span class="np__track"></span>
          <span class="np__artist"></span>
        </span>
      </a>
      <p class="page__more">
        <a href="/reading">Reading — books past &amp; present &rarr;</a>
      </p>

      {
        sections.map((section) => (
          <section class="sec">
            <h2 class="sec__h">
              <span class="sec__name">{section.title}</span>
            </h2>
            <ul class="sec__list">
              {section.items.map((it) => (
                <li class="sec__row">
                  {it.href && it.href !== "#" ? (
                    <a href={it.href} target="_blank" rel="noopener noreferrer">
                      {it.title}
                    </a>
                  ) : (
                    <span>{it.title}</span>
                  )}
                  {section.venue && it.where ? (
                    <span class="sec__where"> — {it.where}</span>
                  ) : null}
                </li>
              ))}
            </ul>
          </section>
        ))
      }

      {
        POSTS.length > 0 && (
          <section class="sec">
            <h2 class="sec__h">
              <span class="sec__name">Some Thoughts</span>
            </h2>
            <ul class="sec__list">
              {POSTS.map((post) => (
                <li class="sec__row">
                  <a href={post.url} target="_blank" rel="noopener noreferrer">
                    {post.title}
                  </a>
                  <span class="sec__where"> — {post.source}</span>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      <section class="sec">
        <h2 class="sec__h">
          <span class="sec__name">Elsewhere</span>
        </h2>
        <ul class="sec__icons">
          {
            ELSEWHERE.map((e) => {
              const isEmail = e.href.startsWith("mailto:");
              const linkClass = isEmail ? "icon-link u-email" : "icon-link u-url";
              const linkRel = isEmail ? "me" : "me noopener noreferrer";
              return (
                <li>
                  <a
                    class={linkClass}
                    href={e.href}
                    target={isEmail ? undefined : "_blank"}
                    rel={linkRel}
                    aria-label={e.label}
                    title={e.label}
                  >
                    <i class={e.icon} aria-hidden="true" />
                  </a>
                </li>
              );
            })
          }
        </ul>
      </section>

      <footer class="foot colophon">
        <p class="colophon__line">
          Say hello: <a class="u-email" href="mailto:ron@ronbronson.com" rel="me"
            >ron@ronbronson.com</a
          >
        </p>
        <p class="colophon__line">
          Last updated <time datetime="2026-06-08">8 June 2026</time>.
        </p>
        <p class="colophon__line">
          Built in Astro, HTML, CSS, JS and Font Awesome.
        </p>
        <p class="colophon__line">Fonts: Sentient and General Sans.</p>
      </footer>
    </main>

    <script>
      // Now playing — same last.fm source as listening.ronbronson.com
      (async () => {
        const el = document.querySelector<HTMLAnchorElement>(".np");
        if (!el) return;

        const user = "statechampion";
        const apiKey = "4f1d49f394a1567717e2c9049947d004";
        const url = `https://ws.audioscrobbler.com/2.0/?method=user.getrecenttracks&user=${user}&limit=1&api_key=${apiKey}&format=json`;

        try {
          const res = await fetch(url);
          if (!res.ok) return;
          const data = await res.json();

          const track = data?.recenttracks?.track?.[0];
          if (!track) return;

          const isNow = track["@attr"]?.nowplaying === "true";
          const name = track.name || "";
          const artist = track.artist?.["#text"] || track.artist?.name || "";
          const images = track.image || [];
          const art =
            images.find(
              (i: { size: string; "#text": string }) => i.size === "large",
            )?.["#text"] || "";

          const $art = el.querySelector<HTMLImageElement>(".np__art");
          const $label = el.querySelector<HTMLElement>(".np__label");
          const $track = el.querySelector<HTMLElement>(".np__track");
          const $artist = el.querySelector<HTMLElement>(".np__artist");

          if ($art && art) {
            $art.src = art;
            $art.alt = `${name} — ${artist}`;
          }
          if ($label) $label.textContent = isNow ? "Now playing" : "Last played";
          if ($track) $track.textContent = name;
          if ($artist) $artist.textContent = artist;

          el.classList.toggle("np--now", isNow);
          el.hidden = false;
        } catch {
          /* silent fail — widget stays hidden */
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  /* ─────────────────────────────────────────────────────────────
     TOKENS — neapolitan palette, WCAG verified on Navajo White #ffe0b5:
       #462521 Espresso     10.7 : 1   AAA   body ink
       #7a5847 Toffee dk      5.0 : 1   AA    meta / italic
       #ca2e55 Rosewood       4.1 : 1   —     strawberry accent (bold labels)
       #8a1f3a wine           7.1 : 1   AAA   link
       #462521 Espresso      10.7 : 1   AAA   visited
       #bdb246 Old Gold       —     selection wash
     Paper is warm vanilla cream; ink is espresso; accent is strawberry.
     ───────────────────────────────────────────────────────────── */
  :root {
    --paper: #ffe0b5;
    --ink: #462521;
    --ink-2: #7a5847;
    --ink-3: #8a6552;
    --oxblood: #ca2e55;
    --gold: #bdb246;
    --link: #8a1f3a;
    --link-vis: #462521;
    --link-hov: #5e1426;
    --hair: rgba(70, 37, 33, 0.2);
    --hair-2: rgba(70, 37, 33, 0.12);

    --serif: "Sentient", "Lyon Text", Georgia, "Times New Roman", serif;
    --sans: "General Sans", system-ui, -apple-system, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }
  html,
  body {
    margin: 0;
    padding: 0;
  }
  body {
    background: var(--paper);
    color: var(--ink);
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    font-feature-settings: "kern", "liga", "onum";
    font-optical-sizing: auto;
    hanging-punctuation: first last;
  }

  .page {
    max-width: 580px;
    margin: 0 auto;
    padding: 56px 28px 96px;
  }

  /* ───── Name + byline ───── */
  .page__hdr {
    margin: 0 0 28px;
  }
  .page__name {
    margin: 0;
    font-family: var(--serif);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(34px, 5.6vw, 44px);
    line-height: 1.02;
    letter-spacing: -0.015em;
    color: var(--ink);
  }
  .page__byline {
    margin: 8px 0 0;
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: 17px;
    line-height: 1.4;
    color: var(--ink-2);
    text-wrap: pretty;
  }

  /* ───── Intro paragraph ───── */
  .page__intro {
    margin: 0 0 28px;
    font-size: 18px;
    line-height: 1.6;
    color: var(--ink);
    text-wrap: pretty;
    max-width: 50ch;
  }

  /* ───── Now playing ───── */
  .np {
    display: inline-flex;
    align-items: center;
    gap: 11px;
    margin: 0 0 56px;
    padding: 7px 12px 7px 7px;
    max-width: 100%;
    border: 0.5px solid var(--hair);
    border-radius: 2px;
    background: rgba(70, 37, 33, 0.04);
    color: var(--ink);
    text-decoration: none;
    transition: border-color 120ms, background 120ms;
  }
  .np:visited {
    color: var(--ink);
  }
  .np:hover {
    border-color: var(--oxblood);
    background: rgba(202, 46, 85, 0.07);
  }
  .np__art {
    width: 40px;
    height: 40px;
    object-fit: cover;
    border-radius: 1px;
    background: var(--hair-2);
    flex-shrink: 0;
  }
  .np__text {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
    min-width: 0;
  }
  .np__label {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .np--now .np__label {
    color: var(--oxblood);
  }
  .np__track {
    font-style: italic;
    font-size: 16px;
    color: var(--ink);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .np__artist {
    font-size: 13px;
    color: var(--ink-2);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .page__more {
    margin: 0 0 56px;
    font-size: 18px;
    font-style: italic;
  }

  /* ───── Section ───── */
  .sec {
    margin: 0 0 44px;
  }

  .sec__h {
    margin: 0 0 14px;
    font-family: var(--sans);
    font-weight: 600;
    font-size: 13px;
    line-height: 1;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--oxblood);
    display: flex;
    align-items: baseline;
    padding-bottom: 10px;
    border-bottom: 0.5px solid var(--hair);
  }
  .sec__name {
    flex: 1;
  }

  .sec__list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .sec__row {
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.5;
    color: var(--ink);
    text-wrap: pretty;
    text-indent: 0;
  }
  .sec__where {
    color: var(--ink-2);
    font-style: italic;
  }

  /* Inline list — for the elsewhere row */
  .sec__list--inline {
    flex-direction: row;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0;
  }
  .sec__list--inline li {
    font-family: var(--serif);
    font-size: 17px;
  }
  .sec__sep {
    color: var(--ink-3);
    padding: 0 4px;
  }

  /* Icon row — for the elsewhere links */
  .sec__icons {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 18px;
  }
  .sec__icons li {
    display: flex;
  }
  .icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--ink-2);
    text-decoration: none;
    transition: color 120ms, transform 120ms;
  }
  .icon-link:visited {
    color: var(--ink-2);
  }
  .icon-link:hover {
    color: var(--oxblood);
    transform: translateY(-1px);
  }
  .icon-link:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 3px;
    border-radius: 2px;
  }
  .icon-link i {
    font-size: 20px;
    line-height: 1;
  }

  /* ───── Links ───── */
  a {
    color: var(--link);
    text-decoration: underline;
    text-decoration-thickness: 0.7px;
    text-underline-offset: 2.5px;
    text-decoration-color: rgba(138, 31, 58, 0.4);
    transition: color 120ms, text-decoration-color 120ms;
  }
  a:visited {
    color: var(--link-vis);
    text-decoration-color: rgba(70, 37, 33, 0.4);
  }
  a:hover {
    color: var(--link-hov);
    text-decoration-color: currentColor;
  }
  a:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 2px;
    border-radius: 1px;
  }

  /* ───── Colophon ───── */
  .foot {
    margin-top: 60px;
    padding-top: 18px;
    border-top: 0.5px solid var(--hair);
    font-family: var(--sans);
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--ink-2);
    text-align: left;
  }
  .colophon__line {
    margin: 0 0 4px;
  }
  .colophon__line:last-child {
    margin-bottom: 0;
  }
  .foot time {
    font-variant-numeric: tabular-nums;
  }

  ::selection {
    background: rgba(189, 178, 70, 0.4);
    color: var(--ink);
  }

  /* ─────────────────────────────────────────────────────────────
     Responsive
     ───────────────────────────────────────────────────────────── */
  @media (max-width: 560px) {
    .page {
      padding: 32px 22px 64px;
    }
    body {
      font-size: 16px;
    }
    .page__intro {
      font-size: 17px;
    }
    .sec__row,
    .sec__list--inline li {
      font-size: 16px;
    }
    .page__byline {
      font-size: 16px;
    }
  }

  @media (max-width: 380px) {
    .page {
      padding: 24px 16px 48px;
    }
  }

  @media print {
    body {
      background: white;
    }
    a {
      color: black;
    }
  }
</style>
