---
import Base from '../layouts/Base.astro';
import {
  ME, CURRENT_WORK, PAST_WORK,
  SPEAKING_2026, SPEAKING_PAST,
  HIGHLIGHTS_2026, HIGHLIGHTS_2025,
  WRITING, PODCASTS, HOSTING, ELSEWHERE,
} from '../data/frontdoor';

const SITE_URL = 'https://ronbronson.design';
const CANONICAL_URL = SITE_URL + '/';
const OG_IMAGE = new URL('/hero.jpg', SITE_URL).toString();

const cases = (items: typeof CURRENT_WORK) => items;
---

<Base title={ME.name} description={ME.role} noindex={false}>
  <Fragment slot="head">
    <link rel="canonical" href={CANONICAL_URL} />
    <meta property="og:type" content="profile" />
    <meta property="og:title" content={ME.name} />
    <meta property="og:description" content={ME.role} />
    <meta property="og:url" content={CANONICAL_URL} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={OG_IMAGE} />
  </Fragment>

  <main class="v2-page">
    <header class="v2-hdr">
      <h1 class="v2-name">{ME.name}</h1>
      <p class="v2-role">{ME.role}</p>
    </header>

    {/* ── Current work ── */}
    <section class="v2-block">
      <div class="v2-seclabel"><span>Current work</span></div>
      <div class="v2-cases">
        {cases(CURRENT_WORK).map((it) => (
          <article class="v2-case">
            <h3 class="v2-case__title">{it.title}</h3>
            {it.images && it.images.length > 0 && (
              <div class={`v2-case__media v2-case__media--${Math.min(it.images.length, 2)}`}>
                {it.images.map((img) => (
                  <figure class="v2-img" style="aspect-ratio: 3 / 2"><span class="v2-img__hint">{img.placeholder}</span></figure>
                ))}
              </div>
            )}
            <div class="v2-case__grid">
              <div class="v2-case__meta">
                <p class="v2-case__role"><strong>Role:</strong> {it.role}</p>
                {it.collab && <p class="v2-case__collab">{it.collab}</p>}
                {it.span && <p class="v2-case__span">{it.span}</p>}
              </div>
              <div class="v2-case__bodywrap">
                <p class="v2-case__body">{it.body}</p>
                {it.courses && (
                  <ul class="v2-courses">
                    {it.courses.map((c) => (
                      <li>
                        <span class="v2-courses__code">{c.code}</span>
                        <span class="v2-courses__title">{c.title}</span>
                        <span class="v2-courses__terms">{c.terms}</span>
                      </li>
                    ))}
                  </ul>
                )}
                {it.reading && (
                  <div class="v2-case__reading">
                    <span class="v2-case__reading-label">Further reading</span>
                    <ul>
                      {it.reading.map((r) => (
                        <li><a href={r.href} target="_blank" rel="noopener noreferrer">{r.label}</a></li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    {/* ── Speaking ── */}
    <section class="v2-block">
      <div class="v2-seclabel"><span>Speaking</span><span class="v2-seclabel__right">Booking 2026–2027 · keynotes, workshops, panels</span></div>
      <div class="v2-speak-wrap">
        <div class="v2-subhead">Upcoming · 2026</div>
        <ul class="v2-speaks">
          {SPEAKING_2026.map((it) => (
            <li class="v2-speak">
              <span class="v2-speak__date">{it.date}</span>
              <span class="v2-speak__body">
                {it.href && it.href !== '#' ? <a class="v2-speak__title" href={it.href} target="_blank" rel="noopener noreferrer">{it.title}</a> : <span class="v2-speak__title">{it.title}</span>}
                <span class="v2-speak__where"> — {it.where}</span>
              </span>
            </li>
          ))}
        </ul>
        <div class="v2-subhead v2-subhead--mt">Recent talks</div>
        <ul class="v2-speaks">
          {SPEAKING_PAST.map((it) => (
            <li class="v2-speak">
              <span class="v2-speak__date">{it.date}</span>
              <span class="v2-speak__body">
                {it.href && it.href !== '#' ? <a class="v2-speak__title" href={it.href} target="_blank" rel="noopener noreferrer">{it.title}</a> : <span class="v2-speak__title">{it.title}</span>}
                <span class="v2-speak__where"> — {it.where}</span>
              </span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    {/* ── Highlights ── */}
    <section class="v2-block">
      <div class="v2-seclabel"><span>Highlights</span><span class="v2-seclabel__right">2026</span></div>
      <h2 class="v2-bigh">Q1 / Q2 2026 Highlights</h2>
      <div class="v2-hlgrid">
        {HIGHLIGHTS_2026.map((it) => (
          <article class="v2-hl">
            <figure class="v2-hl__img" aria-hidden="true"><span class="v2-hl__imghint">{it.placeholder || 'Add image'}</span></figure>
            <div class="v2-hl__pad">
              <div class="v2-hl__month">{it.month}</div>
              <h3 class="v2-hl__title">{it.title}</h3>
              <p class="v2-hl__body">{it.body}</p>
            </div>
          </article>
        ))}
      </div>

      <button id="hl-toggle" class="v2-toggle" aria-expanded="true" aria-controls="hl-2025">
        <span class="v2-toggle__txt">Hide 2025 highlights</span>
        <span class="v2-toggle__chev" aria-hidden="true">▲</span>
      </button>

      <div id="hl-2025">
        <h2 class="v2-bigh v2-bigh--sub">2025 Highlights</h2>
        <div class="v2-hlgrid">
          {HIGHLIGHTS_2025.map((it) => (
            it.href ? (
              <a class="v2-hl v2-hl--linked" href={it.href} target="_blank" rel="noopener noreferrer">
                <figure class="v2-hl__img" aria-hidden="true"><span class="v2-hl__imghint">{it.placeholder}</span></figure>
                <div class="v2-hl__pad">
                  <div class="v2-hl__month">{it.month}</div>
                  <h3 class="v2-hl__title">{it.title}<span class="v2-hl__arrow" aria-hidden="true"> ↗</span></h3>
                  <p class="v2-hl__body">{it.body}</p>
                </div>
              </a>
            ) : (
              <article class="v2-hl">
                <figure class="v2-hl__img" aria-hidden="true"><span class="v2-hl__imghint">{it.placeholder}</span></figure>
                <div class="v2-hl__pad">
                  <div class="v2-hl__month">{it.month}</div>
                  <h3 class="v2-hl__title">{it.title}</h3>
                  <p class="v2-hl__body">{it.body}</p>
                </div>
              </article>
            )
          ))}
        </div>
      </div>
    </section>

    {/* ── Recent past work ── */}
    <section class="v2-block">
      <div class="v2-seclabel"><span>Recent past work</span></div>
      <div class="v2-cases">
        {cases(PAST_WORK).map((it) => (
          <article class="v2-case">
            <h3 class="v2-case__title">{it.title}</h3>
            {it.images && it.images.length > 0 && (
              <div class={`v2-case__media v2-case__media--${Math.min(it.images.length, 2)}`}>
                {it.images.map((img) => (
                  <figure class="v2-img" style="aspect-ratio: 3 / 2"><span class="v2-img__hint">{img.placeholder}</span></figure>
                ))}
              </div>
            )}
            <div class="v2-case__grid">
              <div class="v2-case__meta">
                <p class="v2-case__role"><strong>Role:</strong> {it.role}</p>
                {it.collab && <p class="v2-case__collab">{it.collab}</p>}
                {it.span && <p class="v2-case__span">{it.span}</p>}
              </div>
              <div class="v2-case__bodywrap">
                <p class="v2-case__body">{it.body}</p>
                {it.reading && (
                  <div class="v2-case__reading">
                    <span class="v2-case__reading-label">Further reading</span>
                    <ul>
                      {it.reading.map((r) => (
                        <li><a href={r.href} target="_blank" rel="noopener noreferrer">{r.label}</a></li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    {/* ── Writing / Podcasts ── */}
    <section class="v2-block">
      <div class="v2-twocol">
        <div>
          <div class="v2-seclabel"><span>Writing</span></div>
          <ul class="v2-pieces">
            {WRITING.map((it) => (
              <li class="v2-piece"><a class="v2-piece__title" href={it.href} target="_blank" rel="noopener noreferrer">{it.title}</a><span class="v2-piece__where"> — {it.where}</span></li>
            ))}
          </ul>
        </div>
        <div>
          <div class="v2-seclabel"><span>Podcasts &amp; interviews</span></div>
          <ul class="v2-pieces">
            {PODCASTS.map((it) => (
              <li class="v2-piece"><a class="v2-piece__title" href={it.href} target="_blank" rel="noopener noreferrer">{it.title}</a><span class="v2-piece__where"> — {it.where}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    {/* ── Hosting ── */}
    <section class="v2-block">
      <div class="v2-seclabel"><span>Hosting</span></div>
      <ul class="v2-pieces">
        {HOSTING.map((it) => (
          <li class="v2-piece"><a class="v2-piece__title" href={it.href} target="_blank" rel="noopener noreferrer">{it.title}</a><span class="v2-piece__where"> — {it.where}</span></li>
        ))}
      </ul>
    </section>

    {/* ── Footer ── */}
    <footer class="v2-foot">
      <div class="v2-foot__grid">
        <div>
          <div class="v2-subhead">Contact</div>
          <p class="v2-foot__line">Write a message <a href={`mailto:${ME.email}`}>via email</a></p>
          <p class="v2-foot__hint">A short note describing the situation, the constraint, and what a useful next step looks like will receive a faster, better reply than a calendar invitation.</p>
        </div>
        <div>
          <div class="v2-subhead">Elsewhere</div>
          <ul class="v2-foot__list">
            {ELSEWHERE.map((e) => (
              <li><a href={e.href} target="_blank" rel="noopener noreferrer">{e.label}</a></li>
            ))}
          </ul>
        </div>
      </div>
      <div class="v2-foot__updated">Last updated <time datetime="2026-05-26">May 2026</time>.</div>
    </footer>
  </main>
</Base>

<style is:global>
  /* 2026 Site v2 — ported layout, recolored bright + atypical accents */
  .v2-page { max-width: 1180px; margin: 0 auto; padding: 64px 48px 96px; }

  .v2-hdr { margin-bottom: 96px; }
  .v2-name {
    margin: 0; font-family: var(--sans); font-weight: 800;
    font-size: clamp(64px, 11vw, 152px); line-height: 0.92;
    letter-spacing: -0.045em; color: var(--ink);
  }
  .v2-role {
    margin: 28px 0 0; font-size: clamp(20px, 2vw, 26px); line-height: 1.35;
    color: var(--ink); max-width: 30ch; font-weight: 500;
    letter-spacing: -0.018em; text-wrap: balance;
  }

  .v2-block { margin-top: 96px; }
  .v2-seclabel {
    font-family: var(--sans); font-size: 12px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink);
    display: flex; justify-content: space-between; align-items: baseline;
    margin: 0 0 36px; padding-bottom: 12px;
    border-bottom: 2px solid var(--accent);
  }
  .v2-seclabel__right {
    font-weight: 500; letter-spacing: 0.04em; color: var(--accent-2);
    text-transform: none; font-size: 13px;
  }
  .v2-subhead {
    font-family: var(--sans); font-size: 12px; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-3);
    margin-bottom: 14px;
  }
  .v2-subhead--mt { margin-top: 40px; }

  .v2-cases { display: flex; flex-direction: column; gap: 96px; }
  .v2-case__title {
    margin: 0 0 32px; font-family: var(--sans); font-weight: 700;
    font-size: clamp(28px, 4vw, 48px); line-height: 1.05;
    letter-spacing: -0.028em; color: var(--ink); max-width: 22ch; text-wrap: balance;
  }
  .v2-case__media { display: grid; gap: 12px; margin-bottom: 28px; }
  .v2-case__media--1 { grid-template-columns: 1fr; }
  .v2-case__media--2 { grid-template-columns: 1fr 1fr; }
  .v2-case__grid { display: grid; grid-template-columns: 280px 1fr; gap: 56px; align-items: start; }
  .v2-case__meta { font-size: 15px; line-height: 1.5; color: var(--ink-3); }
  .v2-case__meta p { margin: 0 0 4px; }
  .v2-case__meta strong { color: var(--ink); font-weight: 600; }
  .v2-case__collab { font-style: italic; }
  .v2-case__span { font-family: var(--mono); font-size: 12px; letter-spacing: 0.04em; color: var(--ink-3); margin-top: 8px !important; }
  .v2-case__body { margin: 0; font-size: clamp(17px, 1.4vw, 19px); line-height: 1.55; color: var(--ink); max-width: 62ch; text-wrap: pretty; letter-spacing: -0.008em; }

  .v2-courses { margin: 28px 0 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 8px; max-width: 56ch; }
  .v2-courses li { display: grid; grid-template-columns: 72px 1fr auto; gap: 16px; padding: 10px 0; border-top: 1px solid var(--hair); font-size: 15px; align-items: baseline; }
  .v2-courses li:last-child { border-bottom: 1px solid var(--hair); }
  .v2-courses__code { font-family: var(--mono); font-size: 12.5px; font-weight: 500; letter-spacing: 0.04em; color: var(--accent-2); }
  .v2-courses__title { color: var(--ink); }
  .v2-courses__terms { font-family: var(--mono); font-size: 12.5px; color: var(--ink-3); letter-spacing: 0.04em; }

  .v2-case__reading { margin-top: 28px; }
  .v2-case__reading-label { display: block; font-family: var(--sans); font-size: 11.5px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-3); margin-bottom: 8px; }
  .v2-case__reading ul { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 4px; font-size: 16px; }

  .v2-img {
    margin: 0;
    background: repeating-linear-gradient(135deg, var(--bg-card) 0, var(--bg-card) 12px, color-mix(in srgb, var(--bg-card), var(--hair) 60%) 12px, color-mix(in srgb, var(--bg-card), var(--hair) 60%) 13px);
    border: 1px solid var(--hair); display: flex; align-items: center; justify-content: center; text-align: center; padding: 12px;
  }
  .v2-img__hint { font-family: var(--mono); font-size: 11.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-3); background: var(--bg); padding: 4px 10px; }

  .v2-speak-wrap { display: flex; flex-direction: column; }
  .v2-speaks { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; }
  .v2-speak { display: grid; grid-template-columns: 140px 1fr; gap: 28px; padding: 14px 0; border-top: 1px solid var(--hair); align-items: baseline; }
  .v2-speaks li:last-child { border-bottom: 1px solid var(--hair); }
  .v2-speak__date { font-family: var(--mono); font-size: 12.5px; letter-spacing: 0.04em; color: var(--accent-2); font-variant-numeric: tabular-nums; }
  .v2-speak__title { font-family: var(--sans); font-size: 19px; font-weight: 500; letter-spacing: -0.015em; color: var(--ink); }
  .v2-speak__where { color: var(--ink-3); font-size: 16px; }

  .v2-bigh { margin: 0 0 36px; font-family: var(--sans); font-weight: 800; font-size: clamp(36px, 5vw, 56px); line-height: 1.0; letter-spacing: -0.028em; color: var(--ink); }
  .v2-bigh--sub { margin-top: 56px; }
  .v2-hlgrid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
  .v2-hl { background: var(--bg-card); border: 1px solid var(--hair); border-radius: 4px; overflow: hidden; display: flex; flex-direction: column; border-top: 4px solid var(--accent); transition: border-color 160ms, transform 160ms; }
  .v2-hlgrid .v2-hl:nth-child(4n+2) { border-top-color: var(--accent-2); }
  .v2-hlgrid .v2-hl:nth-child(4n+3) { border-top-color: var(--accent-3); }
  .v2-hlgrid .v2-hl:nth-child(4n+4) { border-top-color: var(--accent-4); }
  .v2-hl--linked { color: inherit; text-decoration: none; cursor: pointer; }
  .v2-hl--linked:hover { transform: translateY(-3px); }
  .v2-hl__img { margin: 0; aspect-ratio: 4 / 3; background: repeating-linear-gradient(135deg, var(--bg-card) 0, var(--bg-card) 12px, color-mix(in srgb, var(--bg-card), var(--hair) 60%) 12px, color-mix(in srgb, var(--bg-card), var(--hair) 60%) 13px); border-bottom: 1px solid var(--hair); display: flex; align-items: center; justify-content: center; padding: 12px; }
  .v2-hl__imghint { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-3); background: var(--bg); padding: 3px 8px; }
  .v2-hl__pad { padding: 18px 20px 22px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .v2-hl__month { font-family: var(--mono); font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); font-variant-numeric: tabular-nums; }
  .v2-hl__title { margin: 0; font-family: var(--sans); font-size: 21px; font-weight: 600; line-height: 1.18; letter-spacing: -0.018em; color: var(--ink); }
  .v2-hl__arrow { font-weight: 400; color: var(--ink-3); }
  .v2-hl__body { margin: 4px 0 0; font-size: 15px; line-height: 1.5; color: var(--ink-2); text-wrap: pretty; }

  .v2-toggle { margin: 40px 0 0; font: inherit; font-family: var(--sans); font-size: 14px; font-weight: 500; padding: 10px 16px; background: var(--bg-card); border: 1px solid var(--hair); border-radius: 4px; color: var(--ink); cursor: pointer; display: inline-flex; align-items: center; gap: 10px; transition: border-color 120ms, background 120ms; }
  .v2-toggle:hover { border-color: var(--accent); }
  .v2-toggle__chev { font-size: 9px; color: var(--accent); }
  #hl-2025.is-hidden { display: none; }

  .v2-twocol { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; }
  .v2-pieces { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; }
  .v2-piece { padding: 12px 0; border-top: 1px solid var(--hair); font-size: 17px; line-height: 1.4; }
  .v2-pieces li:last-child { border-bottom: 1px solid var(--hair); }
  .v2-piece__title { font-family: var(--sans); font-weight: 500; letter-spacing: -0.015em; }
  .v2-piece__where { color: var(--ink-3); font-size: 15px; }

  .v2-foot { margin-top: 120px; padding-top: 36px; border-top: 2px solid var(--accent); }
  .v2-foot__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; }
  .v2-foot__line { margin: 0 0 12px; font-size: 28px; font-weight: 500; letter-spacing: -0.022em; color: var(--ink); line-height: 1.2; }
  .v2-foot__hint { margin: 8px 0 0; font-size: 14.5px; line-height: 1.55; color: var(--ink-3); max-width: 50ch; }
  .v2-foot__list { margin: 0; padding: 0; list-style: none; display: flex; flex-wrap: wrap; gap: 6px 18px; font-size: 17px; }
  .v2-foot__updated { margin-top: 56px; padding-top: 18px; border-top: 1px solid var(--hair); font-family: var(--mono); font-size: 11.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-3); }

  @media (max-width: 960px) {
    .v2-page { padding: 48px 28px 80px; }
    .v2-hdr { margin-bottom: 64px; }
    .v2-block { margin-top: 72px; }
    .v2-case__grid { grid-template-columns: 1fr; gap: 24px; }
    .v2-hlgrid { grid-template-columns: 1fr 1fr; }
    .v2-twocol { grid-template-columns: 1fr; gap: 48px; }
    .v2-foot__grid { grid-template-columns: 1fr; gap: 36px; }
  }
  @media (max-width: 640px) {
    .v2-page { padding: 32px 20px 64px; }
    .v2-name { font-size: clamp(46px, 14vw, 80px); }
    .v2-role { font-size: 18px; }
    .v2-case__media--2 { grid-template-columns: 1fr; }
    .v2-hlgrid { grid-template-columns: 1fr; }
    .v2-speak { grid-template-columns: 1fr; gap: 4px; }
    .v2-courses li { grid-template-columns: 60px 1fr; }
    .v2-courses__terms { grid-column: 2; }
    .v2-foot__line { font-size: 22px; }
  }
  @media print {
    .v2-img, .v2-hl__img { display: none; }
  }
</style>

<script>
  const btn = document.getElementById('hl-toggle');
  const panel = document.getElementById('hl-2025');
  const txt = btn?.querySelector('.v2-toggle__txt');
  const chev = btn?.querySelector('.v2-toggle__chev');
  btn?.addEventListener('click', () => {
    const hidden = panel?.classList.toggle('is-hidden');
    if (btn) btn.setAttribute('aria-expanded', String(!hidden));
    if (txt) txt.textContent = hidden ? 'Show 2025 highlights' : 'Hide 2025 highlights';
    if (chev) chev.textContent = hidden ? '▼' : '▲';
  });
</script>
