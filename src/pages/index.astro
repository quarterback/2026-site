---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import HeroCard from '../components/HeroCard.astro';
import FeatureCard from '../components/FeatureCard.astro';
import Writing from '../components/Writing.astro';
import WritingExcerpt from '../components/WritingExcerpt.astro';
import Books from '../components/Books.astro';
import Albums from '../components/Albums.astro';
import MediaCard from '../components/MediaCard.astro';
import Footer from '../components/Footer.astro';
import { fetchMultipleRSS } from '../lib/rss';

// Top 3 featured projects — BuzzFeed-style hero cards
const heroCards = [
  {
    title: "Solving Dating with a Fantasy Draft",
    description: "Swiping is a social disaster. My fix? I replaced the infinite swipe with a 15-pick weekly draft.",
    image: "/img/heypbj.xyz.png",
    href: "/work/heypbj-matching-platform",
    label: "Platform",
  },
  {
    title: "Pricing the AI Futures Market",
    description: "Compute is the new crude. I built the index to track it. From Civic CPI to reasoning models, I engineered the metrics that turn \u201Cblack-box\u201D AI spend into tradable data.",
    image: "/img/occupant.png",
    href: "/work/occupant-ai-benchmarks",
    label: "Product",
  },
  {
    title: "Engineering portable trust",
    description: "Bad actors thrive in silos. I engineered a decentralize clearinghouse that makes niche apps scalable by creating a cross-platform trust layer.",
    image: "/img/glowrm.png",
    href: "/work/glowrm-trust-layer",
    label: "Infrastructure",
  },
{
  title: "Making Open Licensing Legible",
  description: "Most people open source licenses without understanding. I built a modular license framework that scales with projects.",
  image: "/img/parachute-commons.png",
  href: "/work/parachute-commons-license",
  label: "Infrastructure",
},
];

// Culled case studies — only the most relevant work
const caseStudies = [
  {
    tier: 2 as const,
    title: "18F - Design Leadership at Scale",
    narrative: "Service delivery & deployment in support of millions of Americans.",
    image: "/img/18f-leadership.svg",
    href: "/work/18f-leadership",
  },
  {
    tier: 2 as const,
    title: "Portland Digital Corps",
    narrative: "Volunteer effort bringing together 50+ practitioners to rebuild six nonprofit websites.",
    image: "/img/digitalcorpspdx.org.png",
    href: "/work/portland-digital-corps",
  },
  {
    tier: 2 as const,
    title: "Design For The Public 24",
    narrative: "Two-day unconference bringing together 80+ civic technologists and designers in Portland.",
    href: "/work/design-for-the-public-24",
  },
];

const writingExcerpts = [
  {
    quote: "Most people think design is about making things beautiful. But the real work of design is repair—patching the gaps between intention and reality, between policy and the lived experience of the people who depend on public systems.",
    title: "Design as Repair",
    href: "https://blog.ronbronson.com/design-as-repair",
    label: "Essay",
  },
  {
    quote: "The question isn't whether AI agents will make decisions. They already do. The question is who holds the pen when those decisions go wrong—and whether the systems we build have a manager, not just a manual.",
    title: "Who Holds the Pen?",
    href: "https://makingpublicwork.com/who-holds-the-pen-why-ai-agents-need-a-manager-not-just-a-manual/",
    label: "Analysis",
  },
];

const rssFeeds = [
  'https://makingpublicwork.com/rss/',
  'https://blog.ronbronson.com/feed.rss',
];

let recentPosts: any[] = [];
try {
  const allPosts = await fetchMultipleRSS(rssFeeds);
  recentPosts = allPosts.slice(0, 5);
} catch (error) {
  console.error('Failed to fetch RSS feeds:', error);
  recentPosts = [];
}

const currentBooks = [
  {
    title: "Waging A Good War",
    author: "Thomas E. Ricks",
  },
  {
    title: "Maintenance of Everything: Part One",
    author: "Stewart Brand",
  },
  {
    title: "Religion And The Decline of Magic",
    author: "Keith Thomas",
  },
  {
    title: "The Field Guide to Design Futures",
    author: "Giovanni Caruso, Silvio Cioni",
  },
];

const currentAlbums = [
  {
    title: "Sunshine and Balance Beams",
    artist: "Pile",
  },
  {
    title: "Ripped and Torn",
    artist: "Lifeguard Radio",
  },
  {
    title: "DDR",
    artist: "Sharp Pins",
  },
];

const recentMedia = [
  {
    title: "Future Perfect Book Club",
    source: "futureperfectbook.club",
    description: "Co-hosted with Joel Goodman, exploring the intersection of design, technology, and the future of institutions.",
    mediaType: "podcast" as const,
    url: "https://futureperfectbook.club",
    date: "2025",
  },
  {
    title: "Some advice on managing your design career upwards",
    source: "Piccalil.li",
    description: "Navigating design leadership, building influence across organizations, and positioning yourself for strategic impact.",
    mediaType: "article" as const,
    url: "https://piccalil.li/blog/some-advice-on-managing-your-design-career-upwards/",
    image: "/img/piccalil.li.png",
    date: "January 2026",
  },
  {
    title: "Beyond Civic Tech: Public Mechanics Starts at Home",
    source: "Cascadia Open Source Fall Conference",
    description: "Why civic tech fails when it ignores maintenance, repair, and the invisible work that keeps public services running.",
    mediaType: "talk" as const,
    embedUrl: "https://youtube.com/watch?v=hnAScuK-oMo",
    date: "November 2025",
  },
  {
    title: "Repairing Service Design for the Age of AI",
    source: "Service Design Show Podcast",
    description: "Exploring how service design must evolve to address the challenges and opportunities of AI-driven systems.",
    mediaType: "podcast" as const,
    url: "https://podcasts.apple.com/br/podcast/repairing-service-design-for-the-age-of-ai-ron-bronson-ep-236/id1104665758?i=1000726081505",
    date: "September 2025",
  },
  {
    title: "Design Systems and Public Services",
    source: "YouTube",
    description: "Discussion on service design, public sector innovation, and building decision systems that work at scale.",
    mediaType: "video" as const,
    embedUrl: "https://www.youtube.com/watch?v=kL0gYtoUtvI",
    date: "October 2025",
  },
];

const socials = [
  { name: "Bluesky", url: "https://bsky.app/profile/ronbronson.com" },
  { name: "LinkedIn", url: "https://linkedin.com/in/ronbronson" },
  { name: "GitHub", url: "https://github.com/ronbronson" },
];

const techStack = [
  "built hastily using Astro, Open Props, FontAwesome, TypeScript, Inter, JetBrains Mono, Netlify & GitHub"
];

const fonts: string[] = [];
---

<Base title="Ron Bronson">
  <main>
    <Hero
      taxonomyTerms={["AI", "Service Design", "Civic Tech", "Strategy", "Digital Transformation"]}
      taxonomyResult="[Trusted Advisor]"
      subheadline="I build and stabilize the systems that run public life. My work helps leaders & tech teams navigate the gap between high-level policy and the reality of delivery."
      primaryCTA={{ label: "About me", url: "/about", icon: "fa-user" }}
      secondaryCTA={{ label: "Phone a friend", url: "/phone-a-friend", icon: "fa-phone" }}
    />

    <!-- Currently — AIM style status -->
    <section class="currently-section">
      <div class="container">
        <div class="currently-content">
          <p class="label">Currently</p>
          <p class="currently-status">Assistant Professor of Practice in Urban Technology at the University of Michigan Taubman College. Organizing <a href="https://yearsahead.io">Yearsahead.io</a>. Building frameworks for Agent Experience (AX) and decision engineering at <a href="https://statecapacity.ai">State Capacity AI</a>. Probably retiring from pro skeeball.</p>
        </div>
      </div>
    </section>

    <!-- Featured Projects — BuzzFeed-style hero cards -->
    <section id="featured-projects">
      <div class="container">
        <h2 class="section-heading">Frameworks in Action</h2>
        <div class="hero-cards-stack">
          {heroCards.map(card => (
            <HeroCard
              title={card.title}
              description={card.description}
              image={card.image}
              href={card.href}
              label={card.label}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Excerpt interstitial slot 1 -->
    <div class="excerpt-slot" data-excerpt-slot>
      <div class="container">
        {writingExcerpts.map((excerpt, i) => (
          <div data-excerpt={i} hidden>
            <WritingExcerpt
              quote={excerpt.quote}
              title={excerpt.title}
              href={excerpt.href}
              label={excerpt.label}
            />
          </div>
        ))}
      </div>
    </div>

    <!-- Case Studies — culled to most relevant work -->
    <section id="work">
      <div class="container">
        <h2 class="section-heading">Selected Work</h2>
        <div class="case-studies-grid">
          {caseStudies.map(card => (
            <FeatureCard
              title={card.title}
              narrative={card.narrative}
              image={card.image}
              href={card.href}
              tier={card.tier}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Excerpt interstitial slot 2 -->
    <div class="excerpt-slot" data-excerpt-slot>
      <div class="container">
        {writingExcerpts.map((excerpt, i) => (
          <div data-excerpt={i} hidden>
            <WritingExcerpt
              quote={excerpt.quote}
              title={excerpt.title}
              href={excerpt.href}
              label={excerpt.label}
            />
          </div>
        ))}
      </div>
    </div>

    <!-- Recent Appearances -->
    <section id="media">
      <div class="container">
        <h2 class="section-heading">Recent Appearances</h2>
        <div class="media-list-featured">
          {recentMedia.map(item => (
            <MediaCard {...item} />
          ))}
        </div>
      </div>
    </section>

    <!-- Media Consumption: Books & Albums -->
    <section id="media-consumption">
      <div class="container">
        <div class="media-grid">
          <Books books={currentBooks} />
          <Albums albums={currentAlbums} />
        </div>
      </div>
    </section>
  </main>

  <Footer
    techStack={techStack}
    fonts={fonts}
  />
</Base>

<style>
  /* Hero cards stack — full-width cards stacked vertically */
  #featured-projects {
    padding-block: var(--size-6);
  }

  .hero-cards-stack {
    display: flex;
    flex-direction: column;
    gap: var(--size-5);
  }

  /* Excerpt interstitial slots */
  .excerpt-slot {
    padding-block: var(--size-3);
  }

  /* Section headings */
  .section-heading {
    font-size: clamp(var(--font-size-2), 4vw, var(--font-size-3));
    margin-bottom: var(--size-4);
    font-family: var(--font-mono);
    font-weight: var(--font-weight-6);
  }

  /* Case Studies grid — 3 columns */
  .case-studies-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--size-5);
  }

  @media (max-width: 900px) {
    .case-studies-grid {
      grid-template-columns: 1fr;
      gap: var(--size-4);
    }
  }

  @media (max-width: 600px) {
    .case-studies-grid {
      gap: var(--size-3);
    }
  }

  /* Recent Appearances section */
  #media {
    background: var(--surface-1);
    padding: var(--size-6) 0;
    margin: var(--size-6) 0;
  }

  /* Featured Media List */
  .media-list-featured {
    display: flex;
    flex-direction: column;
    gap: var(--size-4);
  }

  /* Currently section — AIM style status */
  .currently-section {
    background: var(--surface-2);
    border-left: 4px solid var(--brand);
    margin-bottom: var(--size-5);
  }

  .currently-content {
    padding: var(--size-4);
  }

  .currently-content .label {
    margin-bottom: var(--size-2);
  }

  .currently-status {
    font-size: var(--font-size-1);
    color: var(--text-1);
    max-width: 70ch;
    line-height: 1.6;
    margin: 0;
  }

  .currently-status a {
    color: var(--text-1);
    text-decoration-color: var(--brand);
    text-underline-offset: 2px;
  }

  .currently-status a:hover {
    color: var(--brand);
  }

  /* Media section - Books & Albums side by side */
  #media-consumption {
    margin-bottom: var(--size-5);
  }

  .media-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--size-6);
  }

  @media (max-width: 768px) {
    .media-grid {
      grid-template-columns: 1fr;
      gap: var(--size-5);
    }
  }

  @media (max-width: 600px) {
    .section-heading {
      margin-bottom: var(--size-3);
    }

    .hero-cards-stack {
      gap: var(--size-4);
    }

    #featured-projects {
      padding-block: var(--size-4);
    }
  }
</style>

<script is:inline>
  (function () {
    var slots = document.querySelectorAll('[data-excerpt-slot]');
    if (!slots.length) return;
    var total = slots[0].querySelectorAll('[data-excerpt]').length;
    if (!total) return;
    // Build shuffled index array
    var indices = [];
    for (var i = 0; i < total; i++) indices.push(i);
    for (var i = indices.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = indices[i]; indices[i] = indices[j]; indices[j] = tmp;
    }
    // Reveal one unique excerpt per slot
    slots.forEach(function (slot, si) {
      var idx = indices[si % indices.length];
      var el = slot.querySelector('[data-excerpt="' + idx + '"]');
      if (el) el.hidden = false;
    });
  })();
</script>
