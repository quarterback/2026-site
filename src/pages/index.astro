const sections = [
  { title: "Writing", items: WRITING, venue: true },
  { title: "Interviews", items: INTERVIEWS, venue: true },
  { title: "Teaching", items: TEACHING, venue: true },
  { title: "Host", items: HOST, venue: false },
  { title: "Talks", items: TALKS, venue: true },
