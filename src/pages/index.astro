---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import WritingStream from '../components/WritingStream.astro';
import { getHomepageStream } from '../lib/stream';

const stream = await getHomepageStream(12);
---

<Base title="Ron Bronson">
  <main id="main">

    <!-- HERO -->
    <section class="hero" aria-labelledby="hero-heading">
      <div class="container hero-inner">
        <div class="hero-avatar">
          <img src="/ron-bronson.jpg" alt="Ron Bronson" width="140" height="140" />
        </div>

        <div class="hero-text">
          <h1 id="hero-heading" class="hero-headline">
            I build and fix<br>the systems that<br>run <em>public life.</em>
          </h1>

          <div class="hero-bio">
            <p>Hi, I&rsquo;m Ron Bronson. I work in deployment and interaction policy, helping large institutions ship tech and AI &mdash; moving pilots into products, policies into working systems, and stalled programs back on track.</p>
            <p>I run <a href="https://www.occupant.works/" target="_blank" rel="noopener">Occupant</a> (independent advisory for state and local government) and <a href="https://statecapacity.ai" target="_blank" rel="noopener">State Capacity AI</a> (decision infrastructure for institutional AI), write the <a href="https://makingpublicwork.com" target="_blank" rel="noopener">Making Public Work</a> newsletter, and teach at the <a href="/about">University of Michigan</a>.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- HOW CAN I HELP? -->
    <section class="help" aria-labelledby="help-heading">
      <div class="container">
        <h2 id="help-heading" class="help-heading">How can I help?</h2>

        <div class="service-cards">
          <article class="service-card">
            <h3 class="service-title">
              <span class="service-arrow" aria-hidden="true">&rarr;</span>
              Senior advisory for public-sector tech &amp; AI
            </h3>
            <p class="service-body">
              I work with state, local, and federal institutions on deploying AI responsibly, stabilizing programs that have stalled, and building decision infrastructure that makes procurement and delivery tractable.
            </p>
            <a href="/work" class="service-cta">More about my work &rarr;</a>
          </article>

          <article class="service-card">
            <h3 class="service-title">
              <span class="service-arrow" aria-hidden="true">&rarr;</span>
              Writing, speaking, and teaching
            </h3>
            <p class="service-body">
              I publish Making Public Work, a newsletter on public-sector technology, teach at the University of Michigan, and speak with leadership teams about AI and institutional capacity.
            </p>
            <a href="/media" class="service-cta">More about speaking &rarr;</a>
          </article>
        </div>
      </div>
    </section>

    <!-- LATEST POSTS -->
    <section class="posts" aria-labelledby="posts-heading">
      <div class="container">
        <h2 id="posts-heading" class="posts-heading">Latest Posts</h2>

        <WritingStream items={stream} />

        <div class="posts-more">
          <a href="/notes">All notes &rarr;</a>
          <a href="/essays">All essays &rarr;</a>
          <a href="https://makingpublicwork.com" target="_blank" rel="noopener">Newsletter &#8599;</a>
          <a href="https://blog.ronbronson.com" target="_blank" rel="noopener">Blog &#8599;</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Base>

<style>
  /* ===== HERO ===== */
  .hero {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: clamp(3rem, 8vh, 5rem) var(--pad) clamp(3rem, 6vh, 4rem);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(1.5rem, 3vw, 2.5rem);
    align-items: start;
  }

  .hero-avatar {
    width: clamp(96px, 12vw, 140px);
    height: clamp(96px, 12vw, 140px);
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--border);
    flex-shrink: 0;
  }

  .hero-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-text {
    min-width: 0;
  }

  .hero-headline {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4.5vw, 3.4rem);
    font-weight: 900;
    line-height: 1.06;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 1.5rem;
  }

  .hero-headline :global(em) {
    font-style: italic;
    font-weight: 400;
    color: var(--accent);
  }

  .hero-bio {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.4vw, 1.1rem);
    font-weight: 300;
    line-height: 1.7;
    color: var(--ink-mid);
    max-width: 64ch;
  }

  .hero-bio p {
    margin: 0 0 1rem;
  }

  .hero-bio p:last-child {
    margin-bottom: 0;
  }

  .hero-bio a {
    color: var(--ink);
    font-weight: 500;
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 2px;
    transition: color 0.15s;
  }

  .hero-bio a:hover {
    color: var(--accent);
  }

  /* ===== HOW CAN I HELP? ===== */
  .help {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: clamp(3rem, 7vh, 5rem) var(--pad);
    border-top: 1px solid var(--rule);
  }

  .help-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin: 0 0 2.5rem;
  }

  .service-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    background: var(--bg);
    border: 1px solid var(--border);
    padding: clamp(1.5rem, 3vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    transition: background 0.15s, border-color 0.15s;
  }

  .service-card:hover {
    background: var(--bg-warm);
    border-color: var(--ink-faint);
  }

  .service-title {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--ink);
    margin: 0;
  }

  .service-arrow {
    color: var(--accent);
    font-weight: 400;
    margin-right: 0.35rem;
  }

  .service-body {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.65;
    color: var(--ink-mid);
    margin: 0;
    flex: 1;
  }

  .service-cta {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
    margin-top: 0.4rem;
    align-self: flex-start;
    transition: color 0.15s;
  }

  .service-cta:hover {
    color: var(--brand-dim);
  }

  /* ===== LATEST POSTS ===== */
  .posts {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: clamp(3rem, 7vh, 5rem) var(--pad);
    border-top: 1px solid var(--rule);
  }

  .posts-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin: 0 0 2rem;
  }

  .posts-more {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2rem;
    margin-top: 2rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .posts-more a {
    color: var(--ink-mid);
    text-decoration: none;
    transition: color 0.15s;
  }

  .posts-more a:hover {
    color: var(--accent);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }

    .service-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
