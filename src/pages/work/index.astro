---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import WorkCard from '../../components/WorkCard.astro';
import Footer from '../../components/Footer.astro';

const allWork = await getCollection('work', ({ data }) => !data.draft);
const work = allWork.sort((a, b) => a.data.order - b.data.order);

const techStack = [
  "built hastily using Astro, Open Props, FontAwesome, TypeScript, Inter, JetBrains Mono, Netlify & GitHub"
];
---

<Base title="Work — Ron Bronson">
  <main id="main">
    <header class="page-head">
      <p class="kicker">Archive</p>
      <h1 class="page-head__title">Work</h1>
      <p class="page-head__lede">A complete archive of projects, prototypes, and community initiatives — federal programs, civic technology, municipal services, and public-sector innovation.</p>
    </header>

    <section>
      <div class="container">
        <div class="work-grid">
          {work.map(item => (
            <WorkCard
              title={item.data.title}
              type={item.data.type}
              lede={item.data.lede}
              metadata={item.data.metadata}
              href={`/work/${item.slug}`}
              featured={false}
            />
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer
    techStack={techStack}
    fonts={[]}
  />
</Base>

<style>
  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--size-4);
    padding-block: clamp(2rem, 5vw, 3rem);
  }

  @media (max-width: 900px) {
    .work-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .work-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
