---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Webmentions from '../../components/Webmentions.astro';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(note.data.date);

const canonical = new URL(`/notes/${note.slug}`, Astro.site ?? 'https://ronbronson.com').toString();
const pageTitle = note.data.title ? `${note.data.title} — Ron Bronson` : 'Notes — Ron Bronson';
---

<Base title={pageTitle}>
  <main id="main">
    <article class="h-entry now-entry">
      <header class="now-entry__header">
        <p class="now-entry__kicker">
          <a href="/notes">Notes</a>
        </p>

        <a class="u-url" href={canonical}>
          <time class="dt-published now-entry__date" datetime={note.data.date.toISOString()}>
            {formattedDate}
          </time>
        </a>

        {note.data.title && (
          <h1 class="p-name now-entry__title">{note.data.title}</h1>
        )}

        {note.data.reply_to && (
          <p class="now-entry__reply-to">
            In reply to
            <a class="u-in-reply-to" href={note.data.reply_to}>
              {note.data.reply_to}
            </a>
          </p>
        )}

        <a class="p-author h-card now-entry__author" href="https://ronbronson.com/" rel="author">
          Ron Bronson
        </a>
      </header>

      {note.data.image && (
        <figure class="now-entry__figure">
          <img
            src={note.data.image}
            alt={note.data.image_alt ?? ''}
            class="now-entry__image"
          />
        </figure>
      )}

      <div class="e-content now-entry__body">
        <Content />
      </div>

      {note.data.tags.length > 0 && (
        <ul class="now-entry__tags">
          {note.data.tags.map((tag) => (
            <li><span class="p-category">#{tag}</span></li>
          ))}
        </ul>
      )}
    </article>

    <Webmentions url={`/notes/${note.slug}/`} />
  </main>
</Base>

<style>
  .now-entry {
    max-width: var(--measure-narrow);
    margin-inline: auto;
    padding-block: var(--size-10);
    padding-inline: var(--pad);
  }

  .now-entry__header {
    margin-block-end: var(--size-6);
  }

  .now-entry__kicker {
    font-family: var(--font-mono);
    font-size: 0.63rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin: 0 0 var(--size-3);
  }

  .now-entry__kicker a {
    color: inherit;
    text-decoration: none;
  }

  .now-entry__kicker a:hover {
    color: var(--accent);
  }

  .now-entry__date {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-mid);
    margin-block-end: var(--size-3);
  }

  .now-entry__title {
    font-family: var(--font-serif);
    font-size: var(--font-size-h1);
    line-height: var(--line-height-h1);
    letter-spacing: -0.02em;
    margin: 0 0 var(--size-3);
  }

  .now-entry__reply-to {
    font-size: 0.9rem;
    color: var(--ink-mid);
    margin-block: var(--size-3);
  }

  .now-entry__reply-to a {
    color: var(--accent);
    word-break: break-all;
  }

  .now-entry__author {
    display: none;
  }

  .now-entry__figure {
    margin: 0 0 var(--size-6);
  }

  .now-entry__image {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--rule);
  }

  .now-entry__body {
    font-size: var(--font-size-body);
    line-height: 1.65;
  }

  .now-entry__body :global(p) {
    margin-block: var(--size-4);
    max-width: var(--measure-narrow);
  }

  .now-entry__body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .now-entry__body :global(blockquote) {
    margin-block: var(--size-5);
    margin-inline: 0;
    padding-inline-start: var(--size-4);
    border-inline-start: 2px solid var(--rule);
    color: var(--ink-mid);
    font-style: italic;
  }

  .now-entry__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--size-2);
    margin: var(--size-6) 0 0;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--ink-faint);
  }
</style>
