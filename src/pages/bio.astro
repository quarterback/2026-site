---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';

// Placeholder bios drawn from real history (no venture names) — edit freely.
const portrait = {
  src: '/ron-bronson.jpg',
  credit: 'Photograph: —',
  download: '/ron-bronson.jpg',
  spec: 'JPG, high resolution',
};

const shortBio = `Ron Bronson is a critical urbanist and design executive who helps institutions deploy public technology that actually reaches people. He was Head of Design at 18F, the U.S. General Services Administration's digital services unit, leading design across federal agencies including the VA, IRS, HHS, and DOD. He is now an Assistant Professor of Practice in the University of Michigan's Urban Technology program and founder of the Portland Digital Corps. He speaks globally on service design and delivery.`;

const extendedBio = [
  `Ron Bronson is a critical urbanist and design executive who helps institutions deploy public technology that actually reaches people. For two decades he has led digital transformation from small counties with more cows than people to the municipal, state, and federal levels — staying hands-on in delivery while building teams, growing leaders, and advising executives on modernization.`,
  `He was Head of Design at 18F, the U.S. General Services Administration's digital services unit, where he built platforms, systems, and digital services for millions of Americans across agencies including the VA, IRS, HHS, and DOD. He is now an Assistant Professor of Practice in the University of Michigan's Urban Technology program, and founded the Portland Digital Corps, an all-volunteer cohort delivering digital services for local public institutions.`,
  `His current work focuses on public mechanics: closing the latency between written policy and on-the-ground deployment, naming where human judgment lives inside delivery, and formalizing how consequential technology — increasingly agentic AI — gets deployed in daily and urban life. He writes at Making Public Work, hosts the Future Perfect Book Club, and speaks globally on service design and delivery at tech and design events.`,
];

function counts(text) {
  const words = text.trim().split(/\s+/).length;
  return { words, chars: text.length };
}
const shortCounts = counts(shortBio);
const extendedCounts = counts(extendedBio.join(' '));
---

<Base title="Biography & vita — Ron Bronson" description="Ron Bronson's biography in a few lengths, plus a downloadable portrait, for press and event use.">
  <main id="main">
    <header class="page-head">
      <p class="kicker">Biography & vita</p>
      <h1 class="page-head__title">Bio</h1>
      <p class="page-head__lede">Bios in a few lengths for when you're writing about me or my work. <a href="#" data-u="ron" data-d="ronbronson.com" rel="nofollow">Get in touch</a> with questions about current or past work.</p>
    </header>

    <div class="container bio">

      <section class="portrait">
        <figure class="portrait__fig">
          <img src={portrait.src} alt="Portrait of Ron Bronson" width="480" height="600" />
          <figcaption>{portrait.credit}</figcaption>
        </figure>
        <a class="portrait__dl" href={portrait.download} download>
          ↓ Download portrait
          <span class="portrait__spec">{portrait.spec}</span>
        </a>
      </section>

      <section class="biotext">
        <div class="biotext__head">
          <h2 class="kicker">Short biography</h2>
          <span class="biotext__count">{shortCounts.words} words · {shortCounts.chars} characters</span>
        </div>
        <p class="biotext__body">{shortBio}</p>
      </section>

      <section class="biotext">
        <div class="biotext__head">
          <h2 class="kicker">Extended biography</h2>
          <span class="biotext__count">{extendedCounts.words} words · {extendedCounts.chars} characters</span>
        </div>
        {extendedBio.map((para) => <p class="biotext__body">{para}</p>)}
      </section>

    </div>
  </main>

  <Footer />
</Base>

<style>
  .bio { padding-block: clamp(2rem, 5vw, 3.5rem); max-width: 720px; }

  .portrait {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 1.5rem 2rem;
    padding-bottom: clamp(2rem, 5vw, 3rem);
    border-bottom: 1px solid var(--rule);
  }
  .portrait__fig { margin: 0; max-width: 260px; }
  .portrait__fig img {
    width: 100%;
    height: auto;
    border-radius: 6px;
    border: 1px solid var(--border);
    display: block;
  }
  .portrait__fig figcaption {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    color: var(--ink-faint);
    margin-top: 0.6rem;
  }
  .portrait__dl {
    display: inline-flex;
    flex-direction: column;
    gap: 0.2rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 3px;
  }
  .portrait__dl:hover { text-decoration-thickness: 2.5px; }
  .portrait__spec { font-size: 0.62rem; color: var(--ink-faint); text-transform: none; letter-spacing: 0; }

  .biotext {
    padding-block: clamp(1.75rem, 4vw, 2.75rem);
    border-bottom: 1px solid var(--rule);
  }
  .biotext__head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem 1rem;
    margin-bottom: 1.1rem;
  }
  .biotext__count {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    color: var(--ink-faint);
  }
  .biotext__body {
    font-family: var(--font-body);
    font-size: 1.08rem;
    line-height: 1.6;
    color: var(--ink);
    margin: 0 0 1rem;
    max-width: none;
  }
  .biotext__body:last-child { margin-bottom: 0; }
</style>
