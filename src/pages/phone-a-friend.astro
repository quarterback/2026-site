---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';

const techStack = [
  "built hastily using Astro, Open Props, FontAwesome, TypeScript, Inter, JetBrains Mono, Netlify & GitHub"
];

const fonts: string[] = [];
---

<Base title="Phone a Friend — Ron Bronson">
  <main>

    <!-- HERO -->
    <section class="paf-hero">
      <div class="container">
        <span class="paf-hero__label">Phone a Friend</span>
        <h1 class="paf-hero__headline">Senior advisory for the problems nobody else in the building has seen before.</h1>
        <p class="paf-hero__sub">I've advised executive leaders across federal agencies, rebuilt city websites with three-person teams, stood up digital service programs from scratch, and taught the next generation how public systems actually work. If you need someone who's operated at every level of government and can help you think clearly about what comes next, I'm that call.</p>
        <a href="#get-in-touch" class="paf-hero__cta">
          Get in touch
          <i class="fas fa-arrow-down"></i>
        </a>
      </div>
    </section>

    <!-- RANGE — THE GEOGRAPHY OF EXPERIENCE -->
    <section class="paf-range">
      <div class="container">
        <h2 class="paf-section-label">Where I've been</h2>
        <div class="range-grid">
          <div class="range-item">
            <span class="range-item__context">Federal</span>
            <p>Directed strategy and design operations for a 200+ person federal digital service organization. Led a design practice of 40+ across 18F, login.gov, and cloud.gov. Advised agency leaders on procurement, delivery, and organizational design. Supported business development generating over $10M in new work. Shaped how states request billions in Medicaid funding.</p>
          </div>
          <div class="range-item">
            <span class="range-item__context">State</span>
            <p>Led statewide digital strategy for Kentucky's largest post-secondary system: 16 colleges, 70,000 students, a network of 22 web managers. Orchestrated the digital transformation from institutional identity through delivery operations.</p>
          </div>
          <div class="range-item">
            <span class="range-item__context">Municipal</span>
            <p>City IT in Bloomington, Indiana. Redesigned the city website end-to-end with a three-person team. Ran public research in supermarkets. Exit rates down 11%, bounce rate down 93%. Won Best of Indiana, featured at DrupalCon.</p>
          </div>
          <div class="range-item">
            <span class="range-item__context">Community</span>
            <p>Stood up the Portland Digital Corps after 18F closed. Zero budget, 100+ signups, 50+ volunteers, six nonprofit sites rebuilt. Organized Design For The Public, bringing 80+ civic technologists together from across the country.</p>
          </div>
          <div class="range-item">
            <span class="range-item__context">Academic</span>
            <p>Assistant Professor of Practice at the University of Michigan teaching Service Design and Public Mechanics. I run a research lab on AI and state capacity. I know how to teach these concepts because I teach them for a living.</p>
          </div>
          <div class="range-item">
            <span class="range-item__context">Military</span>
            <p>Network administrator, U.S. Air Force. Served in the Persian Gulf in support of Operation Southern Watch. Air Force Achievement Medal, Armed Forces Expeditionary Medal. I know what it means to operate under real constraints.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- WHAT I HELP WITH -->
    <section class="paf-help">
      <div class="container">
        <h2 class="paf-section-label">What I help with</h2>
        <div class="help-grid">
          <div class="help-item">
            <h3>A second read</h3>
            <p>The original "phone a friend." You need someone with range to look at something and tell you what they see. A vendor proposal, an architecture decision, a hiring plan, a strategy deck. I've given this kind of counsel to agency directors, CIOs, and city managers. Sometimes the most valuable thing is someone who's seen it before saying "this is fine" or "don't do that."</p>
          </div>
          <div class="help-item">
            <h3>Standing up digital capacity</h3>
            <p>You want to build an internal team but don't know where to start. I've done this at federal scale and at community scale with no budget at all. I can help you scope what you actually need, write the roles, structure the team, and avoid the mistakes that burn through your first year.</p>
          </div>
          <div class="help-item">
            <h3>Training and teaching</h3>
            <p>I teach service design and public mechanics at a research university. I can run workshops, brief your leadership team, or train your staff on service delivery, procurement literacy, AI governance, or how to think about the systems they're inheriting. I explain complex things clearly because that's literally my job.</p>
          </div>
          <div class="help-item">
            <h3>Delivery and deployment</h3>
            <p>Something is stalled, sideways, or about to go wrong. I've led delivery for work touching billions in federal funding, redesigned city services end-to-end, and built prototypes for military field logistics. I can diagnose what's broken, get it unstuck, and help your team finish.</p>
          </div>
          <div class="help-item">
            <h3>Procurement and vendor strategy</h3>
            <p>You're about to sign something expensive and you're not sure it's right. I've operated inside the federal procurement system, managed vendor relationships for city governments, and built the tools that help agencies evaluate what they're buying. I can read the contract and tell you where the risk is.</p>
          </div>
          <div class="help-item">
            <h3>AI and technology strategy</h3>
            <p>You're hearing about AI from vendors and leadership and you need someone who understands both the technology and the governance. I run a research lab on AI and state capacity. I've built decision transparency prototypes and benefits determination systems. I can help you figure out what's real, what's hype, and what your actual obligations are.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS — TIERS -->
    <section class="paf-tiers">
      <div class="container">
        <h2 class="paf-section-label">How we work together</h2>
        <div class="tiers-grid">
          <div class="tier">
            <span class="tier__format">60-Minute Call</span>
            <h3 class="tier__name">The Gut Check</h3>
            <p class="tier__description">You bring whatever's keeping you up at night. A vendor pitch, a stalled project, a hiring decision, a strategy question. We talk through it and you leave with clarity.</p>
          </div>
          <div class="tier">
            <span class="tier__format">1-Week Sprint</span>
            <h3 class="tier__name">The Deep Look</h3>
            <p class="tier__description">I dig into a specific problem: a failing project, an organizational gap, a technology decision that needs more than a conversation. You get a clear-eyed assessment and a path forward.</p>
          </div>
          <div class="tier">
            <span class="tier__format">Monthly Retainer</span>
            <h3 class="tier__name">The Sounding Board</h3>
            <p class="tier__description">Ongoing senior advisory. The questions that don't fit in a meeting, the decisions that compound over time. Scaling teams, building digital capacity, navigating AI, avoiding the mistakes that cost years.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- WHO THIS IS FOR -->
    <section class="paf-audience">
      <div class="container">
        <div class="audience-layout">
          <div>
            <h2 class="paf-section-label">Who this is for</h2>
            <p class="audience__graf">Cities and towns that don't have a CTO. State agencies navigating digital transformation without internal expertise. Civic technology organizations that need someone who's led at scale. Universities and programs building public interest technology curriculum.</p>
            <p class="audience__graf">If your problems feel too complex for a chatbot and too expensive for a big consultancy, you're in the right place.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- GET IN TOUCH -->
    <section class="paf-contact" id="get-in-touch">
      <div class="container">
        <div class="contact-block">
          <h2 class="paf-section-label">Get in touch</h2>
          <p class="contact-block__graf">You know who to call when the plumbing breaks. Now you know who to call when the systems break.</p>
          <a href="mailto:contact@ronbronson.com" class="contact-block__cta">
            contact@ronbronson.com
            <i class="fas fa-envelope"></i>
          </a>
          <p class="contact-block__procurement">Available for 1099 independent advisory, micro-purchase, fractional leadership, workshops, and training. No vendor affiliations. Independent expertise for the public interest.</p>
        </div>
      </div>
    </section>

  </main>

  <Footer
    techStack={techStack}
    fonts={fonts}
  />
</Base>

<style>
  /* ===== HERO ===== */
  .paf-hero {
    padding-block: clamp(5rem, 15vh, 10rem) clamp(4rem, 10vh, 7rem);
    text-align: center;
    display: flex;
    align-items: center;
    min-height: 70vh;
  }

  .paf-hero .container {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .paf-hero__label {
    font-family: var(--font-mono);
    font-size: var(--font-size-00);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--brand);
    margin-bottom: var(--size-5);
    display: block;
  }

  .paf-hero__headline {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.15;
    font-weight: var(--font-weight-7);
    color: var(--text-1);
    max-width: 22ch;
    margin: 0 auto var(--size-6);
  }

  .paf-hero__sub {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--text-2);
    line-height: 1.6;
    max-width: 55ch;
    margin: 0 auto var(--size-8);
  }

  .paf-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--size-2);
    padding: var(--size-3) var(--size-6);
    font-size: var(--font-size-1);
    font-weight: var(--font-weight-6);
    background: var(--text-1);
    color: var(--surface-1);
    border-radius: var(--radius-2);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .paf-hero__cta:hover {
    background: var(--brand);
    color: var(--surface-1);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }

  /* ===== SECTION LABEL ===== */
  .paf-section-label {
    font-family: var(--font-mono);
    font-size: var(--font-size-00);
    font-weight: var(--font-weight-6);
    color: var(--brand);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 var(--size-6) 0;
  }

  /* ===== RANGE ===== */
  .paf-range {
    background: var(--surface-2);
    padding-block: clamp(3rem, 8vh, 6rem);
  }

  .range-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--size-5);
  }

  .range-item {
    padding: var(--size-5);
    border-left: 3px solid var(--brand);
  }

  .range-item__context {
    font-family: var(--font-mono);
    font-size: var(--font-size-00);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand);
    display: block;
    margin-bottom: var(--size-3);
    font-weight: var(--font-weight-6);
  }

  .range-item p {
    font-size: var(--font-size-0);
    line-height: 1.6;
    color: var(--text-2);
    margin: 0;
    max-width: 100%;
  }

  /* ===== WHAT I HELP WITH ===== */
  .paf-help {
    padding-block: clamp(3rem, 8vh, 6rem);
  }

  .help-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--size-5);
  }

  .help-item {
    padding: var(--size-5);
    background: var(--surface-2);
    border: 1px solid var(--surface-3);
    border-radius: var(--radius-2);
    transition: border-color 0.2s;
  }

  .help-item:hover {
    border-color: var(--brand);
  }

  .help-item h3 {
    font-family: var(--font-mono);
    font-size: var(--font-size-1);
    font-weight: var(--font-weight-7);
    color: var(--text-1);
    margin: 0 0 var(--size-3) 0;
  }

  .help-item p {
    font-size: var(--font-size-0);
    line-height: 1.6;
    color: var(--text-2);
    margin: 0;
    max-width: 100%;
  }

  /* ===== TIERS ===== */
  .paf-tiers {
    background: var(--surface-2);
    padding-block: clamp(3rem, 8vh, 6rem);
  }

  .paf-tiers .paf-section-label {
    text-align: center;
  }

  .tiers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--size-5);
  }

  .tier {
    background: var(--surface-1);
    border: 2px solid var(--surface-3);
    border-radius: var(--radius-3);
    padding: var(--size-6);
    transition: border-color 0.2s, transform 0.2s;
    display: flex;
    flex-direction: column;
  }

  .tier:hover {
    border-color: var(--brand);
    transform: translateY(-4px);
  }

  .tier__format {
    font-family: var(--font-mono);
    font-size: var(--font-size-00);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand);
    margin-bottom: var(--size-3);
  }

  .tier__name {
    font-size: clamp(var(--font-size-2), 2.5vw, var(--font-size-3));
    font-weight: var(--font-weight-7);
    color: var(--text-1);
    margin: 0 0 var(--size-4) 0;
    font-family: var(--font-mono);
  }

  .tier__description {
    font-size: var(--font-size-1);
    line-height: 1.6;
    color: var(--text-2);
    margin: 0;
    flex: 1;
  }

  /* ===== AUDIENCE ===== */
  .paf-audience {
    padding-block: clamp(3rem, 8vh, 6rem);
  }

  .audience-layout {
    max-width: 55ch;
  }

  .audience__graf {
    font-size: clamp(var(--font-size-1), 2.5vw, var(--font-size-2));
    line-height: 1.5;
    color: var(--text-1);
    margin-bottom: var(--size-4);
  }

  .audience__graf:last-child {
    font-weight: var(--font-weight-6);
    margin-bottom: 0;
  }

  /* ===== CONTACT ===== */
  .paf-contact {
    background: var(--surface-2);
    padding-block: clamp(3rem, 8vh, 6rem);
  }

  .contact-block {
    max-width: 55ch;
  }

  .contact-block__graf {
    font-size: clamp(var(--font-size-1), 2.5vw, var(--font-size-2));
    line-height: 1.5;
    color: var(--text-1);
    margin-bottom: var(--size-6);
    font-weight: var(--font-weight-6);
  }

  .contact-block__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--size-3);
    padding: var(--size-4) var(--size-7);
    font-size: clamp(var(--font-size-1), 2vw, var(--font-size-2));
    font-weight: var(--font-weight-6);
    font-family: var(--font-mono);
    background: var(--text-1);
    color: var(--surface-1);
    border-radius: var(--radius-2);
    text-decoration: none;
    transition: all 0.2s ease;
    margin-bottom: var(--size-6);
  }

  .contact-block__cta:hover {
    background: var(--brand);
    color: var(--surface-1);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }

  .contact-block__cta i {
    font-size: var(--font-size-1);
  }

  .contact-block__procurement {
    font-size: var(--font-size-0);
    color: var(--text-3);
    line-height: 1.6;
    font-style: italic;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    .range-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .help-grid {
      grid-template-columns: 1fr;
    }

    .tiers-grid {
      grid-template-columns: 1fr;
      gap: var(--size-4);
    }

  }

  @media (max-width: 600px) {
    .paf-hero {
      min-height: 50vh;
      padding-block: clamp(3rem, 10vh, 5rem);
    }

    .paf-hero__headline {
      max-width: 100%;
    }

    .range-grid {
      grid-template-columns: 1fr;
      gap: var(--size-4);
    }

  }
</style>
